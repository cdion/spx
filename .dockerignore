# Build artifacts
**/bin/
**/obj/
**/TestResults/
coverage/

# Git history (keep HEAD + refs so build logs can reference commit if needed)
.git/
!.git/HEAD
!.git/refs/

# VS Code and editor files
.vscode/
.editorconfig

