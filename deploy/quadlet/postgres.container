[Unit]
Description=Spx PostgreSQL
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/postgres:17
ContainerName=postgres
HostName=postgres
Network=spx.network
EnvironmentFile=/etc/spx/prod.env
Volume=postgres-data:/var/lib/postgresql/data
Volume=/etc/spx/initdb/00-databases.sql:/docker-entrypoint-initdb.d/00-databases.sql:ro,z

[Service]
Restart=always
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
