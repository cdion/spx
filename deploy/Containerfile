# ==============================================================================
# Multi-stage build for Spx.Web and Spx.Silo
#
# Produces two named targets:
#   web   — Blazor web application
#   silo  — Orleans silo host
#
# Build:
#   podman build -f deploy/Containerfile --target web  -t localhost/spx-web:latest  .
#   podman build -f deploy/Containerfile --target silo -t localhost/spx-silo:latest .
#
# The Tailwind CLI binary must exist at tools/tailwind/bin/tailwindcss-linux-x64
# because Spx.Web.Components invokes it as a BeforeTargets=Build;Publish MSBuild target.
# ==============================================================================

ARG SDK_IMAGE=mcr.microsoft.com/dotnet/sdk:10.0.300
ARG ASPNET_IMAGE=mcr.microsoft.com/dotnet/aspnet:10.0
ARG SPX_VERSION=0.0.0-dev
ARG SPX_SOURCE=https://github.com/cdion/spx
ARG SPX_REVISION=dev

# ------------------------------------------------------------------------------
# build — restore and publish both projects
# ------------------------------------------------------------------------------
FROM ${SDK_IMAGE} AS build
ARG SPX_VERSION
ARG SPX_SOURCE
ARG SPX_REVISION
WORKDIR /src

# Copy project files first for layer-cached restore.
COPY Directory.Build.props ./
COPY src/Spx.Account.Application/Spx.Account.Application.csproj                                   src/Spx.Account.Application/
COPY src/Spx.Contracts/Spx.Game.Contract.csproj                           src/Spx.Contracts/
COPY src/Spx.Data/Spx.Data.csproj                                          src/Spx.Data/
COPY src/Spx.Game.Application/Spx.Game.Application.csproj                 src/Spx.Game.Application/
COPY src/Spx.Grains/Spx.Game.Grain.csproj                                  src/Spx.Grains/
COPY src/Spx.Nexus.Domain/Spx.Nexus.Domain.csproj                          src/Spx.Nexus.Domain/
COPY src/Spx.ServiceDefaults/Spx.ServiceDefaults.csproj                    src/Spx.ServiceDefaults/
COPY src/Spx.Silo/Spx.Silo.csproj                                          src/Spx.Silo/
COPY src/Spx.Web/Spx.Web.csproj                                            src/Spx.Web/
COPY src/Spx.Web.Components/Spx.Web.Components.csproj                     src/Spx.Web.Components/

RUN dotnet restore src/Spx.Web/Spx.Web.csproj
RUN dotnet restore src/Spx.Silo/Spx.Silo.csproj

# Copy the full source tree (filtered by .dockerignore).
COPY . .

# Download the Tailwind standalone binary using the repo's single installer path.
RUN ./tools/tailwind/install.sh

# Publish web — Tailwind CLI runs as part of BeforeTargets=Publish inside
# Spx.Web.Components; the binary must be executable and at the expected path.
#
# NOTE: --no-restore is intentionally absent. SDK 10.0.300 changed how restore
# resolves Microsoft.AspNetCore.App.Internal.Assets (which provides blazor.web.js
# and related _framework assets): the package is only included in project.assets.json
# when .razor source files are present during restore. The layer-caching restore above
# runs before COPY . . (no source files), so its project.assets.json is incomplete.
# Restore must run again here, with full source present, to produce a correct graph.
# Packages are already cached from the restore above, so this is fast.
RUN dotnet publish src/Spx.Web/Spx.Web.csproj \
        -c Release \
        -o /out/web \
    -p:Version=${SPX_VERSION} \
    -p:InformationalVersion=${SPX_VERSION} \
    -p:SourceRevisionId=${SPX_REVISION}

# Build a self-contained EF migrations bundle so the operator can run migrations
# without spinning up the full web host (which needs Orleans/Redis at startup).
RUN dotnet tool install --global dotnet-ef && \
    /root/.dotnet/tools/dotnet-ef migrations bundle \
        --project src/Spx.Data/Spx.Data.csproj \
        --startup-project src/Spx.Web/Spx.Web.csproj \
        --self-contained \
        -o /out/migrate

# Publish silo.
RUN dotnet publish src/Spx.Silo/Spx.Silo.csproj \
        -c Release \
        -o /out/silo \
    -p:Version=${SPX_VERSION} \
    -p:InformationalVersion=${SPX_VERSION} \
    -p:SourceRevisionId=${SPX_REVISION}

# ------------------------------------------------------------------------------
# runtime base image
# ------------------------------------------------------------------------------
FROM ${ASPNET_IMAGE} AS runtime-base

# Npgsql probes for GSSAPI support and loads this library when present.
RUN apt-get update && \
    apt-get install -y --no-install-recommends libgssapi-krb5-2 && \
    rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------------------------
# web runtime image
# ------------------------------------------------------------------------------
FROM runtime-base AS web
ARG SPX_VERSION
ARG SPX_SOURCE
ARG SPX_REVISION
WORKDIR /app

LABEL org.opencontainers.image.source=${SPX_SOURCE}
LABEL org.opencontainers.image.version=${SPX_VERSION}
LABEL org.opencontainers.image.revision=${SPX_REVISION}
LABEL org.opencontainers.image.description="Spx Blazor web application"

COPY --from=build /out/web ./
# Migrations bundle — run with: podman run --rm ... spx-web:latest /app/migrate
COPY --from=build /out/migrate ./migrate

# Data Protection key ring — mount a persistent volume here in production.
VOLUME /var/lib/spx/keys

ENV ASPNETCORE_URLS=http://+:8080
ENV ASPNETCORE_ENVIRONMENT=Production
EXPOSE 8080
ENTRYPOINT ["dotnet", "Spx.Web.dll"]

# ------------------------------------------------------------------------------
# silo runtime image
# ------------------------------------------------------------------------------
FROM runtime-base AS silo
ARG SPX_VERSION
ARG SPX_SOURCE
ARG SPX_REVISION
WORKDIR /app

LABEL org.opencontainers.image.source=${SPX_SOURCE}
LABEL org.opencontainers.image.version=${SPX_VERSION}
LABEL org.opencontainers.image.revision=${SPX_REVISION}
LABEL org.opencontainers.image.description="Spx Orleans silo host"

COPY --from=build /out/silo ./

ENV ASPNETCORE_URLS=http://+:8080
ENV ASPNETCORE_ENVIRONMENT=Production
# 8080: HTTP health/API   11111: Orleans silo-to-silo   30000: Orleans gateway
EXPOSE 8080 11111 30000
ENTRYPOINT ["dotnet", "Spx.Silo.dll"]
