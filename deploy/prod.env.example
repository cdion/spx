# ==============================================================================
# Production environment file for Spx
#
# Copy this to .env.prod and fill in real values.
# Deploy to the VM with:  just deploy-secrets
#
# On the VM this file lives at /etc/spx/prod.env (mode 0600).
# Both spx-silo and spx-web read it via Quadlet EnvironmentFile=.
# ==============================================================================

ASPNETCORE_ENVIRONMENT=Production

# ------------------------------------------------------------------------------
# PostgreSQL container credentials
# Used by the postgres container itself (POSTGRES_* vars) and by the app
# connection strings below.
# ------------------------------------------------------------------------------
POSTGRES_USER=spx
POSTGRES_PASSWORD=replace-me

# ------------------------------------------------------------------------------
# Connection strings
# Key format: ConnectionStrings__<name>  (double underscore = colon in .NET config)
# ------------------------------------------------------------------------------
ConnectionStrings__appdb=Host=postgres;Port=5432;Database=appdb;Username=spx;Password=replace-me
ConnectionStrings__orleansdb=Host=postgres;Port=5432;Database=orleansdb;Username=spx;Password=replace-me
ConnectionStrings__orleans-redis=redis:6379

# ------------------------------------------------------------------------------
# Orleans cluster identity
# Must be the same value in both spx-silo and spx-web containers.
# ------------------------------------------------------------------------------
Orleans__ClusterId=spx-prod
Orleans__ServiceId=spx

# ------------------------------------------------------------------------------
# Web application
# ------------------------------------------------------------------------------
# Absolute public URL — used to build confirmation and password-reset links.
AppUrl__BaseUrl=https://mostlyhuman.ca

# Resend email API (https://resend.com)
Resend__ApiKey=replace-me
Resend__FromEmail=noreply@mostlyhuman.ca
Resend__FromName=Spx

# Data Protection key ring path inside the container.
# Must match the volume mount path in the web Quadlet unit.
DataProtection__KeyRingPath=/var/lib/spx/keys
