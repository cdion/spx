{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: web",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/Spx.Web/Spx.Web.csproj"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "build: silo",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/Spx.Silo/Spx.Silo.csproj"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "build: apphost",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/Spx.AppHost/Spx.AppHost.csproj"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "tests: restore tools",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "tool",
        "restore"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "tests: run account",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/Spx.Account.Tests/Spx.Account.Tests.csproj"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "tests: run games unit",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/Spx.Game.Application.Tests/Spx.Game.Application.Tests.csproj"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "tests: run games",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/Spx.Game.Application.IntegrationTests/Spx.Game.Application.IntegrationTests.csproj"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "tests: run grains",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/Spx.Grains.Tests/Spx.Grains.Tests.csproj"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "tests: run web",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/Spx.Web.Tests/Spx.Web.Tests.csproj"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "tests: run",
      "dependsOn": [
        "tests: run account",
        "tests: run games unit",
        "tests: run games",
        "tests: run grains",
        "tests: run web"
      ],
      "dependsOrder": "sequence",
      "group": "test"
    },
    {
      "label": "tests: clean coverage",
      "type": "shell",
      "command": "rm",
      "args": [
        "-rf",
        "${workspaceFolder}/coverage"
      ],
      "problemMatcher": []
    },
    {
      "label": "tests: collect coverage account",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/Spx.Account.Tests/Spx.Account.Tests.csproj",
        "--collect:XPlat Code Coverage",
        "--results-directory",
        "${workspaceFolder}/coverage/testresults"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "tests: collect coverage games unit",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/Spx.Game.Application.Tests/Spx.Game.Application.Tests.csproj",
        "--collect:XPlat Code Coverage",
        "--results-directory",
        "${workspaceFolder}/coverage/testresults"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "tests: collect coverage games",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/Spx.Game.Application.IntegrationTests/Spx.Game.Application.IntegrationTests.csproj",
        "--collect:XPlat Code Coverage",
        "--results-directory",
        "${workspaceFolder}/coverage/testresults"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "tests: collect coverage grains",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/Spx.Grains.Tests/Spx.Grains.Tests.csproj",
        "--collect:XPlat Code Coverage",
        "--results-directory",
        "${workspaceFolder}/coverage/testresults"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "tests: collect coverage web",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/Spx.Web.Tests/Spx.Web.Tests.csproj",
        "--collect:XPlat Code Coverage",
        "--results-directory",
        "${workspaceFolder}/coverage/testresults"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "tests: collect coverage",
      "dependsOn": [
        "tests: collect coverage account",
        "tests: collect coverage games unit",
        "tests: collect coverage games",
        "tests: collect coverage grains",
        "tests: collect coverage web"
      ],
      "dependsOrder": "sequence",
      "group": "test"
    },
    {
      "label": "tests: report html",
      "type": "shell",
      "command": "dotnet tool run reportgenerator -- '-reports:${workspaceFolder}/coverage/testresults/**/coverage.cobertura.xml' '-targetdir:${workspaceFolder}/coverage/html' '-reporttypes:Html'",
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "tests: coverage html",
      "dependsOn": [
        "tests: restore tools",
        "tests: clean coverage",
        "tests: collect coverage",
        "tests: report html"
      ],
      "dependsOrder": "sequence",
      "group": "test"
    },
    {
      "label": "tailwind: build css",
      "type": "shell",
      "command": "${workspaceFolder}/tools/tailwind/bin/tailwindcss-linux-x64",
      "args": [
        "-i",
        "${workspaceFolder}/src/Spx.Web/Styles/app.css",
        "-o",
        "${workspaceFolder}/src/Spx.Web/wwwroot/app.css",
        "--minify"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "tailwind: watch css",
      "type": "shell",
      "command": "${workspaceFolder}/tools/tailwind/bin/tailwindcss-linux-x64",
      "args": [
        "-i",
        "${workspaceFolder}/src/Spx.Web/Styles/app.css",
        "-o",
        "${workspaceFolder}/src/Spx.Web/wwwroot/app.css",
        "--watch"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "tailwind",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*tailwindcss.*",
          "endsPattern": ".*Done in .*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "apphost: run",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/Spx.AppHost/Spx.AppHost.csproj"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "apphost",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Distributed application starting\\..*",
          "endsPattern": ".*Distributed application started\\. Press Ctrl\\+C to shut down\\..*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "apphost: watch",
      "type": "shell",
      "command": "${workspaceFolder}/tools/dev/run-apphost-watch-and-open-dashboard.sh",
      "isBackground": true,
      "problemMatcher": {
        "owner": "apphost-watch",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*dotnet watch.*|.*Distributed application starting\\..*",
          "endsPattern": ".*Distributed application started\\. Press Ctrl\\+C to shut down\\..*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "dev: apphost + tailwind",
      "dependsOn": [
        "tailwind: watch css",
        "apphost: watch"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}