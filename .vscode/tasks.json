    {
      "label": "tests: report coverage html",
      "type": "shell",
      "command": "dotnet tool run reportgenerator -- '-reports:${workspaceFolder}/coverage/testresults/**/coverage.cobertura.xml' '-targetdir:${workspaceFolder}/coverage/html' '-reporttypes:Html'",
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "tests: generate coverage html",
      "dependsOn": [
        "tests: restore tools",
        "tests: clean coverage",
        "tests: collect coverage all",
        "tests: report coverage html"
      ],
      "dependsOrder": "sequence",
      "group": "test"
    },
    {
      "label": "tailwind: build css",
      "type": "shell",
      "command": "${workspaceFolder}/tools/tailwind/bin/tailwindcss-linux-x64",
      "args": [
        "-i",
        "${workspaceFolder}/src/Spx.Web.Components/Styles/app.css",
        "-o",
        "${workspaceFolder}/src/Spx.Web.Components/wwwroot/app.css",
        "--minify"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/Spx.Web.Components"
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "dev: watch tailwind",
      "type": "shell",
      "command": "${workspaceFolder}/tools/tailwind/bin/tailwindcss-linux-x64",
      "args": [
        "-i",
        "${workspaceFolder}/src/Spx.Web.Components/Styles/app.css",
        "-o",
        "${workspaceFolder}/src/Spx.Web.Components/wwwroot/app.css",
        "--watch"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/Spx.Web.Components"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "tailwind",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*tailwindcss.*",
          "endsPattern": ".*Done in .*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "apphost: run",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/Spx.AppHost/Spx.AppHost.csproj"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "apphost",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Distributed application starting\\..*",
          "endsPattern": ".*Distributed application started\\. Press Ctrl\\+C to shut down\\..*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "dev: watch apphost",
      "type": "shell",
      "command": "systemctl --user stop spx-apphost.scope 2>/dev/null; env DOTNET_USE_POLLING_FILE_WATCHER=1 DOTNET_WATCH_RESTART_ON_RUDE_EDIT=1 systemd-run --user --scope --unit=spx-apphost dotnet watch --project ${workspaceFolder}/src/Spx.AppHost/Spx.AppHost.csproj run",
      "isBackground": true,
      "problemMatcher": {
        "owner": "apphost-watch",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*dotnet watch.*|.*Distributed application starting\\..*",
          "endsPattern": ".*Distributed application started\\. Press Ctrl\\+C to shut down\\..*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "dev: watch apphost + tailwind",
      "dependsOn": [
        "dev: watch tailwind",
        "dev: watch apphost"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "dev: watch playground",
      "type": "shell",
      "command": "env DOTNET_USE_POLLING_FILE_WATCHER=1 DOTNET_WATCH_RESTART_ON_RUDE_EDIT=1 dotnet watch --project ${workspaceFolder}/src/Spx.Web.Playground/Spx.Web.Playground.csproj",
      "isBackground": true,
      "problemMatcher": {
        "owner": "playground-watch",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*dotnet watch.*",
          "endsPattern": ".*Application started\\..*|.*Now listening on.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "dev: watch playground + tailwind",
      "dependsOn": [
        "dev: watch tailwind",
        "dev: watch playground"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}