@* Reusable checkbox toggle used in story control panels.
   Replaces the repeated <label> + <input type="checkbox"> boilerplate
   found in TimelineStory, NexusPageStory, and NexusTopInfoBarStory. *@

<label class="ui-panel-card-inner flex items-center gap-2 text-xs text-slate-300">
    <input type="checkbox" @bind="Value" disabled="@Disabled" />
    @Label
</label>

@code {
    /// <summary>
    /// Whether the toggle is checked.
    /// </summary>
    [Parameter]
    public bool Value { get; set; }

    /// <summary>
    /// Raised when the toggle changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> ValueChanged { get; set; }

    /// <summary>
    /// Whether the toggle is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Label displayed next to the checkbox.
    /// </summary>
    [Parameter]
    public string Label { get; set; } = "";
}
