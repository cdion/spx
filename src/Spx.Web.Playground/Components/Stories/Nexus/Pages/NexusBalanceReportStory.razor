@page "/nexus/balance"
@rendermode InteractiveServer
@using System.Text.Json
@using System.Text.Json.Serialization
@using Microsoft.JSInterop
@using Spx.Nexus.Simulation
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Nexus Balance Report</PageTitle>\n\n<style>\n    .ui-balance-heatmap-cell.is-mirror {\n        opacity: 0.35;\n        outline: 1px dashed rgb(255 255 255 / 0.2);\n    }\n</style>

@if (_reportJson is null)
{
    <section class="ui-surface-empty mx-auto max-w-2xl text-slate-400">
        Running simulation…
    </section>
}
else
{
    <section class="ui-page max-w-7xl gap-6">
        <PageHero Eyebrow="Balance" Title="Nexus Tactical Balance Report"
                  Description="Bootstrap report for one-system balance using the live Nexus combat resolver." />

        <div class="ui-panel-card flex flex-wrap gap-4">
            <div class="flex min-w-44 flex-col gap-1.5">
                <label class="ui-panel-label" for="scenario-select">Scenario</label>
                <select class="ui-select" id="scenario-select"></select>
            </div>
            <div class="flex min-w-44 flex-col gap-1.5">
                <label class="ui-panel-label" for="metric-select">Heatmap Metric</label>
                <select class="ui-select" id="metric-select"></select>
            </div>
            <div class="flex min-w-44 flex-col gap-1.5">
                <label class="ui-panel-label" for="attacker-select">Attacker Profile</label>
                <select class="ui-select" id="attacker-select"></select>
            </div>
            <div class="flex min-w-44 flex-col gap-1.5">
                <label class="ui-panel-label" for="defender-select">Defender Profile</label>
                <select class="ui-select" id="defender-select"></select>
            </div>
        </div>

        <div class="flex flex-col gap-6">
            <section class="ui-panel-card flex flex-col gap-4">
                <div>
                    <h2 class="ui-section-title">Matchup Heatmap</h2>
                    <p class="ui-type-meta mt-1">Profile-vs-profile tactical performance for the selected scenario and
                        metric.</p>
                    </div>
                    <div class="overflow-x-auto">
                        <div id="heatmap"></div>
                    </div>
                </section>

                <div id="matchup-stats" class="ui-panel-card"></div>

                <div class="grid gap-6 lg:grid-cols-[1.3fr_0.9fr]">
                    <section class="ui-panel-card flex flex-col gap-6">
                        <div class="flex flex-col gap-2">
                            <h2 class="ui-section-title">Selected Matchup</h2>
                            <div id="matchup-meta" class="flex flex-col gap-1.5 text-sm text-slate-300"></div>
                        </div>
                        <div class="flex flex-col gap-2">
                            <h2 class="ui-section-title">Phase Breakdown</h2>
                            <div id="phase-chart"></div>
                        </div>
                        <div class="flex flex-col gap-2">
                            <h2 class="ui-section-title">Expected Survivors</h2>
                            <div id="survivor-chart"></div>
                        </div>
                    </section>

                    <section class="ui-panel-card flex flex-col gap-4">
                        <div>
                            <h2 class="ui-section-title">Counter Table</h2>
                            <p class="ui-type-meta mt-1">All defender outcomes against the selected attacker, sorted by the
                                active metric.</p>
                            </div>
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm text-slate-300">
                                    <thead>
                                        <tr class="border-b border-white/10 text-left">
                                            <th class="pb-2 pr-4 text-xs font-semibold text-slate-400">Defender</th>
                                            <th class="pb-2 pr-4 text-xs font-semibold text-slate-400">Attacker Win</th>
                                            <th class="pb-2 pr-4 text-xs font-semibold text-slate-400">Dmg Efficiency</th>
                                            <th class="pb-2 pr-4 text-xs font-semibold text-slate-400">Cost Retention</th>
                                            <th class="pb-2 pr-4 text-xs font-semibold text-slate-400">Control</th>
                                            <th class="pb-2 pr-4 text-xs font-semibold text-slate-400">Cost Delta</th>
                                            <th class="pb-2 text-xs font-semibold text-slate-400">Dominant Phase</th>
                                        </tr>
                                    </thead>
                                    <tbody id="counter-table-body"></tbody>
                                </table>
                            </div>
                        </section>
                    </div>
                </div>
            </section>
        }

@code {
    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        Converters = { new JsonStringEnumConverter() },
    };

    private string? _reportJson;
    private bool _jsInitialized;
    private IJSObjectReference? _jsModule;

    protected override async Task OnInitializedAsync()
    {
        var data = await Task.Run(() => TacticalSimulator.Run(TacticalSimulationSettings.Default));
        _reportJson = JsonSerializer.Serialize(data, JsonOptions);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_reportJson is not null && !_jsInitialized)
        {
            _jsInitialized = true;
            _jsModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/nexus-balance-report.js");
            await _jsModule.InvokeVoidAsync("initNexusBalanceReport", _reportJson);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
            await _jsModule.DisposeAsync();
    }
}
