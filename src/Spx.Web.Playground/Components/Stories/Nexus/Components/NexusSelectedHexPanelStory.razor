@page "/stories/nexus/components/selected-hex-panel"
@rendermode InteractiveServer
@attribute [Story("Nexus", "Components", "Selected Hex Panel")]

<StoryShell Title="Selected Hex Panel" Description="The real component — fleet selection, capacity bar, build menu, and Nexus gate.">

<div class="mb-4">
    <VariantPicker Variants="_scenarioLabels" SelectedIndex="_activeIndex" SelectedIndexChanged="HandleScenarioChanged" />
</div>

<NexusSelectedHexPanel System="@_active.System"
                       CurrentPlayer="@(new NexusPlayerContext(NexusStoryFixtures.Player1Id, "Captain Red", NexusFactionColor.Red, HomeCoord: NexusMapTopology.Player1HomeCoord))"
                       Opponent="@(new NexusPlayerContext(NexusStoryFixtures.Player2Id, "Captain Blue", NexusFactionColor.Blue, HomeCoord: NexusMapTopology.Player2HomeCoord))"
                       CurrentPlayerGateProgress="@_active.GateProgress" IsEditable="true"
                       ProjectedEnergy="15" AvailableStacks="@_active.System.GetPlayerMovableStacks(NexusStoryFixtures.Player1Id)"
                       PendingBuildOrders="@_pendingBuildOrders"
                       PlayerDesigns="@NexusStoryFixtures.Player1Designs"
                       OpponentDesigns="@NexusStoryFixtures.Player2Designs"
                       OnOrderDraftRequested="HandleOrderDraftRequested" />

@if (_lastOrder is not null)
{
    <div class="mt-4 rounded-lg border border-white/10 bg-slate-950/40 p-3 text-xs text-slate-500">
        Last order: @_lastOrder
    </div>
}

</StoryShell>

@code {
    private static readonly IReadOnlyList<NexusStoryFixtures.SelectedHexScenario> _scenarios =
        NexusStoryFixtures.CreateSelectedHexScenarios();
    private static readonly string[] _scenarioLabels =
        _scenarios.Select(s => s.Label).ToArray();

    private int _activeIndex;
    private NexusStoryFixtures.SelectedHexScenario _active = _scenarios[0];
    private IReadOnlyList<NexusBuildOrder> _pendingBuildOrders = [];
    private string? _lastOrder;

    private Task HandleScenarioChanged(int index)
    {
        SelectScenario(index);
        return Task.CompletedTask;
    }

    private void SelectScenario(int index)
    {
        _activeIndex = index;
        _active = _scenarios[index];
        _pendingBuildOrders = [];
        _lastOrder = null;
    }

    private Task HandleOrderDraftRequested(OrderDraftRequest request)
    {
        _lastOrder = request.Kind switch
        {
            OrderDraftRequestKind.MoveDraftChanged =>
                $"Move draft: {request.MoveDraftStacks.Length} stack(s)",
            OrderDraftRequestKind.BuildDraftAdjusted =>
                $"Build {request.BuildAdjustment} × {request.DesignId}",
            OrderDraftRequestKind.NexusGateDraftChanged =>
                $"Nexus gate: {request.BeginNexusGate}",
            _ => request.ToString(),
        };

        if (request.Kind == OrderDraftRequestKind.BuildDraftAdjusted && request.DesignId is { } designId)
        {
            _pendingBuildOrders = request.BuildAdjustment switch
            {
                BuildDraftAdjustmentKind.AddOne => AdjustBuildOrder(designId, +1),
                BuildDraftAdjustmentKind.RemoveOne => AdjustBuildOrder(designId, -1),
                BuildDraftAdjustmentKind.RemoveAll => _pendingBuildOrders
                    .Where(o => o.DesignId != designId)
                    .ToList(),
                BuildDraftAdjustmentKind.AddMax => _pendingBuildOrders,
                _ => _pendingBuildOrders,
            };
        }

        return Task.CompletedTask;
    }

    private IReadOnlyList<NexusBuildOrder> AdjustBuildOrder(Guid designId, int delta)
    {
        var list = _pendingBuildOrders.ToList();
        var index = list.FindIndex(o => o.DesignId == designId);
        if (index >= 0)
        {
            var next = list[index].Count + delta;
            if (next <= 0)
                list.RemoveAt(index);
            else
                list[index] = list[index] with { Count = next };
        }
        else if (delta > 0)
        {
            list.Add(new NexusBuildOrder(designId, delta));
        }

        return list;
    }
}
