@page "/stories/nexus/components/category-pip"
@rendermode InteractiveServer
@using Spx.Nexus.Domain
@using Spx.Web.Components.Nexus

<StoryHeader Title="Category Pip">
    <code class="text-sky-300">NexusCategoryPip</code> icons for all three hull categories at
    <code class="text-sky-300">Small</code> and <code class="text-sky-300">Medium</code> sizes.
</StoryHeader>

<div class="grid grid-cols-3 gap-6">

    @* Strike *@
    <div class="ui-panel-card space-y-4">
        <p class="ui-type-overline text-slate-500">Strike</p>

        <div class="flex items-center gap-4">
            <div class="flex flex-col items-center gap-1">
                <NexusCategoryPip Category="NexusUnitCategory.Strike" Size="NexusPipSize.Small" />
                <span class="text-xs text-slate-500">Small</span>
            </div>
            <div class="flex flex-col items-center gap-1">
                <NexusCategoryPip Category="NexusUnitCategory.Strike" Size="NexusPipSize.Medium" />
                <span class="text-xs text-slate-500">Medium</span>
            </div>
        </div>

        <div class="flex flex-col gap-1">
            <span class="text-xs text-slate-500">Custom fill/stroke</span>
            <div class="flex items-center gap-4">
                <NexusCategoryPip Category="NexusUnitCategory.Strike" Size="NexusPipSize.Small"
                             Fill="#fbbf24" Stroke="#d97706" />
                <NexusCategoryPip Category="NexusUnitCategory.Strike" Size="NexusPipSize.Medium"
                             Fill="#60a5fa" Stroke="#2563eb" />
                <NexusCategoryPip Category="NexusUnitCategory.Strike" Size="NexusPipSize.Small"
                             Fill="#f87171" Stroke="#dc2626" />
            </div>
        </div>
    </div>

    @* Capital *@
    <div class="ui-panel-card space-y-4">
        <p class="ui-type-overline text-slate-500">Capital</p>

        <div class="flex items-center gap-4">
            <div class="flex flex-col items-center gap-1">
                <NexusCategoryPip Category="NexusUnitCategory.Capital" Size="NexusPipSize.Small" />
                <span class="text-xs text-slate-500">Small</span>
            </div>
            <div class="flex flex-col items-center gap-1">
                <NexusCategoryPip Category="NexusUnitCategory.Capital" Size="NexusPipSize.Medium" />
                <span class="text-xs text-slate-500">Medium</span>
            </div>
        </div>

        <div class="flex flex-col gap-1">
            <span class="text-xs text-slate-500">Custom fill/stroke</span>
            <div class="flex items-center gap-4">
                <NexusCategoryPip Category="NexusUnitCategory.Capital" Size="NexusPipSize.Small"
                             Fill="#fbbf24" Stroke="#d97706" />
                <NexusCategoryPip Category="NexusUnitCategory.Capital" Size="NexusPipSize.Medium"
                             Fill="#60a5fa" Stroke="#2563eb" />
                <NexusCategoryPip Category="NexusUnitCategory.Capital" Size="NexusPipSize.Small"
                             Fill="#f87171" Stroke="#dc2626" />
            </div>
        </div>
    </div>

    @* Planetary *@
    <div class="ui-panel-card space-y-4">
        <p class="ui-type-overline text-slate-500">Planetary</p>

        <div class="flex items-center gap-4">
            <div class="flex flex-col items-center gap-1">
                <NexusCategoryPip Category="NexusUnitCategory.Planetary" Size="NexusPipSize.Small" />
                <span class="text-xs text-slate-500">Small</span>
            </div>
            <div class="flex flex-col items-center gap-1">
                <NexusCategoryPip Category="NexusUnitCategory.Planetary" Size="NexusPipSize.Medium" />
                <span class="text-xs text-slate-500">Medium</span>
            </div>
        </div>

        <div class="flex flex-col gap-1">
            <span class="text-xs text-slate-500">Custom fill/stroke</span>
            <div class="flex items-center gap-4">
                <NexusCategoryPip Category="NexusUnitCategory.Planetary" Size="NexusPipSize.Small"
                             Fill="#fbbf24" Stroke="#d97706" />
                <NexusCategoryPip Category="NexusUnitCategory.Planetary" Size="NexusPipSize.Medium"
                             Fill="#60a5fa" Stroke="#2563eb" />
                <NexusCategoryPip Category="NexusUnitCategory.Planetary" Size="NexusPipSize.Small"
                             Fill="#f87171" Stroke="#dc2626" />
            </div>
        </div>
    </div>
</div>

@* Inline usage demo — as used inside UnitStackList / SelectedHexPanel *@
<div class="mt-6 ui-panel-card space-y-2">
    <p class="ui-type-overline text-slate-500">Inline as used in the UI</p>
    <div class="space-y-2">
        <p class="ui-type-overline mb-1 text-slate-500">
            <NexusCategoryPip Category="NexusUnitCategory.Strike" Size="NexusPipSize.Small" /> Strike
        </p>
        <p class="ui-type-overline mb-1 text-slate-500">
            <NexusCategoryPip Category="NexusUnitCategory.Capital" Size="NexusPipSize.Small" /> Capital
        </p>
        <p class="ui-type-overline mb-1 text-slate-500">
            <NexusCategoryPip Category="NexusUnitCategory.Planetary" Size="NexusPipSize.Small" /> Planetary
        </p>
    </div>
    <div class="flex flex-wrap items-center gap-3 pt-2">
        <span class="text-sm text-slate-300"><NexusCategoryPip Category="NexusUnitCategory.Strike" /> Fighter ×2</span>
        <span class="text-sm text-slate-300"><NexusCategoryPip Category="NexusUnitCategory.Capital" /> Carrier ×1</span>
        <span class="text-sm text-slate-300"><NexusCategoryPip Category="NexusUnitCategory.Planetary" /> Infantry ×4</span>
    </div>
</div>
