@page "/stories/nexus/components/top-info-bar"
@rendermode InteractiveServer
@attribute [Story("Nexus", "Components", "Top Info Bar")]

<StoryShell Title="Nexus Top Info Bar">

<p class="text-sm text-slate-400 mb-5">
    <code class="text-sky-300">NexusGameplayTopInfoBar</code> showing both players, faction colors, energy, round, and
    presence.
</p>

<div class="mb-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
    <StoryToggle @bind-Value="_currentSubmitted" Label="Current submitted" />
    <StoryToggle @bind-Value="_opponentSubmitted" Label="Opponent submitted" />
    <label class="ui-panel-card-inner flex items-center gap-2 text-xs text-slate-300">
        <span>Round</span>
        <input type="number" min="1" class="w-16 rounded border border-white/10 bg-slate-950/70 px-2 py-1"
               @bind="_round" />
    </label>
    <label class="ui-panel-card-inner flex items-center gap-2 text-xs text-slate-300">
        <span>Current ⚡</span>
        <input type="number" min="0" class="w-16 rounded border border-white/10 bg-slate-950/70 px-2 py-1"
               @bind="_currentEnergy" />
    </label>
    <label class="ui-panel-card-inner flex items-center gap-2 text-xs text-slate-300">
        <span>Opponent ⚡</span>
        <input type="number" min="0" class="w-16 rounded border border-white/10 bg-slate-950/70 px-2 py-1"
               @bind="_opponentEnergy" />
    </label>
</div>

<NexusGameplayTopInfoBar RoundNumber="@_round"
                         CurrentPlayer="@_currentPlayer"
                         Opponent="@_opponentPlayer" />

<div class="mt-3 flex flex-wrap gap-2">
    <button class="ui-pg-ghost-btn" @onclick="SwapFactions">
        Swap factions
    </button>
</div>

</StoryShell>

@code {
    private int _round = 4;
    private bool _currentSubmitted;
    private bool _opponentSubmitted = true;
    private int _currentEnergy = 17;
    private int _opponentEnergy = 12;
    private int _currentCapitalCount = 3;
    private int _opponentCapitalCount = 2;
    private int _currentSupplyPool = 10;
    private int _opponentSupplyPool = 8;
    private NexusFactionColor _currentFaction = NexusFactionColor.Blue;
    private NexusFactionColor _opponentFaction = NexusFactionColor.Red;

    private NexusPlayerInfoBarModel _currentPlayer =>
        new()
        {
            PlayerName = "Player One",
            Faction = _currentFaction,
            Energy = _currentEnergy,
            SupplyPool = _currentSupplyPool,
            CapitalCount = _currentCapitalCount,
            HasSubmittedOrders = _currentSubmitted,
        };

    private NexusPlayerInfoBarModel _opponentPlayer =>
        new()
        {
            PlayerName = "Player Two",
            Faction = _opponentFaction,
            Energy = _opponentEnergy,
            SupplyPool = _opponentSupplyPool,
            CapitalCount = _opponentCapitalCount,
            HasSubmittedOrders = _opponentSubmitted,
        };

    private void SwapFactions()
    {
        (_currentFaction, _opponentFaction) = (_opponentFaction, _currentFaction);
    }
}
