@page "/stories/nexus/components/pending-orders"
@rendermode InteractiveServer
@attribute [Story("Nexus", "Components", "Pending Orders")]

<StoryShell Title="Nexus Pending Orders" Description="NexusPendingOrdersListComponent — your pending orders list.">

<section class="ui-surface-section p-4 lg:p-5 space-y-4">
    <div class="flex items-center justify-between">
        <p class="ui-panel-label">Pending Orders</p>
    </div>

    <NexusPendingOrdersListComponent MoveOrders="@_moveOrders" BuildOrders="@_buildOrders" BeginNexusGate="@_gate"
                                     CurrentPlayer="@(new NexusPlayerContext(default, "Player One", NexusFactionColor.Red, HomeCoord: NexusMapTopology.Player1HomeCoord))"
                                     CurrentPlayerHomeCoord="@NexusMapTopology.Player1HomeCoord"
                                     Designs="@_designs" IsEditable
                                     OnPendingOrderRequested="HandlePendingOrderRequest" />
</section>

</StoryShell>

@code {
    private static readonly ImmutableArray<NexusUnitDesign> _designs =
    [
        new() { DesignId = Guid.Parse("bbbbbbbb-0000-0000-0000-000000000001"), Name = "Carrier", Hull = NexusUnitCategory.Capital },
        new() { DesignId = Guid.Parse("bbbbbbbb-0000-0000-0000-000000000003"), Name = "Infantry", Hull = NexusUnitCategory.Planetary },
    ];

    // Editable state
    private readonly List<NexusMoveOrder> _moveOrders =
    [
        new(
            NexusMapTopology.Player1HomeCoord,
            ImmutableArray.Create(new HexCoord(1, -2)),
            ImmutableArray.Create(
                new NexusUnitStackGroup(Guid.Parse("bbbbbbbb-0000-0000-0000-000000000001"), NexusUnitCategory.Capital, 4, 1, "Carrier"),
                new NexusUnitStackGroup(Guid.Parse("bbbbbbbb-0000-0000-0000-000000000003"), NexusUnitCategory.Planetary, 1, 2, "Infantry")
            )
        ),
    ];

    private readonly List<NexusBuildOrder> _buildOrders = [];
    private bool _gate;

    private void HandlePendingOrderRequest(PendingOrderRequest request)
    {
        switch (request.Kind)
        {
            case PendingOrderRequestKind.RemoveMoveOrder:
                _moveOrders.Remove(request.MoveOrder!);
                return;
            case PendingOrderRequestKind.RemoveBuildOrder:
                _buildOrders.Remove(request.BuildOrder!);
                return;
            case PendingOrderRequestKind.ClearNexusGate:
                _gate = false;
                return;
        }
    }
}
