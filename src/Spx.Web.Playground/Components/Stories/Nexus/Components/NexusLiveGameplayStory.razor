@page "/stories/nexus/components/live-gameplay"
@rendermode InteractiveServer
@using Spx.Game.Application.Nexus.Features.EnsureNexusSession
@using Spx.Game.Application.Nexus.Features.GetNexusPage
@using Spx.Game.Application.Nexus.Features.ManageDesign
@using Spx.Game.Application.Nexus.Features.SubmitOrders

<div class="flex h-full flex-col">
    <StoryHeader Title="Nexus Live Gameplay">
        Real <code class="text-sky-300">NexusEngine</code> — play both sides.
        Submit orders as one player, switch perspective, submit as the other.
    </StoryHeader>

    @if (_isLoading)
    {
        <section class="ui-surface-empty mx-auto max-w-4xl text-slate-300">
            Loading game...
        </section>
    }
    else
    {
        <div class="mb-4 flex flex-wrap items-center gap-3">
            <button class="ui-button-control-info" @onclick="SwitchPlayer" disabled="@(_view.Completion is not null)">
                Viewing: <span class="font-semibold text-white">@PlayerName(_viewingPlayerId)</span>
                &nbsp;&rarr;&nbsp;Switch to @PlayerName(OtherPlayerId)
            </button>

            <div class="flex items-center gap-2 rounded-lg border border-white/10 bg-slate-900/40 px-3 py-1.5 text-xs">
                <span class="@PlayerStatusClass(Player1Id)">@PlayerName(Player1Id)</span>
                <span class="text-slate-600">/</span>
                <span class="@PlayerStatusClass(Player2Id)">@PlayerName(Player2Id)</span>
            </div>

            @if (_view.Completion is not null)
            {
                <span
                    class="rounded-lg border border-emerald-500/30 bg-emerald-900/10 px-3 py-1.5 text-xs font-semibold text-emerald-300">
                    Game over
                </span>
            }

            <button class="ui-button-control-danger ml-auto" @onclick="Restart">
                Restart
            </button>
        </div>

        <div class="flex min-h-0 flex-1 flex-col">
            <NexusGameplayPanel Session="_view" Lobby="_lobby" IsSubmittingAction="false" GameplayError="@_error"
                                OnSubmitOrders="HandleSubmitOrders"
                                OnCreateDesign="HandleCreateDesign" OnDeleteDesign="HandleDeleteDesign"
                                GameplayErrorCleared="ClearGameplayError" />
        </div>
    }
</div>

@code {
    private static readonly Guid Player1Id = NexusStoryFixtures.Player1Id;
    private static readonly Guid Player2Id = NexusStoryFixtures.Player2Id;
    private const string Player1UserId = Spx.Web.Playground.Nexus.PlaygroundNexusUsers.Player1UserId;
    private const string Player2UserId = Spx.Web.Playground.Nexus.PlaygroundNexusUsers.Player2UserId;

    private Guid _gameId;
    private string _viewingUserId = Player1UserId;
    private Guid _viewingPlayerId = Player1Id;
    private bool _isLoading = true;
    private NexusGameView _view = null!;
    private GameLobbyView _lobby = null!;
    private string? _error;

    [Inject]
    private IEnsureNexusSessionHandler EnsureNexusSessionHandler { get; set; } = null!;

    [Inject]
    private IGetNexusPageHandler GetNexusPageHandler { get; set; } = null!;

    [Inject]
    private ISubmitOrdersHandler SubmitOrdersHandler { get; set; } = null!;

    [Inject]
    private IManageDesignHandler ManageDesignHandler { get; set; } = null!;

    private Guid OtherPlayerId => _viewingPlayerId == Player1Id ? Player2Id : Player1Id;
    private string OtherUserId => _viewingUserId == Player1UserId ? Player2UserId : Player1UserId;

    protected override async Task OnInitializedAsync() => await InitGameAsync();

    private async Task InitGameAsync()
    {
        _gameId = Guid.NewGuid();
        _viewingUserId = Player1UserId;
        _viewingPlayerId = Player1Id;
        _isLoading = true;
        _error = null;

        if (!await EnsureNexusSessionHandler.HandleAsync(_gameId))
        {
            _error = "Playground session could not be initialized.";
            _isLoading = false;
            return;
        }

        await RefreshViewAsync();
    }

    private async Task SwitchPlayer()
    {
        _viewingUserId = OtherUserId;
        _viewingPlayerId = OtherPlayerId;
        _isLoading = true;
        _error = null;
        await RefreshViewAsync();
    }

    private Task Restart() => InitGameAsync();

    private async Task HandleSubmitOrders(NexusTurnOrdersCommand command)
    {
        var outcome = await SubmitOrdersHandler.HandleAsync(_gameId, command);
        _error = outcome is GameSessionCommandFailed failed ? failed.ErrorMessage : null;
        if (_error is null)
            await RefreshViewAsync();
    }

    private async Task HandleCreateDesign(NexusCreateDesignCommand command)
    {
        var outcome = await ManageDesignHandler.CreateDesignAsync(_gameId, command);
        _error = outcome is GameSessionCommandFailed failed ? failed.ErrorMessage : null;
        if (_error is null)
            await RefreshViewAsync();
    }

    private async Task HandleDeleteDesign(Guid designId)
    {
        var outcome = await ManageDesignHandler.DeleteDesignAsync(
            _gameId,
            new NexusDeleteDesignCommand(_viewingPlayerId, designId));
        _error = outcome is GameSessionCommandFailed failed ? failed.ErrorMessage : null;
        if (_error is null)
            await RefreshViewAsync();
    }

    private Task ClearGameplayError()
    {
        _error = null;
        return Task.CompletedTask;
    }

    private async Task RefreshViewAsync()
    {
        var page = await GetNexusPageHandler.HandleAsync(_gameId, _viewingUserId);
        if (page is null || page.Session is null)
        {
            _error ??= "Playground session unavailable.";
            _isLoading = false;
            return;
        }

        _lobby = page.Lobby;
        _view = page.Session;
        _isLoading = false;
    }

    private static string PlayerName(Guid id) =>
        NexusStoryFixtures.PlayerNames.TryGetValue(id, out var n) ? n : id.ToString("N")[..8];

    private string PlayerStatusClass(Guid id)
    {
        var player = _view.CurrentPlayer.PlayerId == id
            ? _view.CurrentPlayer
            : _view.Opponent.PlayerId == id
                ? _view.Opponent
                : null;
        if (player is null)
            return "text-slate-500";
        return player.HasSubmittedOrders ? "font-medium text-emerald-400" : "text-slate-400";
    }
}
