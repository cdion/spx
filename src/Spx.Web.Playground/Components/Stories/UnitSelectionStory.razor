@page "/stories/unit-selection"
@rendermode InteractiveServer

<h1 class="mb-1 text-xl font-semibold text-white">Unit Selection</h1>
<p class="mb-5 text-sm text-slate-400">
    <code class="text-sky-300">NexusUnitSelectionPanel</code> — pick units and quantity to move.
</p>

<div class="grid gap-6 lg:grid-cols-2">
    <section class="ui-surface-section p-4 lg:p-5">
        <p class="ui-panel-label mb-4">Fleet move from home (1 Carrier, 4 Infantry, 2 Fighter)</p>
        <NexusUnitSelectionPanel Source="@_homeSystem" AvailableUnits="@_homeUnits" OnConfirmed="OnConfirmed"
                                 OnCancelled="OnCancelled" />

        @if (_confirmedUnits is not null)
        {
            <div class="mt-4 rounded-xl border border-emerald-500/20 bg-emerald-900/10 p-3">
                <p class="text-xs font-semibold text-emerald-400">Confirmed move units</p>
                @foreach (var (unit, count) in _confirmedUnits)
                {
                    <p class="text-xs text-slate-300">@count× @unit</p>
                }
            </div>
        }
        @if (_cancelled)
        {
            <p class="mt-3 text-xs text-slate-500">Cancelled.</p>
        }
    </section>

    <section class="ui-surface-section p-4 lg:p-5">
        <p class="ui-panel-label mb-4">Ships only (2 Frigates, 1 Destroyer)</p>
        <NexusUnitSelectionPanel Source="@_shipsSystem" AvailableUnits="@_shipUnits" OnConfirmed="_ => { }"
                                 OnCancelled="() => { }" />
    </section>
</div>

@code {
    private static readonly Guid P1 = Guid.Parse("aaaaaaaa-0000-0000-0000-000000000001");

    private NexusSystemView _homeSystem = null!;
    private ImmutableDictionary<NexusUnitType, int> _homeUnits = null!;
    private NexusSystemView _shipsSystem = null!;
    private ImmutableDictionary<NexusUnitType, int> _shipUnits = null!;

    private ImmutableDictionary<NexusUnitType, int>? _confirmedUnits;
    private bool _cancelled;

    protected override void OnInitialized()
    {
        _homeSystem = new NexusSystemView(
            NexusMap.Player1HomeCoord,
            false, 3, P1, P1,
            ImmutableDictionary<Guid, ImmutableDictionary<NexusUnitType, int>>.Empty.Add(
                P1,
                ImmutableDictionary<NexusUnitType, int>.Empty
                    .Add(NexusUnitType.Carrier, 1)
                    .Add(NexusUnitType.Infantry, 4)
                    .Add(NexusUnitType.Fighter, 2)));

        _homeUnits = ImmutableDictionary<NexusUnitType, int>.Empty
            .Add(NexusUnitType.Carrier, 1)
            .Add(NexusUnitType.Infantry, 4)
            .Add(NexusUnitType.Fighter, 2);

        _shipsSystem = new NexusSystemView(
            new HexCoord(1, -2),
            false, 3, null, P1,
            ImmutableDictionary<Guid, ImmutableDictionary<NexusUnitType, int>>.Empty.Add(
                P1,
                ImmutableDictionary<NexusUnitType, int>.Empty
                    .Add(NexusUnitType.Frigate, 2)
                    .Add(NexusUnitType.Destroyer, 1)));

        _shipUnits = ImmutableDictionary<NexusUnitType, int>.Empty
            .Add(NexusUnitType.Frigate, 2)
            .Add(NexusUnitType.Destroyer, 1);
    }

    private void OnConfirmed(ImmutableDictionary<NexusUnitType, int> units)
    {
        _confirmedUnits = units;
        _cancelled = false;
    }

    private void OnCancelled()
    {
        _cancelled = true;
        _confirmedUnits = null;
    }
}
