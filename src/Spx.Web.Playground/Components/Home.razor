@page "/"

<div class="space-y-8">
    <PageHero Eyebrow="Playground" Title="Visual review surface"
              Description="Use the sidebar for the full story catalog. This home page highlights the fastest routes for UX review instead of duplicating every link.">
        <div class="ui-actions">
            <a class="ui-button-primary" href="/stories/nexus/pages/lobby">Review lobby page</a>
            <a class="ui-button-secondary" href="/stories/account/forms">Review auth forms</a>
            <a class="ui-button-secondary" href="/stories/nexus/components/gameplay-panel">Review gameplay panel</a>
        </div>
    </PageHero>

    <div class="grid gap-6 xl:grid-cols-[1.3fr_0.9fr]">
        <section class="ui-surface-form space-y-6">
            <SectionHeader Eyebrow="Coverage" Title="Story groups"
                           Description="The sidebar remains the source of truth for navigation. These cards just summarize what is available and where to start." />

            <div class="grid gap-4 md:grid-cols-3">
                @foreach (var section in Sections)
                {
                    <article class="ui-panel-card space-y-4">
                        <div class="space-y-2">
                            <p class="ui-section-eyebrow">@(section.Title)</p>
                            <h2 class="ui-section-title">@GetStoryCount(section) story views</h2>
                            <p class="text-sm leading-6 text-slate-300">@GetGroupSummary(section)</p>
                        </div>

                        <a class="ui-inline-link" href="@GetFirstHref(section)">Open first story</a>
                    </article>
                }
            </div>
        </section>

        <aside class="ui-surface-form space-y-6">
            <SectionHeader Eyebrow="Start Here" Title="Suggested review order"
                           Description="Walk the highest-value UX surfaces first, then drill into component stories when a page needs deeper inspection." />

            <ol class="space-y-3 pl-5 text-sm leading-6 text-slate-300 list-decimal">
                <li>Lobby page state coverage</li>
                <li>Account form and gated-access states</li>
                <li>Gameplay panel and selected-system panels</li>
                <li>Timeline rendering and messaging states</li>
            </ol>

            <div class="ui-inline-links">
                <a class="ui-inline-link" href="/stories/nexus/pages/lobby">Lobby story</a>
                <a class="ui-inline-link" href="/stories/account/access">Access story</a>
                <a class="ui-inline-link" href="/stories/shared/components/timeline">Timeline story</a>
            </div>
        </aside>
    </div>
</div>

@code {
    private static IReadOnlyList<PlaygroundNavigation.NavSection> Sections => PlaygroundNavigation.Sections;

    private static int GetStoryCount(PlaygroundNavigation.NavSection section) =>
        section.Groups.Sum(group => group.Items.Count);

    private static string GetGroupSummary(PlaygroundNavigation.NavSection section) =>
        string.Join(", ", section.Groups.Select(group => $"{group.Title}: {group.Items.Count}"));

    private static string GetFirstHref(PlaygroundNavigation.NavSection section) =>
        section.Groups.SelectMany(group => group.Items).First().Href;
}

