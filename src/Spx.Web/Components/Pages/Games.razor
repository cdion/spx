@page "/games"
@attribute [Authorize]
@using System.Security.Claims
@inject IGetUserGamesHandler GetUserGamesHandler

<PageTitle>My Games</PageTitle>

@if (isLoading)
{
    <section class="ui-surface-empty mx-auto max-w-5xl text-slate-300">
        Loading your games...
    </section>
}
else if (!string.IsNullOrWhiteSpace(loadError))
{
    <section class="mx-auto max-w-5xl">
        <AlertBanner>@loadError</AlertBanner>
    </section>
}
else if (games is not null)
{
    <section class="ui-page max-w-6xl">
        <header class="ui-surface-form flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div class="ui-section-header">
                <p class="ui-section-eyebrow">Lobby</p>
                <h1 class="ui-page-title">My games</h1>
                <p class="ui-page-copy">
                    Open games stay actionable, while ended games remain available as lightweight history.
                </p>
            </div>

            <div class="ui-actions">
                <a class="ui-button-primary" href="/games/create">
                    Create game
                </a>
                <a class="ui-button-secondary" href="/games/join">
                    Join with code
                </a>
            </div>
        </header>

        <div class="grid gap-6 xl:grid-cols-[1.4fr_1fr]">
            <div class="space-y-6">
                <section class="ui-surface-form">
                    <div class="flex items-start justify-between gap-4">
                        <div class="ui-section-header">
                            <p class="ui-section-eyebrow text-emerald-300">Open</p>
                            <h2 class="ui-section-title">Active seats</h2>
                        </div>
                        <StatusBadge Tone="StatusBadge.BadgeTone.Success">
                            @games.OpenGames.Count game(s)
                        </StatusBadge>
                    </div>

                    @if (games.OpenGames.Count == 0)
                    {
                        <p class="mt-6 ui-empty-state">You are not currently seated in any open games.</p>
                    }
                    else
                    {
                        <div class="mt-6 space-y-4">
                            @foreach (var game in games.OpenGames)
                            {
                                <article class="ui-panel-card">
                                    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                                        <div class="space-y-2">
                                            <h3 class="text-xl font-semibold text-white">@game.Name</h3>
                                            <p class="text-sm text-slate-300">Invite code: <span
                                                class="font-semibold tracking-[0.2em] text-sky-300">@game.InviteCode</span></p>
                                                <p class="text-sm text-slate-400">You are playing as @game.CurrentPlayerName.</p>
                                            </div>

                                            <div class="flex flex-wrap gap-3">
                                                <StatusBadge>
                                                    @game.ActivePlayerCount / @game.MaxPlayers players
                                                </StatusBadge>
                                                <a class="ui-button-primary px-4 py-2" href="/games/@game.GameId">
                                                    Open lobby
                                                </a>
                                            </div>
                                        </div>
                                    </article>
                                }
                            </div>
                        }
                    </section>

                    <section class="ui-surface-form">
                        <div class="flex items-start justify-between gap-4">
                            <div class="ui-section-header">
                                <p class="ui-section-eyebrow text-slate-400">Ended</p>
                                <h2 class="ui-section-title">History</h2>
                            </div>
                            <StatusBadge>
                                @games.EndedGames.Count game(s)
                            </StatusBadge>
                        </div>

                        @if (games.EndedGames.Count == 0)
                        {
                            <p class="mt-6 ui-empty-state">Ended games will appear here after their final player leaves.</p>
                        }
                        else
                        {
                            <div class="mt-6 space-y-4">
                                @foreach (var game in games.EndedGames)
                                {
                                    <article class="ui-panel-card">
                                        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                                            <div class="space-y-2">
                                                <h3 class="text-xl font-semibold text-white">@game.Name</h3>
                                                <p class="text-sm text-slate-300">Invite code: <span
                                                    class="font-semibold tracking-[0.2em] text-slate-100">@game.InviteCode</span>
                                                </p>
                                                <p class="text-sm text-slate-400">Your last player name was @game.CurrentPlayerName.</p>
                                            </div>

                                            <div class="space-y-2 text-sm text-slate-400 sm:text-right">
                                                <p>Ended @UiHelpers.FormatDateTime(game.EndedAtUtc ?? game.CreatedAtUtc)</p>
                                                <p>Created @UiHelpers.FormatDateTime(game.CreatedAtUtc)</p>
                                            </div>
                                        </div>
                                    </article>
                                }
                            </div>
                        }
                    </section>
                </div>

                <aside class="ui-surface-form space-y-6">
                    <SectionHeader Eyebrow="Notes" Title="Current rules" />

                    <ul class="space-y-3 text-sm leading-6 text-slate-300">
                        <li>Every game supports exactly two active player seats in this first slice.</li>
                        <li>Player names must be unique within a game and can be updated when you reattach.</li>
                        <li>Active and former players can open the lobby page for a game; only active players can take actions.</li>
                        <li>Ended games appear in history for anyone who played in them, whether or not they had left before the game ended.</li>
                    </ul>
                </aside>
            </div>
        </section>
    }

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    [Inject]
    private ILogger<Games> Logger { get; set; } = default!;

    private UserGamesView? games;
    private string? loadError;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = null;

        try
        {
            var userId = await UiHelpers.GetUserIdAsync(AuthenticationStateTask);
            games = await GetUserGamesHandler.HandleAsync(userId);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to load games for the current user.");
            loadError = "We couldn't load your games right now. Please refresh and try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

}