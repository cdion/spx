@page "/"
@attribute [Authorize]

<PageTitle>Game Lobby</PageTitle>


<section class="ui-page max-w-5xl">
	<PageHero Eyebrow="Lobby"
	          Title="Game lobby"
	          Description="Create a game, join with an invite code, and reopen any active seats from one place." />

	<div class="grid gap-6 lg:grid-cols-[1.3fr_0.9fr]">
		<section class="ui-surface-form">
			<div class="ui-flow">
				<SectionHeader Eyebrow="Quick Start" Title="Choose your next move" Tone="SectionHeader.EyebrowTone.Accent">
					<p class="max-w-xl text-sm leading-6 text-slate-300">
						Start a fresh lobby for a new match, or jump straight into an existing game with an invite code.
					</p>
				</SectionHeader>

				<div class="ui-actions">
					<a class="ui-button-primary" href="/games/create">
						Create game
					</a>
					<a class="ui-button-secondary" href="/games/join">
						Join with code
					</a>
					<a class="ui-button-secondary" href="/games">
						View my games
					</a>
				</div>
			</div>
		</section>

		<aside class="ui-surface-form">
			<SectionHeader Eyebrow="What Changed" Title="Lobby-first flow" />

			<ul class="mt-6 space-y-3 text-sm leading-6 text-slate-300">
				<li>The game lobby is now the default authenticated landing page.</li>
				<li>Invite codes get players into the right game without a separate demo path.</li>
				<li>Active and ended games stay grouped under your account.</li>
			</ul>
		</aside>
	</div>
</section>
