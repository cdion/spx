@using System.Collections.Immutable
@implements IDisposable

<section class="ui-surface-form-tight space-y-5">
    <SectionHeader Eyebrow="Gameplay" Title="@GetHeadline()">
        <p class="text-sm leading-6 text-slate-300">@GetDescription()</p>
    </SectionHeader>

    @if (!string.IsNullOrWhiteSpace(GameplayError))
    {
        <AlertBanner>@GameplayError</AlertBanner>
    }

    @if (Session is null)
    {
        <div class="ui-empty-state">
            @GetEmptyStateMessage()
        </div>
    }
    else
    {
        <div class="grid gap-3 lg:grid-cols-3">
            <article class="ui-panel-row items-start">
                <div>
                    <p class="ui-panel-label">Round</p>
                    <p class="mt-2 text-2xl font-semibold text-white">@Session.RoundNumber</p>
                </div>
                <StatusBadge>@Session.Phase</StatusBadge>
            </article>

            <article class="ui-panel-row items-start">
                <div class="space-y-1">
                    <p class="ui-panel-label">Your faction</p>
                    <p class="text-base font-semibold text-white">@CurrentPlayerName</p>
                    <p class="text-sm text-slate-400">vs @OpponentPlayerName</p>
                </div>
                <StatusBadge>@Session.CurrentPlayer.Faction</StatusBadge>
            </article>

            <article class="ui-panel-row items-start">
                <div>
                    <p class="ui-panel-label">Nexus gate</p>
                    <p class="mt-2 text-base font-semibold text-white">@Session.CurrentPlayer.GateProgress</p>
                </div>
                @if (Session.CurrentPlayer.HasSubmittedOrders)
                {
                    <StatusBadge Tone="StatusBadge.BadgeTone.Success">Orders in</StatusBadge>
                }
                else if (Session.OpponentPlayer.HasSubmittedOrders)
                {
                    <StatusBadge Tone="StatusBadge.BadgeTone.Warning">Waiting</StatusBadge>
                }
            </article>
        </div>

        @if (Session.Completion is not null)
        {
            <AlertBanner Tone="AlertBanner.AlertTone.Success" Role="status">
                @GetCompletionMessage()
            </AlertBanner>
        }

        <div class="grid gap-4 lg:grid-cols-[1fr_0.55fr]">
            <section class="ui-surface-section flex flex-col p-4 lg:p-5">
                <p class="ui-panel-label mb-4">Hex map</p>
                <p class="mb-3 text-xs text-sky-300 @(_selectionHex.HasValue ? "visible" : "invisible")">
                    @GetSelectionHint()
                </p>
                <div class="min-h-0 flex-1">
                    <NexusHexGridComponent Hexes="@Session.Hexes" TradeRoutes="@Session.ActiveTradeRoutes"
                                           CurrentPlayerId="@Session.CurrentPlayer.PlayerId" SelectedFleetHex="@GetSelectedFleetHex()"
                                           ValidMoveTargets="@GetValidMoveTargets()" PendingOrders="@_pendingOrders"
                                           PlayerHomeHex="@GetPlayerHomeHex()" PendingBuildFleet="@_pendingBuildFleet"
                                           PendingBeginNexusGate="@_pendingBeginNexusGate" SelectionCycleLabel="@GetCycleLabel()"
                                           IsEditable="@ShowOrdersForm" OnHexClicked="OnHexClicked" />
                </div>
            </section>

            <aside class="space-y-4">
                <section class="ui-surface-section p-4 lg:p-5">
                    <p class="ui-panel-label mb-3">Resources</p>
                    <div class="space-y-3">
                        <div class="ui-panel-card-inner space-y-2">
                            <div class="flex items-center justify-between gap-2">
                                <p class="text-sm font-semibold text-white">@CurrentPlayerName</p>
                                <StatusBadge>@Session.CurrentPlayer.Faction</StatusBadge>
                            </div>
                            <div class="flex flex-wrap gap-3 text-sm text-slate-300">
                                <span>
                                    <span class="font-semibold text-red-400">@Session.CurrentPlayer.RedCredits</span>
                                    red
                                </span>
                                <span>
                                    <span class="font-semibold text-sky-400">@Session.CurrentPlayer.BlueCredits</span>
                                    blue
                                </span>
                                <span>
                                    <span class="font-semibold text-yellow-400">@Session.CurrentPlayer.GoldCredits</span>
                                    gold
                                </span>
                            </div>
                            <p class="text-xs text-slate-400">
                                @GetPlayerFleetCount(Session.CurrentPlayer.PlayerId) fleet(s) deployed
                            </p>
                        </div>
                        <div class="ui-panel-card-inner space-y-2">
                            <div class="flex items-center justify-between gap-2">
                                <p class="text-sm font-semibold text-white">@OpponentPlayerName</p>
                                <StatusBadge>@Session.OpponentPlayer.Faction</StatusBadge>
                            </div>
                            <div class="flex flex-wrap gap-3 text-sm text-slate-300">
                                <span>
                                    <span class="font-semibold text-red-400">@Session.OpponentPlayer.RedCredits</span>
                                    red
                                </span>
                                <span>
                                    <span class="font-semibold text-sky-400">@Session.OpponentPlayer.BlueCredits</span>
                                    blue
                                </span>
                                <span>
                                    <span class="font-semibold text-yellow-400">@Session.OpponentPlayer.GoldCredits</span>
                                    gold
                                </span>
                            </div>
                            <p class="text-xs text-slate-400">
                                @GetPlayerFleetCount(Session.OpponentPlayer.PlayerId) fleet(s) deployed
                            </p>
                        </div>
                    </div>
                </section>

                @if (ShowOrdersForm)
                {
                    <section class="ui-surface-section p-4 space-y-4 lg:p-5">
                        <div class="flex items-center justify-between gap-2">
                            <p class="ui-panel-label">Your orders</p>
                            <StatusBadge Tone="StatusBadge.BadgeTone.Info">Your turn</StatusBadge>
                        </div>

                        <div class="flex gap-2">
                            <button class="ui-button-secondary flex-1 text-sm @(_pendingBuildFleet ? "" : "opacity-40")"
                                    @onclick="() => _pendingBuildFleet = !_pendingBuildFleet">
                                @(_pendingBuildFleet ? "✓ " : "")Build fleet
                            </button>
                            <button class="ui-button-secondary flex-1 text-sm @(_pendingBeginNexusGate ? "" : "opacity-40")"
                                    @onclick="() => _pendingBeginNexusGate = !_pendingBeginNexusGate">
                                @(_pendingBeginNexusGate ? "✓ " : "")Nexus gate
                            </button>
                        </div>

                        <NexusPendingOrdersListComponent Hexes="@Session.Hexes" Orders="@_pendingOrders" IsEditable
                                                         OnRemoveOrder="RemoveOrder" />

                        <div class="flex flex-wrap gap-3">
                            <button class="ui-button-primary" @onclick="SubmitOrdersAsync" disabled="@IsSubmittingAction">
                                @(IsSubmittingAction ? "Submitting..." : "Submit orders")
                            </button>
                        </div>
                    </section>
                }
            </aside>
        </div>

        @if (_resolveDisplayIndex > 0)
        {
            <section class="ui-surface-section p-4 space-y-3 lg:p-5">
                <p class="ui-panel-label">Last round events</p>
                @foreach (var evt in Session.ResolveEvents.Take(_resolveDisplayIndex))
                {
                    <p class="text-sm text-slate-300">
                        @NexusResolveEventMessageFormatter.Format(evt, RedPlayerName, BluePlayerName)
                    </p>
                }
                @if (_resolveDisplayIndex < Session.ResolveEvents.Length)
                {
                    <p class="animate-pulse text-xs text-slate-500">Resolving...</p>
                }
            </section>
        }
    }
</section>

@code {
    [Parameter, EditorRequired]
    public GameLobbyView Lobby { get; set; } = default!;

    [Parameter]
    public NexusGameView? Session { get; set; }

    [Parameter]
    public bool IsSubmittingAction { get; set; }

    [Parameter]
    public string? GameplayError { get; set; }

    [Parameter]
    public EventCallback<NexusTurnOrdersCommand> OnSubmitOrders { get; set; }

    private HexCoord? _selectionHex;
    private int _selectionCycleIndex = -1; // -1 = all my fleets on hex; ≥0 = specific fleet (stable sorted by FleetId)
    private bool _pendingBuildFleet;
    private bool _pendingBeginNexusGate;
    private readonly List<NexusFleetOrder> _pendingOrders = [];
    private int _resolveDisplayIndex;
    private int? _lastKnownRound;
    private CancellationTokenSource? _playbackCts;

    protected override void OnParametersSet()
    {
        if (Session?.RoundNumber == _lastKnownRound)
        {
            return;
        }

        _lastKnownRound = Session?.RoundNumber;
        _pendingOrders.Clear();
        _selectionHex = null;
        _selectionCycleIndex = -1;
        _pendingBuildFleet = false;
        _pendingBeginNexusGate = false;

        if (Session?.ResolveEvents.Length > 0)
        {
            StartResolvePlayback(Session.ResolveEvents.Length);
        }
        else
        {
            _resolveDisplayIndex = 0;
        }
    }

    private void StartResolvePlayback(int count)
    {
        _playbackCts?.Cancel();
        _playbackCts?.Dispose();
        _playbackCts = new CancellationTokenSource();
        var token = _playbackCts.Token;
        _resolveDisplayIndex = 0;
        _ = InvokeAsync(async () =>
        {
            for (var i = 1; i <= count; i++)
            {
                try
                {
                    await Task.Delay(400, token);
                }
                catch (OperationCanceledException)
                {
                    break;
                }

                if (token.IsCancellationRequested)
                {
                    break;
                }

                _resolveDisplayIndex = i;
                StateHasChanged();
            }
        });
    }

    public void Dispose()
    {
        _playbackCts?.Cancel();
        _playbackCts?.Dispose();
    }

    private int GetPlayerFleetCount(Guid playerId) =>
        Session?.Hexes.Sum(h => h.Fleets.Count(f => f.OwnerId == playerId)) ?? 0;

    private bool ShowOrdersForm =>
        Lobby.IsCurrentUserActive
        && Session is not null
        && Session.Phase == NexusGamePhase.Planning
        && !Session.CurrentPlayer.HasSubmittedOrders
        && Session.Completion is null;

    private string CurrentPlayerName => Lobby.CurrentPlayerName;

    private string OpponentPlayerName =>
        Lobby.Players.FirstOrDefault(p => p.PlayerId != Lobby.CurrentPlayerId)?.Name
        ?? "your opponent";

    private string RedPlayerName =>
        Session?.CurrentPlayer.Faction == NexusFactionColor.Red
            ? CurrentPlayerName
            : OpponentPlayerName;

    private string BluePlayerName =>
        Session?.CurrentPlayer.Faction == NexusFactionColor.Blue
            ? CurrentPlayerName
            : OpponentPlayerName;

    private HexCoord? GetSelectedFleetHex() => _selectionHex;

    private IReadOnlyList<Guid> GetSelectedFleetIds()
    {
        if (_selectionHex is null || Session is null) return [];
        var hex = Session.Hexes.FirstOrDefault(h => h.Coord == _selectionHex);
        if (hex is null) return [];
        var myFleets = hex.Fleets
            .Where(f => f.OwnerId == Session.CurrentPlayer.PlayerId)
            .OrderBy(f => f.FleetId)
            .ToList();
        if (_selectionCycleIndex < 0) return myFleets.Select(f => f.FleetId).ToList();
        if (_selectionCycleIndex < myFleets.Count) return [myFleets[_selectionCycleIndex].FleetId];
        return [];
    }

    private IReadOnlyList<HexCoord> GetValidMoveTargets()
    {
        if (_selectionHex is null || Session is null) return [];
        return GetSelectedFleetIds()
            .SelectMany(id => NexusGameViewQueries.GetValidMoveDestinations(Session, id))
            .Distinct()
            .ToList();
    }

    private HexCoord? GetPlayerHomeHex() =>
        Session is null ? null : NexusMap.GetHomeCoord(Session.CurrentPlayer.Faction);

    private string? GetCycleLabel()
    {
        if (_selectionHex is null || Session is null) return null;
        var hex = Session.Hexes.FirstOrDefault(h => h.Coord == _selectionHex);
        if (hex is null) return null;
        var count = hex.Fleets.Count(f => f.OwnerId == Session.CurrentPlayer.PlayerId);
        if (count <= 1) return null;
        return _selectionCycleIndex < 0 ? $"×{count}" : $"{_selectionCycleIndex + 1}/{count}";
    }

    private string GetSelectionHint()
    {
        if (_selectionHex is null) return string.Empty;
        var ids = GetSelectedFleetIds();
        if (ids.Count == 0) return string.Empty;
        if (ids.Count > 1)
            return $"×{ids.Count} fleets — click destination to move all, click hex again to cycle individually.";
        return Session is not null && NexusGameViewQueries.CanColonize(Session, ids[0])
            ? "Fleet selected — click to move, or click hex again to colonize."
            : "Fleet selected — click to move, or click hex again to deselect.";
    }

    private void OnHexClicked(HexCoord coord)
    {
        if (!ShowOrdersForm || Session is null) return;

        var hex = Session.Hexes.FirstOrDefault(h => h.Coord == coord);
        if (hex is null) return;

        var myFleetsOnHex = hex.Fleets
            .Where(f => f.OwnerId == Session.CurrentPlayer.PlayerId)
            .OrderBy(f => f.FleetId)
            .ToList();

        // ── Clicking the currently selected hex: cycle or colonize ─────────────────
        if (_selectionHex == coord)
        {
            if (_selectionCycleIndex < 0) // “all” selected
            {
                if (myFleetsOnHex.Count > 0 &&
                    NexusGameViewQueries.CanColonize(Session, myFleetsOnHex[0].FleetId))
                {
                    foreach (var fleet in myFleetsOnHex)
                    {
                        _pendingOrders.RemoveAll(o => o.FleetId == fleet.FleetId);
                        _pendingOrders.Add(new NexusColonizeOrder(fleet.FleetId));
                    }
                    _selectionHex = null;
                    return;
                }

                if (myFleetsOnHex.Count > 1)
                {
                    _selectionCycleIndex = 0;
                    return;
                }

                _selectionHex = null;
                TryToggleFlag(coord);
                return;
            }
            else
            {
                if (_selectionCycleIndex < myFleetsOnHex.Count - 1)
                {
                    _selectionCycleIndex++;
                    return;
                }

                _selectionHex = null;
                TryToggleFlag(coord);
                return;
            }
        }

        // ── Different hex: fleet selection takes priority over move target ─────
        if (myFleetsOnHex.Count > 0)
        {
            _selectionHex = coord;
            _selectionCycleIndex = -1;
            return;
        }

        // Issue move if valid target and something is selected
        if (_selectionHex.HasValue)
        {
            var validTargets = GetValidMoveTargets();
            if (validTargets.Contains(coord))
            {
                foreach (var fleetId in GetSelectedFleetIds())
                {
                    _pendingOrders.RemoveAll(o => o.FleetId == fleetId);
                    _pendingOrders.Add(new NexusMoveOrder(fleetId, coord));
                }
            }
            _selectionHex = null;
            return;
        }

        // No active selection → flag toggle
        TryToggleFlag(coord);
    }

    private void TryToggleFlag(HexCoord coord)
    {
        if (Session is null) return;
        var homeCoord = NexusMap.GetHomeCoord(Session.CurrentPlayer.Faction);
        if (coord == homeCoord)
            _pendingBuildFleet = !_pendingBuildFleet;
        else if (coord == NexusMap.NexusCoord)
            _pendingBeginNexusGate = !_pendingBeginNexusGate;
    }

    private void RemoveOrder(Guid fleetId) => _pendingOrders.RemoveAll(o => o.FleetId == fleetId);

    private string GetHeadline() =>
        Session switch
        {
            null when !Lobby.IsCurrentUserActive => "Archived seat",
            null when Lobby.Players.Count < Lobby.MaxPlayers => "Waiting for an opponent",
            null => "Session syncing",
            { Completion: not null } => "Match complete",
            { Phase: NexusGamePhase.Planning, CurrentPlayer.HasSubmittedOrders: false } =>
                "Submit your orders",
            { Phase: NexusGamePhase.Planning } => "Waiting for opponent",
            _ => "Gameplay",
        };

    private string GetDescription() =>
        Session switch
        {
            null when !Lobby.IsCurrentUserActive =>
                "Gameplay is only available while you still occupy an active seat in the match.",
            null when Lobby.Players.Count < Lobby.MaxPlayers =>
                "The match begins automatically after another player joins this lobby.",
            null => "The match is active, but your session view is still catching up.",
            { Completion: not null } => GetCompletionMessage(),
            { Phase: NexusGamePhase.Planning, CurrentPlayer.HasSubmittedOrders: false } =>
                "Choose your orders and submit. Both players resolve simultaneously once both have submitted.",
            { Phase: NexusGamePhase.Planning } =>
                $"Waiting for {OpponentPlayerName} to submit their orders.",
            _ => "Game state is resolving.",
        };

    private string GetEmptyStateMessage() =>
        !Lobby.IsCurrentUserActive
            ? "You can still read the lobby timeline, but gameplay controls are disabled because you already left this game."
            : Lobby.Players.Count < Lobby.MaxPlayers
                ? "Share the invite code and wait for the second player to join. Gameplay will appear here as soon as the match initializes."
                : "The match state is still loading. This panel updates automatically.";

    private string GetCompletionMessage()
    {
        if (Session?.Completion is null)
        {
            return string.Empty;
        }

        return Session.Completion.Outcome switch
        {
            NexusGameOutcome.Victory
                when Session.Completion.WinnerId == Session.CurrentPlayer.PlayerId =>
                "You activated the Nexus gate. Victory!",
            NexusGameOutcome.Victory => $"{OpponentPlayerName} activated the Nexus gate.",
            NexusGameOutcome.Draw => "The match ended in a draw.",
            _ => "The match has ended.",
        };
    }

    private Task SubmitOrdersAsync()
    {
        if (Session is null)
        {
            return Task.CompletedTask;
        }

        var command = new NexusTurnOrdersCommand(
            Session.CurrentPlayer.PlayerId,
            Session.RoundNumber,
            _pendingOrders.ToImmutableArray(),
            _pendingBuildFleet,
            _pendingBeginNexusGate
        );

        _pendingOrders.Clear();
        _selectionHex = null;
        _selectionCycleIndex = -1;
        _pendingBuildFleet = false;
        _pendingBeginNexusGate = false;

        return OnSubmitOrders.InvokeAsync(command);
    }
}
