@* Routes between the pre-game waiting state and the active gameplay panel. *@
<section class="ui-surface-form-tight space-y-5">
    @if (Session is null)
    {
        <SectionHeader Eyebrow="Gameplay" Title="@GetHeadline()">
            <p class="text-sm leading-6 text-slate-300">@GetDescription()</p>
        </SectionHeader>

        @if (!string.IsNullOrWhiteSpace(GameplayError))
        {
            <AlertBanner>@GameplayError</AlertBanner>
        }

        <div class="ui-empty-state">
            @GetEmptyStateMessage()
        </div>
    }
    else
    {
        <NexusGameplayPanel Session="Session" Lobby="Lobby" IsSubmittingAction="IsSubmittingAction"
                            GameplayError="GameplayError" OnSubmitOrders="OnSubmitOrders" />
    }
</section>

@code {
    [Parameter, EditorRequired]
    public GameLobbyView Lobby { get; set; } = default!;

    [Parameter]
    public NexusGameView? Session { get; set; }

    [Parameter]
    public bool IsSubmittingAction { get; set; }

    [Parameter]
    public string? GameplayError { get; set; }

    [Parameter]
    public EventCallback<NexusTurnOrdersCommand> OnSubmitOrders { get; set; }

    private string GetHeadline() =>
        !Lobby.IsCurrentUserActive ? "Archived seat" :
        Lobby.Players.Count < Lobby.MaxPlayers ? "Waiting for an opponent" :
        "Session syncing";

    private string GetDescription() =>
        !Lobby.IsCurrentUserActive
            ? "Gameplay is only available while you still occupy an active seat in the match."
            : Lobby.Players.Count < Lobby.MaxPlayers
                ? "The match begins automatically after another player joins this lobby."
                : "The match is active, but your session view is still catching up.";

    private string GetEmptyStateMessage() =>
        !Lobby.IsCurrentUserActive
            ? "You can still read the lobby timeline, but gameplay controls are disabled because you already left this game."
            : Lobby.Players.Count < Lobby.MaxPlayers
                ? "Share the invite code and wait for the second player to join. Gameplay will appear here as soon as the match initializes."
                : "The match state is still loading. This panel updates automatically.";
}

