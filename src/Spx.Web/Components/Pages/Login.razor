@page "/login"
@attribute [AllowAnonymous]

<PageTitle>Sign in</PageTitle>

<section class="mx-auto flex max-w-2xl flex-col gap-8">
    <header class="space-y-4">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-sky-300">Identity</p>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">Sign in</h1>
        <p class="max-w-2xl text-base leading-7 text-slate-300 sm:text-lg">
            Use your email and password to open an authenticated session for the Orleans demo.
        </p>
    </header>

    <div class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-2xl shadow-slate-950/40 backdrop-blur sm:p-8">
        <div class="space-y-6">
            @if (!string.IsNullOrWhiteSpace(Status))
            {
                <div class="rounded-2xl border border-emerald-400/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-100" role="status">@Status</div>
            }

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <div class="rounded-2xl border border-red-400/30 bg-red-500/10 px-4 py-3 text-sm text-red-100" role="alert">@Error</div>
            }

            <form method="post" action="/account/login" class="space-y-6">
                <AntiforgeryToken />
                <input type="hidden" name="returnUrl" value="@ResolvedReturnUrl" />

                <div class="space-y-2">
                    <label class="block text-sm font-medium text-slate-200" for="email">Email</label>
                    <input id="email" name="email" type="email" value="@Email" autocomplete="email" required
                           class="w-full rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-base text-white outline-none transition placeholder:text-slate-500 focus:border-sky-300/60 focus:ring-2 focus:ring-sky-400/30" />
                </div>

                <div class="space-y-2">
                    <label class="block text-sm font-medium text-slate-200" for="password">Password</label>
                    <input id="password" name="password" type="password" autocomplete="current-password" required
                           class="w-full rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-base text-white outline-none transition placeholder:text-slate-500 focus:border-sky-300/60 focus:ring-2 focus:ring-sky-400/30" />
                </div>

                <button class="inline-flex items-center justify-center rounded-full bg-sky-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-sky-300" type="submit">
                    Sign in
                </button>
            </form>

            <div class="flex flex-wrap gap-4 text-sm text-slate-300">
                <a class="font-medium text-sky-300 hover:text-sky-200" href="/register">Create an account</a>
                <a class="font-medium text-sky-300 hover:text-sky-200" href="/forgot-password">Forgot your password?</a>
                <a class="font-medium text-sky-300 hover:text-sky-200" href="/resend-confirmation?email=@Uri.EscapeDataString(Email ?? string.Empty)">Resend confirmation email</a>
            </div>
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "status")]
    public string? Status { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    private string ResolvedReturnUrl => string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl!;
}