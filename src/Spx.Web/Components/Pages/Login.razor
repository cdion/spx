@page "/login"
@attribute [AllowAnonymous]

<PageTitle>Sign in</PageTitle>

<FormPage Eyebrow="Identity" Title="Sign in"
          Description="Use your email and password to open an authenticated session for the Orleans demo.">
    @if (!string.IsNullOrWhiteSpace(Status))
    {
        <AlertBanner Tone="AlertBanner.AlertTone.Success" Role="status">@Status</AlertBanner>
    }

    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <AlertBanner>@Error</AlertBanner>
    }

    <form method="post" action="/account/login" class="ui-flow">
        <AntiforgeryToken />
        <input type="hidden" name="returnUrl" value="@ResolvedReturnUrl" />

        <div class="ui-field">
            <label class="ui-label" for="email">Email</label>
            <input id="email" name="email" type="email" value="@Email" autocomplete="email" required class="ui-input" />
        </div>

        <div class="ui-field">
            <label class="ui-label" for="password">Password</label>
            <input id="password" name="password" type="password" autocomplete="current-password" required
                   class="ui-input" />
        </div>

        <button class="ui-button-primary" type="submit">
            Sign in
        </button>
    </form>

    <div class="ui-inline-links">
        <a class="ui-inline-link" href="/register">Create an account</a>
        <a class="ui-inline-link" href="/forgot-password">Forgot your password?</a>
        <a class="ui-inline-link" href="/resend-confirmation?email=@Uri.EscapeDataString(Email ?? string.Empty)">Resend
            confirmation email</a>
        </div>
    </FormPage>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "status")]
    public string? Status { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    private string ResolvedReturnUrl => string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl!;
}