@page "/games/create"
@attribute [Authorize]

<PageTitle>Create Game</PageTitle>

<FormPage Eyebrow="Lobby" Title="Create a game"
          Description="Creating a game reserves an invite code and seats you immediately as player one.">
    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <AlertBanner>@Error</AlertBanner>
    }

    <form method="post" action="/games/create/submit" class="ui-flow">
        <AntiforgeryToken />

        <FormField For="game-name" Label="Game name">
            <input id="game-name" name="gameName" class="ui-input" maxlength="100" placeholder="Weekend match"
                   value="@GameName" required />
        </FormField>

        <FormField For="player-name" Label="Player name">
            <input id="player-name" name="playerName" class="ui-input" maxlength="40" placeholder="Captain Red"
                   value="@PlayerName" required />
        </FormField>

        <div class="ui-actions">
            <button class="ui-button-primary" type="submit">
                Create and join
            </button>
            <a class="ui-button-secondary" href="/games">
                Cancel
            </a>
        </div>
    </form>
</FormPage>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "gameName")]
    public string? GameName { get; set; }

    [SupplyParameterFromQuery(Name = "playerName")]
    public string? PlayerName { get; set; }

}