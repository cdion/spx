@page "/games/join"
@attribute [Authorize]
@using System.Security.Claims
@inject IJoinGameHandler JoinGameHandler
@inject ILogger<GameJoin> Logger
@inject NavigationManager Navigation

<PageTitle>Join Game</PageTitle>

<FormPage Eyebrow="Lobby"
          Title="Join a game"
          Description="Enter the invite code and the player name you want to use for this game.">
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <AlertBanner>@errorMessage</AlertBanner>
    }

    <FormField For="invite-code" Label="Invite code">
        <input id="invite-code" class="ui-input ui-input-code" maxlength="6" placeholder="ABC123" @bind="inviteCode" />
    </FormField>

    <FormField For="join-player-name" Label="Player name">
        <input id="join-player-name" class="ui-input" maxlength="40" placeholder="Captain Blue" @bind="playerName" />
    </FormField>

    <div class="ui-actions">
        <button class="ui-button-primary" @onclick="JoinGameAsync" disabled="@isSubmitting">
            @(isSubmitting ? "Joining game..." : "Join game")
        </button>
        <a class="ui-button-secondary" href="/games">
            Cancel
        </a>
    </div>
</FormPage>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private string inviteCode = string.Empty;
    private string playerName = string.Empty;
    private string? errorMessage;
    private bool isSubmitting;

    private async Task JoinGameAsync()
    {
        if (isSubmitting)
        {
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            var userId = await UiHelpers.GetUserIdAsync(AuthenticationStateTask);
            var result = await JoinGameHandler.HandleAsync(userId, new JoinGameRequest(inviteCode, playerName));

            if (result is not GameCommandSucceeded succeeded)
            {
                errorMessage = ((GameCommandFailed)result).ErrorMessage;
                return;
            }

            Navigation.NavigateTo($"/games/{succeeded.GameId}");
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to join a game for the current user.");
            errorMessage = "We couldn't join that game right now. Please try again.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

}