@page "/games/join"
@attribute [Authorize]

<PageTitle>Join Game</PageTitle>

<FormPage Eyebrow="Lobby" Title="Join a game"
          Description="Enter the invite code and the player name you want to use for this game.">
    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <AlertBanner>@Error</AlertBanner>
    }

    <form method="post" action="/games/join/submit" class="ui-flow">
        <AntiforgeryToken />

        <FormField For="invite-code" Label="Invite code">
            <input id="invite-code" name="inviteCode" class="ui-input ui-input-code" maxlength="6" placeholder="ABC123"
                   value="@InviteCode" required />
        </FormField>

        <FormField For="join-player-name" Label="Player name">
            <input id="join-player-name" name="playerName" class="ui-input" maxlength="40" placeholder="Captain Blue"
                   value="@PlayerName" required />
        </FormField>

        <div class="ui-actions">
            <button class="ui-button-primary" type="submit">
                Join game
            </button>
            <a class="ui-button-secondary" href="/games">
                Cancel
            </a>
        </div>
    </form>
</FormPage>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "inviteCode")]
    public string? InviteCode { get; set; }

    [SupplyParameterFromQuery(Name = "playerName")]
    public string? PlayerName { get; set; }

}