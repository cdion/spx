@page "/"
@attribute [Authorize]

<PageTitle>Game Lobby</PageTitle>


<section class="ui-page max-w-5xl">
	<PageHero Eyebrow="Lobby" Title="Game lobby"
			  Description="Create a game, join with an invite code, and reopen any active seats from one place." />

	<div class="grid gap-6 lg:grid-cols-[1.3fr_0.9fr]">
		<section class="ui-surface-form">
			<div class="ui-flow">
				<SectionHeader Eyebrow="Quick Start" Title="Choose your next move"
							   Tone="@SectionHeader.EyebrowTone.Accent"
							   Description="Create a new game or join an existing game with an invite code." />

				<div class="ui-actions">
					<a class="ui-button-primary" href="/games/create">
						Create game
					</a>
					<a class="ui-button-secondary" href="/games/join">
						Join with code
					</a>
					<a class="ui-button-secondary" href="/games">
						View my games
					</a>
				</div>
			</div>
		</section>

		<aside class="ui-surface-form">
			<SectionHeader Eyebrow="What's Changed" Title="First release" />

			<ul class="mt-6 space-y-3 ui-type-body">
				<li>First 'playable' release of the Nexus Protocol</li>
			</ul>
		</aside>
	</div>
</section>
