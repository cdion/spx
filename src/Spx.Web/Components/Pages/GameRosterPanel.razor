<section class="ui-surface-form">
    <SectionHeader Eyebrow="Roster" Title="Active players" />

    <div class="mt-6 space-y-4">
        @foreach (var player in Lobby.Players)
        {
            var isOnline = Presence.OnlinePlayerIds.Contains(player.PlayerId);

            <article class="ui-panel-row">
                <div>
                    <p class="text-base font-semibold text-white">@player.Name</p>
                    <p class="text-sm text-slate-400">Joined @UiHelpers.FormatDateTime(player.JoinedAtUtc)</p>
                </div>

                <div class="flex flex-wrap items-center gap-2">
                    @if (isOnline)
                    {
                        <StatusBadge Tone="StatusBadge.BadgeTone.Success">Online</StatusBadge>
                    }
                    else
                    {
                        <StatusBadge Tone="StatusBadge.BadgeTone.Offline">Offline</StatusBadge>
                    }

                    @if (player.PlayerId == Lobby.CurrentPlayerId)
                    {
                        <StatusBadge Tone="StatusBadge.BadgeTone.Info">You</StatusBadge>
                    }
                </div>
            </article>
        }

        @if (Lobby.Players.Count < Lobby.MaxPlayers)
        {
            <article class="ui-empty-state">
                Waiting for another player to join with the invite code.
            </article>
        }
    </div>
</section>

@code {
    [Parameter, EditorRequired]
    public GameLobbyView Lobby { get; set; } = default!;

    [Parameter, EditorRequired]
    public GamePresenceView Presence { get; set; } = default!;

}