@page "/register"
@attribute [AllowAnonymous]

<PageTitle>Create account</PageTitle>

<FormPage Eyebrow="Identity" Title="Create account"
          Description="Register with your email address. You will confirm the account before the first sign-in.">
    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <AlertBanner>@Error</AlertBanner>
    }

    <form method="post" action="/account/register" class="ui-flow">
        <AntiforgeryToken />

        <div class="ui-field">
            <label class="ui-label" for="email">Email</label>
            <input id="email" name="email" type="email" value="@Email" autocomplete="email" required class="ui-input" />
        </div>

        <div class="ui-field">
            <label class="ui-label" for="password">Password</label>
            <input id="password" name="password" type="password" autocomplete="new-password" required
                   class="ui-input" />
        </div>

        <div class="ui-field">
            <label class="ui-label" for="confirmPassword">Confirm password</label>
            <input id="confirmPassword" name="confirmPassword" type="password" autocomplete="new-password" required
                   class="ui-input" />
        </div>

        <p class="text-sm text-slate-400">
            Passwords must be at least 12 characters and include uppercase, lowercase, and a digit.
        </p>

        <button class="ui-button-primary" type="submit">
            Create account
        </button>
    </form>

    <p class="text-sm text-slate-300">
        Already registered?
        <a class="ui-inline-link" href="/login">Sign in</a>
    </p>
</FormPage>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }
}