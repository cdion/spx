@page "/games/{GameId:guid}"
@attribute [Authorize]
@implements IAsyncDisposable
@using Orleans
@using Spx.Data
@using System.Security.Claims
@inject IClusterClient ClusterClient
@inject IGetGamePageHandler GetGamePageHandler
@inject IGetGamePresenceHandler GetGamePresenceHandler
@inject IGetGameSessionHandler GetGameSessionHandler
@inject IGamePresenceService GamePresenceService
@inject Spx.Web.Circuits.CircuitConnectionEvents CircuitConnectionEvents
@inject ILeaveGameHandler LeaveGameHandler
@inject IGetMessagesHandler GetMessagesHandler
@inject IGetMessageUpdatesHandler GetMessageUpdatesHandler
@inject ISendPublicMessageHandler SendPublicMessageHandler
@inject ISendPrivateMessageHandler SendPrivateMessageHandler
@inject IEditMessageHandler EditMessageHandler
@inject IDeleteMessageHandler DeleteMessageHandler
@inject ISubmitAcquireCardHandler SubmitAcquireCardHandler
@inject ISubmitPlayBatchHandler SubmitPlayBatchHandler
@inject IGameplayEventMessageFormatter GameplayEventMessageFormatter
@inject ILogger<GamePage> Logger
@inject ILogger<GamePageActionCoordinator> ActionCoordinatorLogger
@inject ILogger<GamePageDataCoordinator> DataCoordinatorLogger
@inject ILogger<GamePageLiveCoordinator> LiveCoordinatorLogger
@inject ILogger<GamePageSubscription> SubscriptionLogger
@inject NavigationManager Navigation

<PageTitle>Game</PageTitle>

@if (isLoading)
{
    <section class="ui-surface-empty mx-auto max-w-4xl text-slate-300">
        Loading lobby...
    </section>
}
else if (lobby is null)
{
    <section class="ui-surface-empty mx-auto flex max-w-3xl flex-col gap-6">
        <PageHero Eyebrow="Lobby"
                  Title="Game unavailable"
                  Description="You can only open lobby pages for games where you are an active player or where you previously played."
                  Compact />
        <div class="ui-actions">
            <a class="ui-button-primary" href="/games">
                Back to my games
            </a>
            <a class="ui-button-secondary" href="/games/join">
                Join another game
            </a>
        </div>
    </section>
}
else
{
    <section class="ui-page max-w-6xl gap-6 lg:gap-7">
        <header class="ui-surface-form-tight">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
                <div class="ui-section-header">
                    <p class="ui-section-eyebrow">Lobby</p>
                    <h1 class="ui-page-title">@lobby.Name</h1>
                    <p class="ui-page-copy">
                        Invite code <span class="font-semibold tracking-[0.25em] text-sky-300">@lobby.InviteCode</span>
                    </p>
                </div>

                <div class="flex flex-wrap items-center gap-2">
                    <StatusBadge>
                        @lobby.Status
                    </StatusBadge>
                    <StatusBadge Tone="StatusBadge.BadgeTone.Success">
                        @lobby.Players.Count / @lobby.MaxPlayers players
                    </StatusBadge>
                </div>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <AlertBanner>@errorMessage</AlertBanner>
        }

        @if (!lobby.IsCurrentUserActive)
        {
            <AlertBanner Tone="AlertBanner.AlertTone.Warning" Role="status">
                You are viewing this game as a former player. Timeline history is limited to the point when you left.
            </AlertBanner>
        }

        <GameSessionPanel Lobby="@lobby"
                  Session="@session"
                  IsSubmittingAction="@isSubmittingGameplayAction"
                  GameplayError="@gameplayError"
                  OnAcquireCard="AcquireCardAsync"
                  OnLockBatch="LockBatchAsync" />

        <section class="ui-surface-form-tight">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
                <SectionHeader Eyebrow="Timeline" Title="Messages and game events" />
            </div>

            @if (!string.IsNullOrWhiteSpace(timeline.MessageError))
            {
                <div class="mt-4">
                    <AlertBanner>@timeline.MessageError</AlertBanner>
                </div>
            }

            <div class="mt-4 grid gap-4 lg:grid-cols-[1.35fr_0.85fr] lg:gap-5">
                <GameTimelinePanel @key="GetTimelinePanelKey()"
                                   @ref="timelineComponent"
                                   CurrentUserName="@lobby.CurrentPlayerName"
                                   TimelineItems="timeline.Items"
                                   MessageError="@timeline.MessageError"
                                   IsTimelineLoading="@timeline.IsTimelineLoading"
                                   IsLoadingOlderMessages="@timeline.IsLoadingOlderMessages"
                                   HasOlderMessages="@timeline.HasOlderMessages"
                                   EditingMessageId="@timeline.EditingMessageId"
                                   @bind-EditMessageText="timeline.EditMessageText"
                                   IsSavingEdit="@timeline.IsSavingEdit"
                                   OnLoadOlderMessages="LoadOlderMessagesAsync"
                                   OnBeginEdit="BeginEdit"
                                   OnCancelEdit="CancelEdit"
                                   OnSaveEdit="SaveEditAsync"
                                   OnDeleteMessage="DeleteMessageAsync"
                                   OnRetryPendingMessage="RetryPendingMessageAsync"
                                   OnDismissPendingMessage="DismissPendingMessage" />

                <GameMessageComposer @key="GetMessageComposerKey()"
                                     IsCurrentUserActive="@lobby.IsCurrentUserActive"
                                     CurrentPlayerId="@lobby.CurrentPlayerId"
                                     Players="@lobby.Players"
                                     @bind-Text="timeline.ComposerText"
                                     @bind-SelectedRecipientPlayerIdString="timeline.SelectedRecipientPlayerIdString"
                                     IsSendingMessage="@timeline.IsSendingMessage"
                                     OnSend="SendMessageAsync" />
            </div>
        </section>

        <div class="grid gap-4 xl:grid-cols-[1.4fr_1fr] xl:gap-5">
            <GameRosterPanel Lobby="@lobby" Presence="@presence" />

            <GameCurrentUserPanel Lobby="@lobby"
                                  IsLeaving="@isLeaving"
                                  OnLeave="LeaveGameAsync" />
        </div>
    </section>
}

@code {
    [Parameter]
    public Guid GameId { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private readonly GamePageDataState data = new();
    private readonly GamePageActionState actions = new();
    private readonly GameTimelineState timeline = new();

    private string currentUserId = string.Empty;
    private Guid currentPlayerId;
    private GamePageActionCoordinator? actionCoordinator;
    private GamePageDataCoordinator? dataCoordinator;
    private GamePageLiveCoordinator? liveCoordinator;
    private GameTimelinePanel? timelineComponent;

    private GameLobbyView? lobby => data.Lobby;

    private GameSessionView? session => data.Session;

    private GamePresenceView presence => data.Presence;

    private string? errorMessage => data.ErrorMessage;

    private string? gameplayError => data.GameplayError;

    private bool isLoading => data.IsLoading;

    private bool isLeaving => actions.IsLeaving;

    private bool isSubmittingGameplayAction => actions.IsSubmittingGameplayAction;

    protected override void OnInitialized()
    {
        actionCoordinator = new GamePageActionCoordinator(
            LeaveGameHandler,
            SubmitAcquireCardHandler,
            SubmitPlayBatchHandler,
            GameplayEventMessageFormatter,
            ActionCoordinatorLogger,
            data,
            actions,
            timeline);
        dataCoordinator = new GamePageDataCoordinator(
            GetGamePageHandler,
            GetGameSessionHandler,
            GetGamePresenceHandler,
            DataCoordinatorLogger,
            data);
        liveCoordinator = new GamePageLiveCoordinator(
            ClusterClient,
            GamePresenceService,
            CircuitConnectionEvents,
            LiveCoordinatorLogger,
            SubscriptionLogger,
            HandleLobbyInvalidatedAsync,
            HandleSessionInvalidatedAsync,
            HandleMessagesInvalidatedAsync,
            HandlePresenceInvalidatedAsync);
        liveCoordinator.Initialize();
    }

    protected override async Task OnParametersSetAsync()
    {
        currentUserId = await UiHelpers.GetUserIdAsync(AuthenticationStateTask);
        await LoadPageAsync();
        if (lobby is not null)
        {
            currentPlayerId = lobby.CurrentPlayerId;
        }

        if (lobby is null)
        {
            await liveCoordinator!.StopAsync();
            ResetTimelineState();
            return;
        }

        var isNewGame = liveCoordinator!.GameId != lobby.GameId;
        if (isNewGame)
        {
            ResetTimelineState();
            await LoadInitialMessagesAsync();
            await liveCoordinator.StartAsync(lobby);
            timeline.RequestScrollToBottom();
            return;
        }

        await liveCoordinator.StartAsync(lobby);

        if (timeline.Items.Count == 0)
        {
            await LoadInitialMessagesAsync();
            timeline.RequestScrollToBottom();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (timeline.ShouldRestoreScrollAfterOlderLoad && timelineComponent is not null)
        {
            timeline.MarkRestoreScrollHandled();
            await timelineComponent.RestoreScrollAfterPrependAsync(timeline.RestoreScrollHeight, timeline.RestoreScrollTop);
        }
        else if (timeline.ShouldScrollTimelineToBottom && timelineComponent is not null)
        {
            timeline.MarkScrollToBottomHandled();
            await timelineComponent.ScrollToBottomAsync();
        }
    }

    private Task LoadPageAsync()
        => dataCoordinator!.LoadPageAsync(GameId, currentUserId);

    private async Task LoadPresenceAsync()
    {
        if (lobby is null)
        {
            data.ClearPresence();
            return;
        }

        await dataCoordinator!.ReloadPresenceAsync(lobby.GameId);
    }

    private async Task LoadSessionAsync()
    {
        if (lobby is null)
        {
            data.ApplySession(null);
            return;
        }

        await dataCoordinator!.ReloadSessionAsync(lobby.GameId, currentPlayerId);
    }

    private Task HandleLobbyInvalidatedAsync()
        => InvokeAsync(async () =>
        {
            await LoadPageAsync();
            if (lobby is null)
            {
                await liveCoordinator!.StopAsync();
            }
            else
            {
                await liveCoordinator!.StartAsync(lobby);
            }

            StateHasChanged();
        });

    private Task HandleSessionInvalidatedAsync()
        => InvokeAsync(async () =>
        {
            await LoadSessionAsync();
            StateHasChanged();
        });

    private Task HandleMessagesInvalidatedAsync()
        => InvokeAsync(async () =>
        {
            await LoadMessageUpdatesAsync();
            StateHasChanged();
        });

    private Task HandlePresenceInvalidatedAsync()
        => InvokeAsync(async () =>
        {
            await LoadPresenceAsync();
            StateHasChanged();
        });

    private async Task LeaveGameAsync()
    {
        if (await actionCoordinator!.LeaveGameAsync(GameId, currentUserId))
        {
            Navigation.NavigateTo("/games");
        }
    }

    private Task AcquireCardAsync(Guid marketCardInstanceId)
        => actionCoordinator!.AcquireCardAsync(GameId, currentPlayerId, marketCardInstanceId);

    private Task LockBatchAsync(IReadOnlyList<GameBatchCardSelection> cards)
        => actionCoordinator!.LockBatchAsync(GameId, currentPlayerId, cards);

    private async Task LoadInitialMessagesAsync()
    {
        if (lobby is null)
        {
            return;
        }

        timeline.BeginInitialLoad();

        try
        {
            var page = await GetMessagesHandler.HandleAsync(lobby.GameId, currentPlayerId);
            timeline.ApplyInitialPage(page);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to load initial messages for game {GameId} player {PlayerId}.", GameId, currentPlayerId);
            timeline.MessageError = "We couldn't load messages right now. Please try again.";
        }
        finally
        {
            timeline.CompleteInitialLoad();
        }
    }

    private async Task LoadMessageUpdatesAsync()
    {
        if (lobby is null)
        {
            return;
        }

        if (timeline.NewestMessageId is null)
        {
            await LoadInitialMessagesAsync();
            timeline.RequestScrollToBottom();
            return;
        }

        try
        {
            var shouldStickToBottom = timelineComponent is null || await timelineComponent.IsNearBottomAsync();
            var updates = await GetMessageUpdatesHandler.HandleAsync(lobby.GameId, currentPlayerId, timeline.NewestMessageId);
            if (updates is null || updates.Count == 0)
            {
                return;
            }

            timeline.UpsertPersistedMessages(updates);
            if (shouldStickToBottom)
            {
                timeline.RequestScrollToBottom();
            }
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to load message updates for game {GameId} player {PlayerId}.", GameId, currentPlayerId);
            timeline.MessageError = "We couldn't refresh messages right now. Please try again.";
        }
    }

    private async Task LoadOlderMessagesAsync()
    {
        if (lobby is null || !timeline.HasOlderMessages || timeline.IsLoadingOlderMessages || timeline.OldestMessageId is null)
        {
            return;
        }

        timeline.BeginOlderLoad();

        try
        {
            var metrics = timelineComponent is null
                ? new TimelineScrollMetrics()
                : await timelineComponent.GetScrollMetricsAsync();
            var page = await GetMessagesHandler.HandleAsync(lobby.GameId, currentPlayerId, timeline.OldestMessageId);
            timeline.ApplyOlderPage(page, metrics);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to load older messages for game {GameId} player {PlayerId}.", GameId, currentPlayerId);
            timeline.MessageError = "We couldn't load older messages right now. Please try again.";
        }
        finally
        {
            timeline.CompleteOlderLoad();
        }
    }

    private async Task SendMessageAsync()
    {
        if (lobby is null || !lobby.IsCurrentUserActive || timeline.IsSendingMessage)
        {
            return;
        }

        timeline.MessageError = null;
        var body = timeline.ComposerText.Trim();
        if (string.IsNullOrWhiteSpace(body))
        {
            timeline.MessageError = "Messages cannot be empty.";
            return;
        }

        var recipient = GetSelectedRecipient();
        var pendingItem = timeline.AddPendingMessage(body, recipient?.PlayerId, recipient?.Name ?? string.Empty, recipient is not null);
        timeline.ClearComposer();
        timeline.BeginSend();

        try
        {
            GameMessageCommandOutcome result;
            if (recipient is null)
            {
                result = await SendPublicMessageHandler.HandleAsync(lobby.GameId, currentPlayerId, new SendGameMessageRequest(body));
            }
            else
            {
                result = await SendPrivateMessageHandler.HandleAsync(lobby.GameId, currentPlayerId, recipient.PlayerId, new SendGameMessageRequest(body));
            }

            if (result is not GameMessageCommandSucceeded succeeded)
            {
                timeline.SetPendingMessageFailed(pendingItem.Key, true);
                timeline.MessageError = ((GameMessageCommandFailed)result).ErrorMessage;
                return;
            }

            timeline.ReplacePendingWithPersistedMessage(pendingItem.Key, succeeded.Message);
        }
        catch (Exception exception)
        {
            timeline.SetPendingMessageFailed(pendingItem.Key, true);
            Logger.LogError(exception, "Failed to send a message for game {GameId} player {PlayerId}.", GameId, currentPlayerId);
            timeline.MessageError = "We couldn't send that message right now. Please try again.";
        }
        finally
        {
            timeline.CompleteSend();
        }
    }

    private async Task RetryPendingMessageAsync(Guid itemKey)
    {
        var item = timeline.FindPendingMessage(itemKey);
        if (item?.Pending is null || timeline.IsSendingMessage || lobby is null)
        {
            return;
        }

        timeline.SetPendingMessageFailed(itemKey, false);
        timeline.BeginSend();
        timeline.MessageError = null;

        try
        {
            GameMessageCommandOutcome result;
            if (item.Pending.RecipientPlayerId is null)
            {
                result = await SendPublicMessageHandler.HandleAsync(lobby.GameId, currentPlayerId, new SendGameMessageRequest(item.Pending.Body));
            }
            else
            {
                result = await SendPrivateMessageHandler.HandleAsync(lobby.GameId, currentPlayerId, item.Pending.RecipientPlayerId.Value, new SendGameMessageRequest(item.Pending.Body));
            }

            if (result is not GameMessageCommandSucceeded succeeded)
            {
                timeline.SetPendingMessageFailed(itemKey, true);
                timeline.MessageError = ((GameMessageCommandFailed)result).ErrorMessage;
                return;
            }

            timeline.ReplacePendingWithPersistedMessage(itemKey, succeeded.Message);
        }
        catch (Exception exception)
        {
            timeline.SetPendingMessageFailed(itemKey, true);
            Logger.LogError(exception, "Failed to retry a message for game {GameId} player {PlayerId}.", GameId, currentPlayerId);
            timeline.MessageError = "We couldn't resend that message right now. Please try again.";
        }
        finally
        {
            timeline.CompleteSend();
        }
    }

    private void DismissPendingMessage(Guid itemKey)
    {
        timeline.DismissPendingMessage(itemKey);
    }

    private void BeginEdit(GameTimelineEntryView message)
    {
        timeline.BeginEdit(message);
    }

    private void CancelEdit()
    {
        timeline.CancelEdit();
    }

    private async Task SaveEditAsync()
    {
        if (lobby is null || timeline.EditingMessageId is null || timeline.IsSavingEdit)
        {
            return;
        }

        timeline.BeginSaveEdit();
        timeline.MessageError = null;

        try
        {
            var result = await EditMessageHandler.HandleAsync(lobby.GameId, currentPlayerId, timeline.EditingMessageId.Value, new UpdateGameMessageRequest(timeline.EditMessageText));
            if (result is not GameMessageCommandSucceeded succeeded)
            {
                timeline.MessageError = ((GameMessageCommandFailed)result).ErrorMessage;
                return;
            }

            timeline.UpsertPersistedMessages([succeeded.Message]);
            CancelEdit();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to save a message edit for game {GameId} player {PlayerId}.", GameId, currentPlayerId);
            timeline.MessageError = "We couldn't save that message right now. Please try again.";
        }
        finally
        {
            timeline.CompleteSaveEdit();
        }
    }

    private async Task DeleteMessageAsync(Guid messageId)
    {
        if (lobby is null)
        {
            return;
        }

        timeline.MessageError = null;

        try
        {
            var result = await DeleteMessageHandler.HandleAsync(lobby.GameId, currentPlayerId, messageId);
            if (result is not GameMessageCommandSucceeded succeeded)
            {
                timeline.MessageError = ((GameMessageCommandFailed)result).ErrorMessage;
                return;
            }

            timeline.UpsertPersistedMessages([succeeded.Message]);
            if (timeline.EditingMessageId == messageId)
            {
                CancelEdit();
            }
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to delete a message for game {GameId} player {PlayerId}.", GameId, currentPlayerId);
            timeline.MessageError = "We couldn't delete that message right now. Please try again.";
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (liveCoordinator is not null)
        {
            await liveCoordinator.DisposeAsync();
        }
    }

    private void ResetTimelineState()
    {
        timeline.Reset();
        data.ClearGameplayError();
    }

    private PendingRecipient? GetSelectedRecipient()
    {
        if (!Guid.TryParse(timeline.SelectedRecipientPlayerIdString, out var recipientPlayerId) || lobby is null)
        {
            return null;
        }

        var player = lobby.Players.SingleOrDefault(entry => entry.PlayerId == recipientPlayerId);
        return player is null ? null : new PendingRecipient(player.PlayerId, player.Name);
    }

    private object GetTimelinePanelKey()
        => (nameof(GameTimelinePanel), lobby?.GameId ?? Guid.Empty);

    private object GetMessageComposerKey()
        => (nameof(GameMessageComposer), lobby?.GameId ?? Guid.Empty);

    private sealed record PendingRecipient(Guid PlayerId, string Name);
}