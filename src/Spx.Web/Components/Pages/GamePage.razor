@page "/games/{GameId:guid}"
@attribute [Authorize]
@implements IAsyncDisposable
@using Orleans
@using Spx.Data
@using System.Security.Claims
@inject IClusterClient ClusterClient
@inject IGetGamePageHandler GetGamePageHandler
@inject IGetGamePresenceHandler GetGamePresenceHandler
@inject IGetGameSessionHandler GetGameSessionHandler
@inject IGamePresenceService GamePresenceService
@inject Spx.Web.Circuits.CircuitConnectionEvents CircuitConnectionEvents
@inject ILeaveGameHandler LeaveGameHandler
@inject IGetMessagesHandler GetMessagesHandler
@inject IGetMessageUpdatesHandler GetMessageUpdatesHandler
@inject ISendPublicMessageHandler SendPublicMessageHandler
@inject ISendPrivateMessageHandler SendPrivateMessageHandler
@inject IEditMessageHandler EditMessageHandler
@inject IDeleteMessageHandler DeleteMessageHandler
@inject ISubmitGameMoveHandler SubmitGameMoveHandler
@inject ILogger<GamePage> Logger
@inject NavigationManager Navigation

<PageTitle>Game</PageTitle>

@if (isLoading)
{
    <section class="ui-surface-empty mx-auto max-w-4xl text-slate-300">
        Loading lobby...
    </section>
}
else if (lobby is null)
{
    <section class="ui-surface-empty mx-auto flex max-w-3xl flex-col gap-6">
        <PageHero Eyebrow="Lobby"
                  Title="Game unavailable"
                  Description="You can only open lobby pages for games where you are an active player or where you previously played."
                  Compact />
        <div class="ui-actions">
            <a class="ui-button-primary" href="/games">
                Back to my games
            </a>
            <a class="ui-button-secondary" href="/games/join">
                Join another game
            </a>
        </div>
    </section>
}
else
{
    <section class="ui-page max-w-6xl">
        <header class="ui-surface-form">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
                <div class="space-y-3">
                    <p class="ui-page-eyebrow">Lobby</p>
                    <h1 class="ui-page-title">@lobby.Name</h1>
                    <p class="ui-page-copy">
                        Invite code <span class="font-semibold tracking-[0.25em] text-sky-300">@lobby.InviteCode</span>
                    </p>
                </div>

                <div class="flex flex-wrap items-center gap-3">
                    <span class="ui-status-badge">
                        @lobby.Status
                    </span>
                    <span class="ui-status-badge border-emerald-400/30 bg-emerald-500/10 text-emerald-200">
                        @lobby.Players.Count / @lobby.MaxPlayers players
                    </span>
                </div>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <AlertBanner>@errorMessage</AlertBanner>
        }

        @if (!lobby.IsCurrentUserActive)
        {
            <AlertBanner Tone="warning" Role="status">
                You are viewing this game as a former player. Timeline history is limited to the point when you left.
            </AlertBanner>
        }

        <GameSessionPanel Lobby="@lobby"
                  Session="@session"
                  IsSubmittingMove="@isSubmittingMove"
                  GameplayError="@gameplayError"
                  OnSubmitMove="SubmitMoveAsync" />

        <section class="ui-surface-form">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                <div class="space-y-2">
                    <p class="ui-section-eyebrow">Timeline</p>
                    <h2 class="ui-section-title">Messages and game events</h2>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(messageError))
            {
                <div class="mt-6">
                    <AlertBanner>@messageError</AlertBanner>
                </div>
            }

            <div class="mt-6 grid gap-6 lg:grid-cols-[1.3fr_0.9fr]">
                <GameTimelinePanel @key="GetTimelinePanelKey()"
                                   @ref="timelineComponent"
                                   CurrentUserName="@lobby.CurrentPlayerName"
                                   TimelineItems="timelineItems"
                                   MessageError="@messageError"
                                   IsTimelineLoading="@isTimelineLoading"
                                   IsLoadingOlderMessages="@isLoadingOlderMessages"
                                   HasOlderMessages="@hasOlderMessages"
                                   EditingMessageId="@editingMessageId"
                                   @bind-EditMessageText="editMessageText"
                                   IsSavingEdit="@isSavingEdit"
                                   OnLoadOlderMessages="LoadOlderMessagesAsync"
                                   OnBeginEdit="BeginEdit"
                                   OnCancelEdit="CancelEdit"
                                   OnSaveEdit="SaveEditAsync"
                                   OnDeleteMessage="DeleteMessageAsync"
                                   OnRetryPendingMessage="RetryPendingMessageAsync"
                                   OnDismissPendingMessage="DismissPendingMessage" />

                <GameMessageComposer @key="GetMessageComposerKey()"
                                     IsCurrentUserActive="@lobby.IsCurrentUserActive"
                                     Players="@lobby.Players"
                                     @bind-Text="composerText"
                                     @bind-SelectedRecipientPlayerIdString="selectedRecipientPlayerIdString"
                                     IsSendingMessage="@isSendingMessage"
                                     OnSend="SendMessageAsync" />
            </div>
        </section>

        <div class="grid gap-6 xl:grid-cols-[1.4fr_1fr]">
            <GameRosterPanel Lobby="@lobby" Presence="@presence" />

            <GameCurrentUserPanel Lobby="@lobby"
                                  IsLeaving="@isLeaving"
                                  OnLeave="LeaveGameAsync" />
        </div>
    </section>
}

@code {
    [Parameter]
    public Guid GameId { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private readonly List<TimelineEntryState> timelineItems = [];
    private const int PresenceLeaseSeconds = 10;
    private const int PresenceRenewalSeconds = 5;

    private GameLobbyView? lobby;
    private GameSessionView? session;
    private GamePresenceView presence = GamePresenceView.Empty;
    private string currentUserId = string.Empty;
    private string? errorMessage;
    private string? messageError;
    private string? gameplayError;
    private bool isLoading = true;
    private bool isLeaving;
    private bool isTimelineLoading = true;
    private bool isLoadingOlderMessages;
    private bool isSendingMessage;
    private bool isSavingEdit;
    private bool isSubmittingMove;
    private GamePageSubscription? liveSubscription;
    private GameTimelinePanel? timelineComponent;
    private string composerText = string.Empty;
    private string? selectedRecipientPlayerIdString;
    private Guid? oldestMessageId;
    private Guid? newestMessageId;
    private bool hasOlderMessages;
    private Guid? editingMessageId;
    private string editMessageText = string.Empty;
    private double restoreScrollHeight;
    private double restoreScrollTop;
    private bool shouldRestoreScrollAfterOlderLoad;
    private bool shouldScrollTimelineToBottom;
    private Guid? trackedPresenceGameId;
    private Guid? trackedPresencePlayerId;
    private Guid? presenceConnectionId;
    private CancellationTokenSource? presenceRenewalCts;
    private PeriodicTimer? presenceRenewalTimer;
    private Task? presenceRenewalTask;

    protected override void OnInitialized()
    {
        CircuitConnectionEvents.ConnectionDown += HandleCircuitConnectionDownAsync;
        CircuitConnectionEvents.ConnectionUp += HandleCircuitConnectionUpAsync;
    }

    protected override async Task OnParametersSetAsync()
    {
        currentUserId = await GetUserIdAsync();
        await LoadPageAsync();

        if (lobby is null)
        {
            await StopPresenceTrackingAsync();
            await DisposeSubscriptionsAsync();
            ResetTimelineState();
            return;
        }

        var isNewGame = liveSubscription?.GameId != lobby.GameId;
        if (isNewGame)
        {
            await StopPresenceTrackingAsync();
            await DisposeSubscriptionsAsync();
            ResetTimelineState();
            await LoadInitialMessagesAsync();
            liveSubscription = new GamePageSubscription(
                ClusterClient,
                lobby.GameId,
                HandleLobbyInvalidatedAsync,
                HandleSessionInvalidatedAsync,
                HandleMessagesInvalidatedAsync,
                HandlePresenceInvalidatedAsync);
            await liveSubscription.SubscribeAsync();
            await EnsurePresenceTrackingAsync();
            shouldScrollTimelineToBottom = true;
            return;
        }

        await EnsurePresenceTrackingAsync();

        if (timelineItems.Count == 0)
        {
            await LoadInitialMessagesAsync();
            shouldScrollTimelineToBottom = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (shouldRestoreScrollAfterOlderLoad && timelineComponent is not null)
        {
            shouldRestoreScrollAfterOlderLoad = false;
            await timelineComponent.RestoreScrollAfterPrependAsync(restoreScrollHeight, restoreScrollTop);
        }
        else if (shouldScrollTimelineToBottom && timelineComponent is not null)
        {
            shouldScrollTimelineToBottom = false;
            await timelineComponent.ScrollToBottomAsync();
        }
    }

    private async Task LoadPageAsync()
    {
        isLoading = true;
        errorMessage = null;
        gameplayError = null;

        try
        {
            var page = await GetGamePageHandler.HandleAsync(GameId, currentUserId);
            lobby = page?.Lobby;
            session = page?.Session;
            presence = page?.Presence ?? GamePresenceView.Empty;
        }
        catch (Exception exception)
        {
            lobby = null;
            session = null;
            presence = GamePresenceView.Empty;
            Logger.LogError(exception, "Failed to load game page {GameId} for user {UserId}.", GameId, currentUserId);
            errorMessage = "We couldn't load this game right now. Refresh and try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadPresenceAsync()
    {
        if (lobby is null)
        {
            presence = GamePresenceView.Empty;
            return;
        }

        try
        {
            presence = await GetGamePresenceHandler.HandleAsync(lobby.GameId);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to refresh presence for game {GameId} user {UserId}.", lobby.GameId, currentUserId);
        }
    }

    private async Task LoadSessionAsync()
    {
        if (lobby is null)
        {
            session = null;
            return;
        }

        try
        {
            session = await GetGameSessionHandler.HandleAsync(lobby.GameId, currentUserId);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to refresh session state for game {GameId} user {UserId}.", lobby.GameId, currentUserId);
            gameplayError ??= "We couldn't refresh the game state right now. Please try again.";
        }
    }

    private Task HandleLobbyInvalidatedAsync()
        => InvokeAsync(async () =>
        {
            await LoadPageAsync();
            await EnsurePresenceTrackingAsync();
            StateHasChanged();
        });

    private Task HandleSessionInvalidatedAsync()
        => InvokeAsync(async () =>
        {
            await LoadSessionAsync();
            StateHasChanged();
        });

    private Task HandleMessagesInvalidatedAsync()
        => InvokeAsync(async () =>
        {
            await LoadMessageUpdatesAsync();
            StateHasChanged();
        });

    private Task HandlePresenceInvalidatedAsync()
        => InvokeAsync(async () =>
        {
            await LoadPresenceAsync();
            StateHasChanged();
        });

    private async Task LeaveGameAsync()
    {
        if (isLeaving)
        {
            return;
        }

        isLeaving = true;
        errorMessage = null;

        try
        {
            var result = await LeaveGameHandler.HandleAsync(GameId, currentUserId);

            if (result is GameCommandFailed failed)
            {
                errorMessage = failed.ErrorMessage;
                return;
            }

            Navigation.NavigateTo("/games");
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to leave game {GameId} for user {UserId}.", GameId, currentUserId);
            errorMessage = "We couldn't leave the game right now. Please try again.";
        }
        finally
        {
            isLeaving = false;
        }
    }

    private async Task SubmitMoveAsync(GameMove move)
    {
        if (lobby is null || session is null || !lobby.IsCurrentUserActive || isSubmittingMove)
        {
            return;
        }

        gameplayError = null;
        isSubmittingMove = true;

        try
        {
            var result = await SubmitGameMoveHandler.HandleAsync(lobby.GameId, currentUserId, session.RoundNumber, move);
            if (result is not SubmitGameMoveSucceeded succeeded)
            {
                gameplayError = ((SubmitGameMoveFailed)result).ErrorMessage;
                return;
            }

            session = succeeded.Session;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to submit a move for game {GameId} user {UserId}.", GameId, currentUserId);
            gameplayError = "We couldn't submit your move right now. Please try again.";
        }
        finally
        {
            isSubmittingMove = false;
        }
    }

    private async Task LoadInitialMessagesAsync()
    {
        if (lobby is null)
        {
            return;
        }

        isTimelineLoading = true;
        messageError = null;

        try
        {
            var page = await GetMessagesHandler.HandleAsync(lobby.GameId, currentUserId);
            timelineItems.Clear();

            if (page is not null)
            {
                var orderedItems = page.Items.OrderBy(entry => entry.Id).ToList();
                timelineItems.AddRange(orderedItems.Select(entry => new TimelineEntryState
                {
                    Key = entry.Id,
                    Message = entry
                }));

                hasOlderMessages = page.HasMore;
                oldestMessageId = orderedItems.FirstOrDefault()?.Id;
                newestMessageId = orderedItems.LastOrDefault()?.Id;
            }
            else
            {
                hasOlderMessages = false;
                oldestMessageId = null;
                newestMessageId = null;
            }
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to load initial messages for game {GameId} user {UserId}.", GameId, currentUserId);
            messageError = "We couldn't load messages right now. Please try again.";
        }
        finally
        {
            isTimelineLoading = false;
        }
    }

    private async Task LoadMessageUpdatesAsync()
    {
        if (lobby is null)
        {
            return;
        }

        if (newestMessageId is null)
        {
            await LoadInitialMessagesAsync();
            shouldScrollTimelineToBottom = true;
            return;
        }

        try
        {
            var shouldStickToBottom = timelineComponent is null || await timelineComponent.IsNearBottomAsync();
            var updates = await GetMessageUpdatesHandler.HandleAsync(lobby.GameId, currentUserId, newestMessageId);
            if (updates is null || updates.Count == 0)
            {
                return;
            }

            UpsertPersistedMessages(updates);
            if (shouldStickToBottom)
            {
                shouldScrollTimelineToBottom = true;
            }
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to load message updates for game {GameId} user {UserId}.", GameId, currentUserId);
            messageError = "We couldn't refresh messages right now. Please try again.";
        }
    }

    private async Task LoadOlderMessagesAsync()
    {
        if (lobby is null || !hasOlderMessages || isLoadingOlderMessages || oldestMessageId is null)
        {
            return;
        }

        isLoadingOlderMessages = true;

        try
        {
            var metrics = timelineComponent is null
                ? new TimelineScrollMetrics()
                : await timelineComponent.GetScrollMetricsAsync();
            var page = await GetMessagesHandler.HandleAsync(lobby.GameId, currentUserId, oldestMessageId);
            if (page is null)
            {
                return;
            }

            var existingIds = timelineItems.Where(entry => entry.Message is not null).Select(entry => entry.Message!.Id).ToHashSet();
            var olderItems = page.Items
                .Where(entry => !existingIds.Contains(entry.Id))
                .OrderBy(entry => entry.Id)
                .Select(entry => new TimelineEntryState
                {
                    Key = entry.Id,
                    Message = entry
                })
                .ToList();

            if (olderItems.Count > 0)
            {
                timelineItems.InsertRange(0, olderItems);
                oldestMessageId = timelineItems.FirstOrDefault(entry => entry.Message is not null)?.Message?.Id;
                restoreScrollHeight = metrics.ScrollHeight;
                restoreScrollTop = metrics.ScrollTop;
                shouldRestoreScrollAfterOlderLoad = true;
            }

            hasOlderMessages = page.HasMore;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to load older messages for game {GameId} user {UserId}.", GameId, currentUserId);
            messageError = "We couldn't load older messages right now. Please try again.";
        }
        finally
        {
            isLoadingOlderMessages = false;
        }
    }

    private async Task SendMessageAsync()
    {
        if (lobby is null || !lobby.IsCurrentUserActive || isSendingMessage)
        {
            return;
        }

        messageError = null;
        var body = composerText.Trim();
        if (string.IsNullOrWhiteSpace(body))
        {
            messageError = "Messages cannot be empty.";
            return;
        }

        var recipient = GetSelectedRecipient();
        var pendingItem = CreatePendingMessage(body, recipient);
        timelineItems.Add(pendingItem);
        composerText = string.Empty;
        selectedRecipientPlayerIdString = null;
        shouldScrollTimelineToBottom = true;
        isSendingMessage = true;

        try
        {
            GameMessageCommandOutcome result;
            if (recipient is null)
            {
                result = await SendPublicMessageHandler.HandleAsync(lobby.GameId, currentUserId, new SendGameMessageRequest(body));
            }
            else
            {
                result = await SendPrivateMessageHandler.HandleAsync(lobby.GameId, currentUserId, recipient.PlayerId, new SendGameMessageRequest(body));
            }

            if (result is not GameMessageCommandSucceeded succeeded)
            {
                pendingItem.Pending!.Failed = true;
                messageError = ((GameMessageCommandFailed)result).ErrorMessage;
                return;
            }

            ReplacePendingWithPersistedMessage(pendingItem.Key, succeeded.Message);
        }
        catch (Exception exception)
        {
            pendingItem.Pending!.Failed = true;
            Logger.LogError(exception, "Failed to send a message for game {GameId} user {UserId}.", GameId, currentUserId);
            messageError = "We couldn't send that message right now. Please try again.";
        }
        finally
        {
            isSendingMessage = false;
        }
    }

    private async Task RetryPendingMessageAsync(Guid itemKey)
    {
        var item = timelineItems.SingleOrDefault(entry => entry.Key == itemKey && entry.Pending is not null);
        if (item?.Pending is null || isSendingMessage || lobby is null)
        {
            return;
        }

        item.Pending.Failed = false;
        isSendingMessage = true;
        messageError = null;

        try
        {
            GameMessageCommandOutcome result;
            if (item.Pending.RecipientPlayerId is null)
            {
                result = await SendPublicMessageHandler.HandleAsync(lobby.GameId, currentUserId, new SendGameMessageRequest(item.Pending.Body));
            }
            else
            {
                result = await SendPrivateMessageHandler.HandleAsync(lobby.GameId, currentUserId, item.Pending.RecipientPlayerId.Value, new SendGameMessageRequest(item.Pending.Body));
            }

            if (result is not GameMessageCommandSucceeded succeeded)
            {
                item.Pending.Failed = true;
                messageError = ((GameMessageCommandFailed)result).ErrorMessage;
                return;
            }

            ReplacePendingWithPersistedMessage(itemKey, succeeded.Message);
        }
        catch (Exception exception)
        {
            item.Pending.Failed = true;
            Logger.LogError(exception, "Failed to retry a message for game {GameId} user {UserId}.", GameId, currentUserId);
            messageError = "We couldn't resend that message right now. Please try again.";
        }
        finally
        {
            isSendingMessage = false;
        }
    }

    private void DismissPendingMessage(Guid itemKey)
    {
        timelineItems.RemoveAll(entry => entry.Key == itemKey && entry.Pending is not null);
    }

    private void BeginEdit(GameTimelineEntryView message)
    {
        editingMessageId = message.Id;
        editMessageText = message.Body;
    }

    private void CancelEdit()
    {
        editingMessageId = null;
        editMessageText = string.Empty;
        isSavingEdit = false;
    }

    private async Task SaveEditAsync()
    {
        if (lobby is null || editingMessageId is null || isSavingEdit)
        {
            return;
        }

        isSavingEdit = true;
        messageError = null;

        try
        {
            var result = await EditMessageHandler.HandleAsync(lobby.GameId, currentUserId, editingMessageId.Value, new UpdateGameMessageRequest(editMessageText));
            if (result is not GameMessageCommandSucceeded succeeded)
            {
                messageError = ((GameMessageCommandFailed)result).ErrorMessage;
                return;
            }

            UpsertPersistedMessages([succeeded.Message]);
            CancelEdit();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to save a message edit for game {GameId} user {UserId}.", GameId, currentUserId);
            messageError = "We couldn't save that message right now. Please try again.";
        }
        finally
        {
            isSavingEdit = false;
        }
    }

    private async Task DeleteMessageAsync(Guid messageId)
    {
        if (lobby is null)
        {
            return;
        }

        messageError = null;

        try
        {
            var result = await DeleteMessageHandler.HandleAsync(lobby.GameId, currentUserId, messageId);
            if (result is not GameMessageCommandSucceeded succeeded)
            {
                messageError = ((GameMessageCommandFailed)result).ErrorMessage;
                return;
            }

            UpsertPersistedMessages([succeeded.Message]);
            if (editingMessageId == messageId)
            {
                CancelEdit();
            }
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to delete a message for game {GameId} user {UserId}.", GameId, currentUserId);
            messageError = "We couldn't delete that message right now. Please try again.";
        }
    }

    public async ValueTask DisposeAsync()
    {
        CircuitConnectionEvents.ConnectionDown -= HandleCircuitConnectionDownAsync;
        CircuitConnectionEvents.ConnectionUp -= HandleCircuitConnectionUpAsync;
        await StopPresenceTrackingAsync();
        await DisposeSubscriptionsAsync();
    }

    private async Task<string> GetUserIdAsync()
    {
        var authenticationState = await AuthenticationStateTask;
        return authenticationState.User.FindFirstValue(ClaimTypes.NameIdentifier)
            ?? throw new InvalidOperationException("The current user does not have an identity id claim.");
    }

    private async Task DisposeSubscriptionsAsync()
    {
        if (liveSubscription is not null)
        {
            await liveSubscription.DisposeAsync();
            liveSubscription = null;
        }
    }

    private void ResetTimelineState()
    {
        timelineItems.Clear();
        oldestMessageId = null;
        newestMessageId = null;
        hasOlderMessages = false;
        isTimelineLoading = true;
        isLoadingOlderMessages = false;
        messageError = null;
        gameplayError = null;
        composerText = string.Empty;
        selectedRecipientPlayerIdString = null;
        editingMessageId = null;
        editMessageText = string.Empty;
        restoreScrollHeight = 0;
        restoreScrollTop = 0;
        shouldRestoreScrollAfterOlderLoad = false;
        shouldScrollTimelineToBottom = false;
    }

    private async Task EnsurePresenceTrackingAsync()
    {
        if (lobby is null || !lobby.IsCurrentUserActive)
        {
            await StopPresenceTrackingAsync();
            return;
        }

        var currentPlayerId = lobby.Players.SingleOrDefault(player => player.IsCurrentUser)?.PlayerId;
        if (!currentPlayerId.HasValue)
        {
            await StopPresenceTrackingAsync();
            return;
        }

        if (trackedPresenceGameId == lobby.GameId
            && trackedPresencePlayerId == currentPlayerId
            && presenceConnectionId.HasValue)
        {
            if (presenceRenewalTask is not null)
            {
                return;
            }

            await ResumePresenceTrackingAsync(lobby.GameId, currentPlayerId.Value, presenceConnectionId.Value);
            return;
        }

        await StopPresenceTrackingAsync();

        trackedPresenceGameId = lobby.GameId;
        trackedPresencePlayerId = currentPlayerId;
        presenceConnectionId = Guid.NewGuid();
        presenceRenewalCts = new CancellationTokenSource();
        presenceRenewalTimer = new PeriodicTimer(TimeSpan.FromSeconds(PresenceRenewalSeconds));

        await PublishPresenceLeaseAsync(lobby.GameId, currentPlayerId.Value, presenceConnectionId.Value, presenceRenewalCts.Token);
        await LoadPresenceAsync();
        presenceRenewalTask = RenewPresenceAsync(lobby.GameId, currentPlayerId.Value, presenceConnectionId.Value, presenceRenewalCts.Token);
    }

    private Task HandleCircuitConnectionDownAsync()
        => InvokeAsync(PausePresenceTrackingAsync);

    private Task HandleCircuitConnectionUpAsync()
        => InvokeAsync(async () =>
        {
            await EnsurePresenceTrackingAsync();
            StateHasChanged();
        });

    private async Task RenewPresenceAsync(Guid gameId, Guid playerId, Guid connectionId, CancellationToken cancellationToken)
    {
        if (presenceRenewalTimer is null)
        {
            return;
        }

        try
        {
            while (await presenceRenewalTimer.WaitForNextTickAsync(cancellationToken))
            {
                await PublishPresenceLeaseAsync(gameId, playerId, connectionId, cancellationToken);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task PublishPresenceLeaseAsync(Guid gameId, Guid playerId, Guid connectionId, CancellationToken cancellationToken)
    {
        try
        {
            await GamePresenceService.UpsertPresenceLeaseAsync(
                gameId,
                playerId,
                connectionId,
                DateTime.UtcNow.AddSeconds(PresenceLeaseSeconds),
                cancellationToken);
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Failed to renew presence for game {GameId} player {PlayerId}.", gameId, playerId);
        }
    }

    private async Task ResumePresenceTrackingAsync(Guid gameId, Guid playerId, Guid connectionId)
    {
        presenceRenewalCts = new CancellationTokenSource();
        presenceRenewalTimer = new PeriodicTimer(TimeSpan.FromSeconds(PresenceRenewalSeconds));

        await PublishPresenceLeaseAsync(gameId, playerId, connectionId, presenceRenewalCts.Token);
        await LoadPresenceAsync();
        presenceRenewalTask = RenewPresenceAsync(gameId, playerId, connectionId, presenceRenewalCts.Token);
    }

    private async Task PausePresenceTrackingAsync()
    {
        var timer = presenceRenewalTimer;
        var cancellationSource = presenceRenewalCts;
        var renewalTask = presenceRenewalTask;

        presenceRenewalTimer = null;
        presenceRenewalCts = null;
        presenceRenewalTask = null;

        cancellationSource?.Cancel();

        if (renewalTask is not null)
        {
            try
            {
                await renewalTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        timer?.Dispose();
        cancellationSource?.Dispose();
    }

    private async Task StopPresenceTrackingAsync()
    {
        var gameId = trackedPresenceGameId;
        var playerId = trackedPresencePlayerId;
        var connectionId = presenceConnectionId;

        trackedPresenceGameId = null;
        trackedPresencePlayerId = null;
        presenceConnectionId = null;

        await PausePresenceTrackingAsync();

        if (!gameId.HasValue || !playerId.HasValue || !connectionId.HasValue)
        {
            return;
        }

        try
        {
            await GamePresenceService.RemovePresenceLeaseAsync(gameId.Value, playerId.Value, connectionId.Value);
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Failed to remove presence lease for game {GameId} player {PlayerId}.", gameId.Value, playerId.Value);
        }
    }

    private void UpsertPersistedMessages(IEnumerable<GameTimelineEntryView> messages)
    {
        foreach (var message in messages)
        {
            var existingItem = timelineItems.SingleOrDefault(entry => entry.Message?.Id == message.Id);
            if (existingItem is not null)
            {
                existingItem.Message = message;
                continue;
            }

            timelineItems.Add(new TimelineEntryState
            {
                Key = message.Id,
                Message = message
            });
        }

        timelineItems.Sort(static (left, right) => CompareTimelineItems(left, right));
        oldestMessageId = timelineItems.FirstOrDefault(entry => entry.Message is not null)?.Message?.Id;
        newestMessageId = timelineItems.LastOrDefault(entry => entry.Message is not null)?.Message?.Id;
    }

    private void ReplacePendingWithPersistedMessage(Guid itemKey, GameTimelineEntryView message)
    {
        timelineItems.RemoveAll(entry => entry.Key == itemKey);
        UpsertPersistedMessages([message]);
    }

    private PendingRecipient? GetSelectedRecipient()
    {
        if (!Guid.TryParse(selectedRecipientPlayerIdString, out var recipientPlayerId) || lobby is null)
        {
            return null;
        }

        var player = lobby.Players.SingleOrDefault(entry => entry.PlayerId == recipientPlayerId);
        return player is null ? null : new PendingRecipient(player.PlayerId, player.Name);
    }

    private TimelineEntryState CreatePendingMessage(string body, PendingRecipient? recipient)
        => new()
        {
            Key = Guid.NewGuid(),
            Pending = new PendingMessageState(
                body,
                recipient?.PlayerId,
                recipient?.Name ?? string.Empty,
                DateTime.UtcNow,
                recipient is not null,
                false)
        };

    private object GetTimelinePanelKey()
        => (nameof(GameTimelinePanel), lobby?.GameId ?? Guid.Empty);

    private object GetMessageComposerKey()
        => (nameof(GameMessageComposer), lobby?.GameId ?? Guid.Empty);

    private static int CompareTimelineItems(TimelineEntryState left, TimelineEntryState right)
    {
        if (left.Message is null && right.Message is not null)
        {
            return 1;
        }

        if (left.Message is not null && right.Message is null)
        {
            return -1;
        }

        if (left.Message is null && right.Message is null)
        {
            return DateTime.Compare(left.Pending?.CreatedAtUtc ?? DateTime.MinValue, right.Pending?.CreatedAtUtc ?? DateTime.MinValue);
        }

        return left.Message!.Id.CompareTo(right.Message!.Id);
    }

    private sealed record PendingRecipient(Guid PlayerId, string Name);
}