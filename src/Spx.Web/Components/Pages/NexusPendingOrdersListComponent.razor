@if (!Orders.Any())
{
    <p class="text-xs text-slate-500">
        No fleet orders yet. Select a fleet on the map to assign move or colonize orders.
    </p>
}
else
{
    <ul class="space-y-2">
        @foreach (var order in Orders)
        {
            var description = GetOrderDescription(order);
            <li class="flex items-center justify-between gap-2 rounded-xl border border-white/10 bg-slate-950/60 px-3 py-2">
                <span class="text-xs text-slate-200">@description</span>
                @if (IsEditable)
                {
                    <button class="text-sm text-slate-500 transition-colors hover:text-rose-400" title="Remove order"
                            @onclick="() => HandleRemove(order)">
                        ×
                    </button>
                }
            </li>
        }
    </ul>
}

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<NexusFleetOrder> Orders { get; set; } = [];

    [Parameter]
    public bool IsEditable { get; set; }

    [Parameter]
    public EventCallback<NexusFleetOrder> OnRemoveOrder { get; set; }

    private static string GetOrderDescription(NexusFleetOrder order) =>
        order switch
        {
            NexusMoveOrder move => $"Move {move.From} → {move.To} ×{move.Count}",
            NexusColonizeOrder col => $"Colonize {col.From}",
            _ => order.GetType().Name,
        };

    private Task HandleRemove(NexusFleetOrder order) => OnRemoveOrder.InvokeAsync(order);
}
