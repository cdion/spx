@page "/games/join"
@attribute [Authorize]
@using System.Security.Claims
@inject IJoinGameHandler JoinGameHandler
@inject NavigationManager Navigation

<PageTitle>Join Game</PageTitle>

<section class="ui-page">
    <PageHero Eyebrow="Lobby"
              Title="Join a game"
              Description="Enter the invite code and the player name you want to use inside that game." />

    <div class="ui-surface-form">
        <div class="ui-flow">
            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <AlertBanner>@errorMessage</AlertBanner>
            }

            <div class="ui-field">
                <label class="ui-label" for="invite-code">Invite code</label>
                <input id="invite-code"
                       class="ui-input uppercase tracking-[0.35em]"
                       maxlength="6"
                       placeholder="ABC123"
                       @bind="inviteCode" />
            </div>

            <div class="ui-field">
                <label class="ui-label" for="join-player-name">Player name</label>
                <input id="join-player-name"
                       class="ui-input"
                       maxlength="40"
                       placeholder="Captain Blue"
                       @bind="playerName" />
            </div>

            <div class="ui-actions">
                <button class="ui-button-primary"
                        @onclick="JoinGameAsync"
                        disabled="@isSubmitting">
                    @(isSubmitting ? "Joining game..." : "Join game")
                </button>
                <a class="ui-button-secondary" href="/games">
                    Cancel
                </a>
            </div>
        </div>
    </div>
</section>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private string inviteCode = string.Empty;
    private string playerName = string.Empty;
    private string? errorMessage;
    private bool isSubmitting;

    private async Task JoinGameAsync()
    {
        if (isSubmitting)
        {
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            var userId = await GetUserIdAsync();
            var result = await JoinGameHandler.HandleAsync(userId, new JoinGameRequest(inviteCode, playerName));

            if (!result.Succeeded || result.GameId is null)
            {
                errorMessage = result.ErrorMessage ?? "The game could not be joined.";
                return;
            }

            Navigation.NavigateTo($"/games/{result.GameId.Value}");
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task<string> GetUserIdAsync()
    {
        var authenticationState = await AuthenticationStateTask;
        return authenticationState.User.FindFirstValue(ClaimTypes.NameIdentifier)
            ?? throw new InvalidOperationException("The current user does not have an identity id claim.");
    }
}