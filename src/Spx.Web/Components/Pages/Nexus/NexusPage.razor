@page "/games/{GameId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]
@implements IAsyncDisposable
@implements IGameInvalidationSubscriber
@using Orleans
@using Spx.Contracts
@using Spx.Data
@using Spx.Web.Hubs
@using Spx.Web.Presence
@using System.Security.Claims
@inject IGetNexusPageHandler GetNexusPageHandler
@inject IGetGamePresenceHandler GetGamePresenceHandler
@inject ILeaveGameHandler LeaveGameHandler
@inject IGetMessagesHandler GetMessagesHandler
@inject IGetMessageUpdatesHandler GetMessageUpdatesHandler
@inject ISendPublicMessageHandler SendPublicMessageHandler
@inject ISendPrivateMessageHandler SendPrivateMessageHandler
@inject IEditMessageHandler EditMessageHandler
@inject IDeleteMessageHandler DeleteMessageHandler
@inject ISubmitOrdersHandler SubmitOrdersHandler
@inject IManageDesignHandler ManageDesignHandler
@inject IGameInvalidationNotifier InvalidationNotifier
@inject NexusPresenceLeaseCoordinator PresenceLeaseCoordinator
@inject ILogger<NexusPage> Logger
@inject ILogger<NexusPageActionCoordinator> ActionCoordinatorLogger
@inject ILogger<NexusPageDataCoordinator> DataCoordinatorLogger
@inject ILogger<NexusPageMessageCoordinator> MessageCoordinatorLogger
@inject ILogger<NexusPagePresenceCoordinator> PresenceCoordinatorLogger
@inject NavigationManager Navigation

<PageTitle>Game</PageTitle>

@if (isLoading)
{
    <section class="ui-surface-empty mx-auto max-w-4xl text-slate-300">
        Loading lobby...
    </section>
}
else if (lobby is null)
{
    <section class="ui-surface-empty mx-auto flex max-w-3xl flex-col gap-6">
        <PageHero Eyebrow="Lobby" Title="Game unavailable"
                  Description="You can only open lobby pages for games where you are an active player or where you previously played."
                  Compact />
        <div class="ui-actions">
            <a class="ui-button-primary" href="/games">
                Back to My Games
            </a>
            <a class="ui-button-secondary" href="/games/join">
                Join another game
            </a>
        </div>
    </section>
}
else
{
    <section class="ui-page max-w-6xl gap-6 lg:gap-7">
        <LobbyHeader Lobby="@lobby" Presence="@presence" />

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <AlertBanner>@errorMessage</AlertBanner>
        }

        @if (!lobby.IsCurrentUserActive)
        {
            <AlertBanner Tone="@AlertBanner.AlertTone.Warning" Role="status">
                You are viewing this game as a former player. Timeline history is limited to the point when you left.
            </AlertBanner>
        }

        <LobbySessionPanel @ref="sessionPanel" State="LobbySessionState" MessagesState="LobbyMessagesState"
                           MessagesCallbacks="LobbyMessagesCallbacks" OnSubmitOrders="SubmitOrdersAsync"
                           OnCreateDesign="CreateDesignAsync" OnDeleteDesign="DeleteDesignAsync"
                           OnGameplayErrorCleared="ClearGameplayErrorAsync" />

        <LobbyCurrentUserPanel Lobby="@lobby" IsLeaving="@isLeaving" OnLeave="LeaveGameAsync" />
    </section>
}

@code {
    [Parameter]
    public Guid GameId { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private readonly NexusPageDataState data = new();
    private readonly NexusPageActionState actions = new();
    private readonly NexusPagePresenceState presenceState = new();
    private readonly NexusTimelineState timeline = new();

    private string currentUserId = string.Empty;
    private Guid currentPlayerId;
    private NexusPageActionCoordinator? actionCoordinator;
    private NexusPageDataCoordinator? dataCoordinator;
    private NexusPageMessageCoordinator? messageCoordinator;
    private NexusPagePresenceCoordinator? presenceCoordinator;
    private LobbySessionPanel? sessionPanel;

    private GameLobbyView? lobby => data.Lobby;

    private NexusGameView? session => data.Session;

    private GamePresenceView presence => data.Presence;

    private string? errorMessage => data.ErrorMessage;

    private string? gameplayError => data.GameplayError;

    private bool isLoading => data.IsLoading;

    private bool isLeaving => actions.IsLeaving;

    private bool isSubmittingGameplayAction => actions.IsSubmittingGameplayAction;

    private LobbySessionState LobbySessionState => new()
    {
        Lobby = lobby!,
        Session = session,
        IsSubmittingGameplayAction = isSubmittingGameplayAction,
        GameplayError = gameplayError,
    };

    private LobbyMessagesState LobbyMessagesState => new()
    {
        CurrentUserName = lobby!.CurrentPlayerName,
        Items = timeline.Items,
        TimelineError = timeline.TimelineError,
        ComposerError = timeline.ComposerError,
        IsTimelineLoading = timeline.IsTimelineLoading,
        IsLoadingOlderMessages = timeline.IsLoadingOlderMessages,
        HasOlderMessages = timeline.HasOlderMessages,
        EditingMessageId = timeline.EditingMessageId,
        EditMessageText = timeline.EditMessageText,
        IsSavingEdit = timeline.IsSavingEdit,
        ComposerResetVersion = timeline.ComposerResetVersion,
        IsSendingMessage = timeline.IsSendingMessage,
        IsCurrentUserActive = lobby!.IsCurrentUserActive,
        CurrentPlayerId = lobby!.CurrentPlayerId,
        Players = lobby!.Players,
    };

    private LobbyMessagesCallbacks LobbyMessagesCallbacks => new()
    {
        LoadOlderMessagesAsync = EventCallback.Factory.Create(this, LoadOlderMessagesAsync),
        BeginEditAsync = EventCallback.Factory.Create<GameTimelineEntryView>(this, BeginEditAsync),
        SetEditMessageTextAsync = EventCallback.Factory.Create<string>(this, SetEditMessageTextAsync),
        CancelEditAsync = EventCallback.Factory.Create(this, CancelEditAsync),
        SaveEditAsync = EventCallback.Factory.Create(this, SaveEditAsync),
        DeleteMessageAsync = EventCallback.Factory.Create<Guid>(this, DeleteMessageAsync),
        RetryPendingMessageAsync = EventCallback.Factory.Create<Guid>(this, RetryPendingMessageAsync),
        DismissPendingMessageAsync = EventCallback.Factory.Create<Guid>(this, DismissPendingMessageAsync),
        SendMessageAsync = EventCallback.Factory.Create<LobbyMessageComposerSubmitRequest>(this, SendMessageAsync),
    };

    protected override void OnInitialized()
    {
        actionCoordinator = new NexusPageActionCoordinator(
            LeaveGameHandler,
            SubmitOrdersHandler,
            ManageDesignHandler,
            ActionCoordinatorLogger,
            data,
            actions);
        dataCoordinator = new NexusPageDataCoordinator(
            GetNexusPageHandler,
            GetGamePresenceHandler,
            DataCoordinatorLogger,
            data);
        messageCoordinator = new NexusPageMessageCoordinator(
            GetMessagesHandler,
            GetMessageUpdatesHandler,
            SendPublicMessageHandler,
            SendPrivateMessageHandler,
            EditMessageHandler,
            DeleteMessageHandler,
            MessageCoordinatorLogger,
            data,
            timeline);
        presenceCoordinator = new NexusPagePresenceCoordinator(
            GetGamePresenceHandler,
            InvalidationNotifier,
            PresenceLeaseCoordinator,
            PresenceCoordinatorLogger,
            data,
            presenceState);
    }

    protected override async Task OnParametersSetAsync()
    {
        currentUserId = await UiHelpers.GetUserIdAsync(AuthenticationStateTask);
        await LoadPageAsync();
        if (lobby is not null)
        {
            currentPlayerId = lobby.CurrentPlayerId;
        }

        if (lobby is null)
        {
            await presenceCoordinator!.DisconnectAsync(this);
            ResetTimelineState();
            return;
        }

        var isNewGame = !presenceCoordinator!.IsConnectedTo(lobby.GameId);
        if (isNewGame)
        {
            ResetTimelineState();
            await LoadInitialMessagesAsync();
            await presenceCoordinator.ChangeGameAsync(lobby.GameId, this);
            timeline.RequestScrollToBottom();
            return;
        }

        if (!presenceCoordinator.HasConnectedGame)
        {
            await presenceCoordinator.ConnectAsync(lobby.GameId, this);
        }
        else
        {
            await presenceCoordinator.SyncAsync();
        }

        if (timeline.Items.Count == 0)
        {
            await LoadInitialMessagesAsync();
            timeline.RequestScrollToBottom();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (timeline.ShouldRestoreScrollAfterOlderLoad && sessionPanel is not null)
        {
            timeline.MarkRestoreScrollHandled();
            await sessionPanel.RestoreScrollAfterPrependAsync(timeline.RestoreScrollHeight, timeline.RestoreScrollTop);
        }
        else if (timeline.ShouldScrollTimelineToBottom && sessionPanel is not null)
        {
            timeline.MarkScrollToBottomHandled();
            await sessionPanel.ScrollToBottomAsync();
        }
    }

    private Task LoadPageAsync()
        => dataCoordinator!.LoadPageAsync(GameId, currentUserId);

    private Task LoadInitialMessagesAsync()
        => messageCoordinator!.LoadInitialMessagesAsync(GameId, currentPlayerId);

    private Task LoadMessageUpdatesAsync()
        => messageCoordinator!.LoadMessageUpdatesAsync(GameId, currentPlayerId, sessionPanel);

    private Task LoadOlderMessagesAsync()
        => messageCoordinator!.LoadOlderMessagesAsync(GameId, currentPlayerId, sessionPanel);

    private Task SendMessageAsync(LobbyMessageComposerSubmitRequest request)
        => messageCoordinator!.SendMessageAsync(GameId, currentPlayerId, request);

    private Task RetryPendingMessageAsync(Guid itemKey)
        => messageCoordinator!.RetryPendingMessageAsync(GameId, currentPlayerId, itemKey);

    private Task DismissPendingMessageAsync(Guid itemKey)
    {
        messageCoordinator!.DismissPendingMessage(itemKey);
        return Task.CompletedTask;
    }

    private Task BeginEditAsync(GameTimelineEntryView message)
    {
        messageCoordinator!.BeginEdit(message);
        return Task.CompletedTask;
    }

    private Task CancelEditAsync()
    {
        messageCoordinator!.CancelEdit();
        return Task.CompletedTask;
    }

    private Task SetEditMessageTextAsync(string text)
    {
        messageCoordinator!.SetEditMessageText(text);
        return Task.CompletedTask;
    }

    private Task SaveEditAsync()
        => messageCoordinator!.SaveEditAsync(GameId, currentPlayerId);

    private Task DeleteMessageAsync(Guid messageId)
        => messageCoordinator!.DeleteMessageAsync(GameId, currentPlayerId, messageId);

    public Task OnGameStateChangedAsync(Guid gameId)
        => InvokeAsync(async () =>
        {
            if (!presenceCoordinator!.IsConnectedTo(gameId))
            {
                return;
            }

            await LoadPageAsync();
            if (lobby is null)
            {
                await presenceCoordinator.DisconnectAsync(this);
                ResetTimelineState();
            }
            else
            {
                currentPlayerId = lobby.CurrentPlayerId;
                await presenceCoordinator.SyncAsync();
            }

            StateHasChanged();
        });

    public Task OnMessagesChangedAsync(Guid gameId)
        => InvokeAsync(async () =>
        {
            if (!presenceCoordinator!.IsConnectedTo(gameId))
            {
                return;
            }

            await LoadMessageUpdatesAsync();
            StateHasChanged();
        });

    public Task OnPresenceChangedAsync(Guid gameId)
        => InvokeAsync(async () =>
        {
            if (!presenceCoordinator!.IsConnectedTo(gameId))
            {
                return;
            }

            await presenceCoordinator.LoadPresenceAsync();
            StateHasChanged();
        });


    private Task HandleLobbyInvalidatedAsync() => Task.CompletedTask;

    private Task HandleSessionInvalidatedAsync() => Task.CompletedTask;

    private Task HandleMessagesInvalidatedAsync() => Task.CompletedTask;

    private Task HandlePresenceInvalidatedAsync() => Task.CompletedTask;

    private async Task LeaveGameAsync()
    {
        if (await actionCoordinator!.LeaveGameAsync(GameId, currentUserId))
        {
            Navigation.NavigateTo("/games");
        }
    }

    private Task SubmitOrdersAsync(NexusTurnOrdersCommand command)
        => actionCoordinator!.SubmitOrdersAsync(GameId, command);

    private async Task CreateDesignAsync(NexusCreateDesignCommand command)
    {
        await actionCoordinator!.CreateDesignAsync(GameId, command);
        StateHasChanged();
    }

    private async Task DeleteDesignAsync(Guid designId)
    {
        await actionCoordinator!.DeleteDesignAsync(GameId, new NexusDeleteDesignCommand(currentPlayerId, designId));
        StateHasChanged();
    }

    private Task ClearGameplayErrorAsync()
    {
        data.ClearGameplayError();
        StateHasChanged();
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        await presenceCoordinator!.DisposeAsync(this);
    }

    private void ResetTimelineState()
    {
        timeline.Reset();
        data.ClearGameplayError();
    }
}