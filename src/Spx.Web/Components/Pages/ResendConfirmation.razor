@page "/resend-confirmation"
@attribute [AllowAnonymous]

<PageTitle>Resend confirmation</PageTitle>

<section class="ui-page">
    <PageHero Eyebrow="Identity"
              Title="Resend confirmation email"
              Description="Enter the email address you used to register and we will send a fresh confirmation link if the account still needs one." />

    <div class="ui-surface-form">
        <div class="ui-flow">
            @if (!string.IsNullOrWhiteSpace(Status))
            {
                <AlertBanner Tone="success" Role="status">@Status</AlertBanner>
            }

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <AlertBanner>@Error</AlertBanner>
            }

            <form method="post" action="/account/resend-confirmation" class="ui-flow">
                <AntiforgeryToken />

                <div class="ui-field">
                    <label class="ui-label" for="email">Email</label>
                    <input id="email" name="email" type="email" value="@Email" autocomplete="email" required
                           class="ui-input" />
                </div>

                <button class="ui-button-primary" type="submit">
                    Resend email
                </button>
            </form>
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "status")]
    public string? Status { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }
}