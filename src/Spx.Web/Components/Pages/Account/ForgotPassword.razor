@page "/forgot-password"
@attribute [AllowAnonymous]

<PageTitle>Forgot password</PageTitle>

<AccountForgotPasswordForm Email="@Email" Error="@Error" Status="@Status">
    <FormTokens>
        <AntiforgeryToken />
    </FormTokens>
</AccountForgotPasswordForm>

@code {
    [SupplyParameterFromQuery(Name = "status")] public string? Status { get; set; }
    [SupplyParameterFromQuery(Name = "error")] public string? Error { get; set; }
    [SupplyParameterFromQuery(Name = "email")] public string? Email { get; set; }
}