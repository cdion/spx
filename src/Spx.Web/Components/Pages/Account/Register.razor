@page "/register"
@attribute [AllowAnonymous]

<PageTitle>Create account</PageTitle>

<AccountRegisterForm Email="@Email" Error="@Error">
    <FormTokens><AntiforgeryToken /></FormTokens>
</AccountRegisterForm>

@code {
    [SupplyParameterFromQuery(Name = "error")] public string? Error { get; set; }
    [SupplyParameterFromQuery(Name = "email")] public string? Email { get; set; }
}