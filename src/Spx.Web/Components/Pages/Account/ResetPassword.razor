@page "/reset-password"
@attribute [AllowAnonymous]

<PageTitle>Choose a new password</PageTitle>

<AccountResetPasswordForm Email="@Email" Code="@Code" Error="@Error">
    <FormTokens>
        <AntiforgeryToken />
    </FormTokens>
</AccountResetPasswordForm>

@code {
    [SupplyParameterFromQuery(Name = "email")] public string? Email { get; set; }
    [SupplyParameterFromQuery(Name = "code")] public string? Code { get; set; }
    [SupplyParameterFromQuery(Name = "error")] public string? Error { get; set; }
}