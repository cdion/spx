@page "/reset-password"
@attribute [AllowAnonymous]

<PageTitle>Choose a new password</PageTitle>

<section class="mx-auto flex max-w-2xl flex-col gap-8">
    <header class="space-y-4">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-sky-300">Identity</p>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">Choose a new password</h1>
        <p class="max-w-2xl text-base leading-7 text-slate-300 sm:text-lg">
            Set a new password for your account using the reset link sent to your email address.
        </p>
    </header>

    <div class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-2xl shadow-slate-950/40 backdrop-blur sm:p-8">
        <div class="space-y-6">
            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <div class="rounded-2xl border border-red-400/30 bg-red-500/10 px-4 py-3 text-sm text-red-100" role="alert">@Error</div>
            }

            @if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Code))
            {
                <div class="rounded-2xl border border-amber-400/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-100">
                    The reset link is incomplete. Request a new password reset email.
                </div>
                <a class="inline-flex items-center justify-center rounded-full bg-sky-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-sky-300" href="/forgot-password">
                    Request new link
                </a>
            }
            else
            {
                <form method="post" action="/account/reset-password" class="space-y-6">
                    <AntiforgeryToken />
                    <input type="hidden" name="email" value="@Email" />
                    <input type="hidden" name="code" value="@Code" />

                    <div class="space-y-2">
                        <label class="block text-sm font-medium text-slate-200" for="password">New password</label>
                        <input id="password" name="password" type="password" autocomplete="new-password" required
                               class="w-full rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-base text-white outline-none transition placeholder:text-slate-500 focus:border-sky-300/60 focus:ring-2 focus:ring-sky-400/30" />
                    </div>

                    <div class="space-y-2">
                        <label class="block text-sm font-medium text-slate-200" for="confirmPassword">Confirm new password</label>
                        <input id="confirmPassword" name="confirmPassword" type="password" autocomplete="new-password" required
                               class="w-full rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-base text-white outline-none transition placeholder:text-slate-500 focus:border-sky-300/60 focus:ring-2 focus:ring-sky-400/30" />
                    </div>

                    <button class="inline-flex items-center justify-center rounded-full bg-sky-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-sky-300" type="submit">
                        Reset password
                    </button>
                </form>
            }
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "code")]
    public string? Code { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }
}