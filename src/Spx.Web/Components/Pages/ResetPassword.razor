@page "/reset-password"
@attribute [AllowAnonymous]

<PageTitle>Choose a new password</PageTitle>

<section class="ui-page">
    <PageHero Eyebrow="Identity"
              Title="Choose a new password"
              Description="Set a new password for your account using the reset link sent to your email address." />

    <div class="ui-surface-form">
        <div class="ui-flow">
            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <AlertBanner>@Error</AlertBanner>
            }

            @if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Code))
            {
                <AlertBanner Tone="warning" Role="status">
                    The reset link is incomplete. Request a new password reset email.
                </AlertBanner>
                <a class="ui-button-primary" href="/forgot-password">
                    Request new link
                </a>
            }
            else
            {
                <form method="post" action="/account/reset-password" class="ui-flow">
                    <AntiforgeryToken />
                    <input type="hidden" name="email" value="@Email" />
                    <input type="hidden" name="code" value="@Code" />

                    <div class="ui-field">
                        <label class="ui-label" for="password">New password</label>
                        <input id="password" name="password" type="password" autocomplete="new-password" required
                               class="ui-input" />
                    </div>

                    <div class="ui-field">
                        <label class="ui-label" for="confirmPassword">Confirm new password</label>
                        <input id="confirmPassword" name="confirmPassword" type="password" autocomplete="new-password" required
                               class="ui-input" />
                    </div>

                    <button class="ui-button-primary" type="submit">
                        Reset password
                    </button>
                </form>
            }
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "code")]
    public string? Code { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }
}