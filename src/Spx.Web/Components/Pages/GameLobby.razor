@page "/games/{GameId:guid}"
@attribute [Authorize]
@implements IAsyncDisposable
@using Spx.Data
@using System.Security.Claims
@inject IGetLobbyHandler GetLobbyHandler
@inject ILeaveGameHandler LeaveGameHandler
@inject IGetMessagesHandler GetMessagesHandler
@inject IGetMessageUpdatesHandler GetMessageUpdatesHandler
@inject ISendPublicMessageHandler SendPublicMessageHandler
@inject ISendPrivateMessageHandler SendPrivateMessageHandler
@inject IEditMessageHandler EditMessageHandler
@inject IDeleteMessageHandler DeleteMessageHandler
@inject IGameLobbySubscriptionService GameLobbySubscriptions
@inject IGameMessageSubscriptionService GameMessageSubscriptions
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Game Lobby</PageTitle>

@if (isLoading)
{
    <section class="ui-surface-empty mx-auto max-w-4xl text-slate-300">
        Loading lobby...
    </section>
}
else if (lobby is null)
{
    <section class="ui-surface-empty mx-auto flex max-w-3xl flex-col gap-6">
        <PageHero Eyebrow="Lobby"
                  Title="Game unavailable"
                  Description="You can only open lobby pages for games where you are an active player or where you previously played."
                  Compact />
        <div class="ui-actions">
            <a class="ui-button-primary" href="/games">
                Back to my games
            </a>
            <a class="ui-button-secondary" href="/games/join">
                Join another game
            </a>
        </div>
    </section>
}
else
{
    <section class="ui-page max-w-6xl">
        <header class="ui-surface-form">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
                <div class="space-y-3">
                    <p class="ui-page-eyebrow">Lobby</p>
                    <h1 class="ui-page-title">@lobby.Name</h1>
                    <p class="ui-page-copy">
                        Invite code <span class="font-semibold tracking-[0.25em] text-sky-300">@lobby.InviteCode</span>
                    </p>
                </div>

                <div class="flex flex-wrap items-center gap-3">
                    <span class="ui-status-badge">
                        @lobby.Status
                    </span>
                    <span class="ui-status-badge border-emerald-400/30 bg-emerald-500/10 text-emerald-200">
                        @lobby.Players.Count / @lobby.MaxPlayers players
                    </span>
                </div>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <AlertBanner>@errorMessage</AlertBanner>
        }

        @if (!lobby.IsCurrentUserActive)
        {
            <AlertBanner Tone="warning" Role="status">
                You are viewing this game as a former player. Timeline history is limited to the point when you left.
            </AlertBanner>
        }

        <section class="ui-surface-form">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                <div class="space-y-2">
                    <p class="ui-section-eyebrow">Timeline</p>
                    <h2 class="ui-section-title">Messages and game events</h2>
                </div>

                @if (timelineItems.Count > 0)
                {
                    <p class="text-sm text-slate-400">
                        Newest cursor <span class="font-medium text-slate-200">@FormatTimelineCursor(newestMessageId)</span>
                    </p>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(messageError))
            {
                <div class="mt-6">
                    <AlertBanner>@messageError</AlertBanner>
                </div>
            }

            <div class="mt-6 grid gap-6 lg:grid-cols-[1.3fr_0.9fr]">
                <div class="ui-panel-card-tight">
                    <div class="mb-3 flex items-center justify-between px-2 text-xs uppercase tracking-[0.2em] text-slate-400">
                        <span>History</span>
                        @if (isLoadingOlderMessages)
                        {
                            <span>Loading older...</span>
                        }
                    </div>

                    <div class="ui-scroll-panel" @ref="timelineContainer">
                        <div @ref="timelineTopSentinel" class="h-px w-full"></div>

                        @if (isTimelineLoading)
                        {
                            <div class="ui-panel-card text-sm text-slate-400">
                                Loading timeline...
                            </div>
                        }
                        else if (timelineItems.Count == 0)
                        {
                            <div class="ui-empty-state">
                                No messages or events have appeared in this game yet.
                            </div>
                        }
                        else
                        {
                            <div class="space-y-3">
                                @if (hasOlderMessages)
                                {
                                    <div class="px-2 py-1 text-center text-xs uppercase tracking-[0.2em] text-slate-500">
                                        Scroll up to load older history
                                    </div>
                                }

                                @foreach (var item in timelineItems)
                                {
                                    <article class="rounded-2xl border @(GetTimelineCardBorderClass(item)) bg-slate-950/60 px-4 py-4">
                                        <div class="flex items-start justify-between gap-4">
                                            <div class="space-y-2">
                                                <div class="flex flex-wrap items-center gap-2">
                                                    <p class="text-sm font-semibold text-white">@GetTimelineTitle(item)</p>
                                                    @if (IsPrivate(item))
                                                    {
                                                        <span class="ui-inline-badge border border-amber-400/30 bg-amber-500/10 text-amber-100">
                                                            @GetPrivateBadgeText(item)
                                                        </span>
                                                    }
                                                    @if (IsPending(item))
                                                    {
                                                        <span class="ui-inline-badge border border-sky-400/30 bg-sky-400/10 text-sky-200">
                                                            Pending
                                                        </span>
                                                    }
                                                    @if (IsFailed(item))
                                                    {
                                                        <span class="ui-inline-badge border border-red-400/30 bg-red-500/10 text-red-100">
                                                            Failed
                                                        </span>
                                                    }
                                                </div>

                                                <p class="text-sm leading-6 text-slate-200 whitespace-pre-wrap">@GetTimelineBody(item)</p>

                                                <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.2em] text-slate-500">
                                                    <span>@FormatDateTime(GetTimelineCreatedAt(item))</span>
                                                    @if (IsEdited(item))
                                                    {
                                                        <span>Edited</span>
                                                    }
                                                    @if (IsDeleted(item))
                                                    {
                                                        <span>Deleted</span>
                                                    }
                                                </div>
                                            </div>

                                            @if (item.Message is not null && editingMessageId != item.Message.Id && (item.Message.CanEdit || item.Message.CanDelete))
                                            {
                                                <div class="flex flex-wrap gap-2">
                                                    @if (item.Message.CanEdit)
                                                    {
                                                        <button class="ui-button-compact border border-white/10 text-slate-300 hover:border-sky-300/60 hover:text-white"
                                                                @onclick="() => BeginEdit(item.Message)">
                                                            Edit
                                                        </button>
                                                    }
                                                    @if (item.Message.CanDelete)
                                                    {
                                                        <button class="ui-button-compact border border-rose-400/40 text-rose-100 hover:border-rose-300 hover:text-white"
                                                                @onclick="() => DeleteMessageAsync(item.Message.Id)">
                                                            Delete
                                                        </button>
                                                    }
                                                </div>
                                            }
                                            else if (IsFailed(item))
                                            {
                                                <div class="flex flex-wrap gap-2">
                                                    <button class="ui-button-compact border border-sky-400/30 text-sky-200 hover:border-sky-300/60 hover:text-white"
                                                            @onclick="() => RetryPendingMessageAsync(item.Key)">
                                                        Retry
                                                    </button>
                                                    <button class="ui-button-compact border border-white/10 text-slate-300 hover:border-sky-300/60 hover:text-white"
                                                            @onclick="() => DismissPendingMessage(item.Key)">
                                                        Dismiss
                                                    </button>
                                                </div>
                                            }
                                        </div>

                                        @if (item.Message is not null && editingMessageId == item.Message.Id)
                                        {
                                            <div class="mt-4 space-y-3 rounded-2xl border border-sky-400/30 bg-sky-400/10 p-4">
                                                <textarea class="ui-textarea min-h-24"
                                                          @bind="editMessageText"
                                                          @bind:event="oninput"></textarea>
                                                <div class="flex flex-wrap justify-end gap-3">
                                                    <button class="ui-button-compact border border-white/10 px-4 text-slate-300 hover:border-sky-300/60 hover:text-white"
                                                            @onclick="CancelEdit">
                                                        Cancel
                                                    </button>
                                                    <button class="ui-button-compact bg-sky-400 px-4 text-slate-950 hover:bg-sky-300 disabled:cursor-not-allowed disabled:bg-slate-700 disabled:text-slate-400"
                                                            @onclick="SaveEditAsync"
                                                            disabled="@isSavingEdit">
                                                        @(isSavingEdit ? "Saving..." : "Save")
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </article>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="ui-panel-card space-y-4">
                    <div class="space-y-2">
                        <p class="ui-section-eyebrow">Composer</p>
                        <h3 class="text-xl font-semibold tracking-tight text-white">Send a message</h3>
                        <p class="text-sm leading-6 text-slate-300">
                            @if (lobby.IsCurrentUserActive)
                            {
                                <span>Enter sends. Shift+Enter adds a new line. Choose a player to send privately.</span>
                            }
                            else
                            {
                                <span>Only active players can send new messages.</span>
                            }
                        </p>
                    </div>

                    @if (lobby.IsCurrentUserActive)
                    {
                        <div class="space-y-4">
                            <div class="space-y-2">
                                <label class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400" for="message-recipient">Recipient</label>
                                <select id="message-recipient"
                                        class="ui-select"
                                        @bind="selectedRecipientPlayerIdString">
                                    <option value="">All active players</option>
                                    @foreach (var player in lobby.Players.Where(player => !player.IsCurrentUser))
                                    {
                                        <option value="@player.PlayerId">@player.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="space-y-2">
                                <label class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400" for="message-composer">Message</label>
                                <textarea id="message-composer"
                                          class="ui-textarea min-h-32"
                                          placeholder="Write something for the game timeline..."
                                          @bind="composerText"
                                          @bind:event="oninput"
                                          @ref="composerTextArea"></textarea>
                            </div>

                            <div class="flex flex-wrap items-center justify-between gap-3">
                                <p class="text-xs uppercase tracking-[0.2em] text-slate-500">
                                    @composerText.Length / 1024 characters
                                </p>
                                <button class="ui-button-primary"
                                        @onclick="SendMessageAsync"
                                        disabled="@isSendingMessage">
                                    @(isSendingMessage ? "Sending..." : "Send message")
                                </button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="ui-empty-state">
                            This composer is disabled because you are no longer an active player in this game.
                        </div>
                    }
                </div>
            </div>
        </section>

        <div class="grid gap-6 xl:grid-cols-[1.4fr_1fr]">
            <section class="ui-surface-form">
                <div class="space-y-2">
                    <p class="ui-section-eyebrow">Roster</p>
                    <h2 class="ui-section-title">Active players</h2>
                </div>

                <div class="mt-6 space-y-4">
                    @foreach (var player in lobby.Players)
                    {
                        <article class="ui-panel-row">
                            <div>
                                <p class="text-base font-semibold text-white">@player.Name</p>
                                <p class="text-sm text-slate-400">Joined @FormatDateTime(player.JoinedAtUtc)</p>
                            </div>

                            @if (player.IsCurrentUser)
                            {
                                <span class="ui-status-badge border-sky-400/30 bg-sky-400/10 text-sky-200">
                                    You
                                </span>
                            }
                        </article>
                    }

                    @if (lobby.Players.Count < lobby.MaxPlayers)
                    {
                        <article class="ui-empty-state">
                            Waiting for another player to join with the invite code.
                        </article>
                    }
                </div>
            </section>

            <aside class="ui-surface-form space-y-6">
                <div class="ui-section-header">
                    <p class="ui-section-eyebrow">You</p>
                    <h2 class="ui-section-title">@lobby.CurrentPlayerName</h2>
                    <p class="text-sm leading-6 text-slate-300">@GetPlayerPanelMessage()</p>
                </div>

                <div class="space-y-3 text-sm leading-6 text-slate-300">
                    <p>Created @FormatDateTime(lobby.CreatedAtUtc)</p>
                    @if (lobby.EndedAtUtc is not null)
                    {
                        <p>Ended @FormatDateTime(lobby.EndedAtUtc.Value)</p>
                    }
                </div>

                <div class="ui-actions">
                    @if (lobby.IsCurrentUserActive)
                    {
                        <button class="ui-button-danger"
                                @onclick="LeaveGameAsync"
                                disabled="@isLeaving">
                            @(isLeaving ? "Leaving..." : "Leave game")
                        </button>
                    }
                    <a class="ui-button-secondary" href="/games">
                        Back to my games
                    </a>
                </div>
            </aside>
        </div>
    </section>
}

@code {
    [Parameter]
    public Guid GameId { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private readonly List<LobbyTimelineItem> timelineItems = [];

    private GameLobbyView? lobby;
    private string currentUserId = string.Empty;
    private string? errorMessage;
    private string? messageError;
    private bool isLoading = true;
    private bool isLeaving;
    private bool isTimelineLoading = true;
    private bool isLoadingOlderMessages;
    private bool isSendingMessage;
    private bool isSavingEdit;
    private Guid? subscribedGameId;
    private IAsyncDisposable? lobbySubscription;
    private IAsyncDisposable? messageSubscription;
    private string composerText = string.Empty;
    private string? selectedRecipientPlayerIdString;
    private Guid? oldestMessageId;
    private Guid? newestMessageId;
    private bool hasOlderMessages;
    private Guid? editingMessageId;
    private string editMessageText = string.Empty;
    private ElementReference timelineContainer;
    private ElementReference timelineTopSentinel;
    private ElementReference composerTextArea;
    private IJSObjectReference? gameLobbyModule;
    private DotNetObjectReference<GameLobby>? dotNetReference;
    private double restoreScrollHeight;
    private double restoreScrollTop;
    private bool shouldRestoreScrollAfterOlderLoad;
    private bool shouldScrollTimelineToBottom;

    protected override async Task OnParametersSetAsync()
    {
        currentUserId = await GetUserIdAsync();
        await LoadLobbyAsync();

        if (lobby is null)
        {
            await DisposeSubscriptionsAsync();
            ResetTimelineState();
            return;
        }

        var isNewGame = subscribedGameId != lobby.GameId;
        if (isNewGame)
        {
            await DisposeSubscriptionsAsync();
            ResetTimelineState();
            await LoadInitialMessagesAsync();
            lobbySubscription = await GameLobbySubscriptions.SubscribeAsync(lobby.GameId, HandleLobbyChangedAsync);
            if (lobby.IsCurrentUserActive)
            {
                messageSubscription = await GameMessageSubscriptions.SubscribeToMessagesAsync(lobby.GameId, HandleMessagesChangedAsync);
            }
            subscribedGameId = lobby.GameId;
            shouldScrollTimelineToBottom = true;
            return;
        }

        if (timelineItems.Count == 0)
        {
            await LoadInitialMessagesAsync();
            shouldScrollTimelineToBottom = true;
        }

        if (lobby.IsCurrentUserActive && messageSubscription is null)
        {
            messageSubscription = await GameMessageSubscriptions.SubscribeToMessagesAsync(lobby.GameId, HandleMessagesChangedAsync);
        }
        else if (!lobby.IsCurrentUserActive && messageSubscription is not null)
        {
            await messageSubscription.DisposeAsync();
            messageSubscription = null;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (gameLobbyModule is null)
        {
            gameLobbyModule = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/GameLobby.razor.js");
            dotNetReference = DotNetObjectReference.Create(this);
        }

        if (lobby is not null && dotNetReference is not null)
        {
            await gameLobbyModule.InvokeVoidAsync("setTimelineObserver", timelineContainer, timelineTopSentinel, dotNetReference);

            if (lobby.IsCurrentUserActive)
            {
                await gameLobbyModule.InvokeVoidAsync("setComposerSubmit", composerTextArea, dotNetReference);
            }
        }

        if (shouldRestoreScrollAfterOlderLoad)
        {
            shouldRestoreScrollAfterOlderLoad = false;
            await gameLobbyModule.InvokeVoidAsync("restoreScrollAfterPrepend", timelineContainer, restoreScrollHeight, restoreScrollTop);
        }
        else if (shouldScrollTimelineToBottom)
        {
            shouldScrollTimelineToBottom = false;
            await gameLobbyModule.InvokeVoidAsync("scrollToBottom", timelineContainer);
        }
    }

    private async Task LoadLobbyAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            lobby = await GetLobbyHandler.HandleAsync(GameId, currentUserId);
        }
        catch (Exception exception)
        {
            lobby = null;
            errorMessage = exception.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private Task HandleLobbyChangedAsync()
        => InvokeAsync(async () =>
        {
            await LoadLobbyAsync();

            if (lobby is not null && !lobby.IsCurrentUserActive && messageSubscription is not null)
            {
                await messageSubscription.DisposeAsync();
                messageSubscription = null;
            }

            StateHasChanged();
        });

    private Task HandleMessagesChangedAsync()
        => InvokeAsync(async () =>
        {
            await LoadMessageUpdatesAsync();
            StateHasChanged();
        });

    private async Task LeaveGameAsync()
    {
        if (isLeaving)
        {
            return;
        }

        isLeaving = true;
        errorMessage = null;

        try
        {
            var result = await LeaveGameHandler.HandleAsync(GameId, currentUserId);

            if (!result.Succeeded)
            {
                errorMessage = result.ErrorMessage ?? "The game could not be left.";
                return;
            }

            Navigation.NavigateTo("/games");
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
        finally
        {
            isLeaving = false;
        }
    }

    private async Task LoadInitialMessagesAsync()
    {
        if (lobby is null)
        {
            return;
        }

        isTimelineLoading = true;
        messageError = null;

        try
        {
            var page = await GetMessagesHandler.HandleAsync(lobby.GameId, currentUserId);
            timelineItems.Clear();

            if (page is not null)
            {
                var orderedItems = page.Items.OrderBy(entry => entry.Id).ToList();
                timelineItems.AddRange(orderedItems.Select(entry => new LobbyTimelineItem
                {
                    Key = entry.Id,
                    Message = entry
                }));

                hasOlderMessages = page.HasMore;
                oldestMessageId = orderedItems.FirstOrDefault()?.Id;
                newestMessageId = orderedItems.LastOrDefault()?.Id;
            }
            else
            {
                hasOlderMessages = false;
                oldestMessageId = null;
                newestMessageId = null;
            }
        }
        catch (Exception exception)
        {
            messageError = exception.Message;
        }
        finally
        {
            isTimelineLoading = false;
        }
    }

    private async Task LoadMessageUpdatesAsync()
    {
        if (lobby is null)
        {
            return;
        }

        if (newestMessageId is null)
        {
            await LoadInitialMessagesAsync();
            shouldScrollTimelineToBottom = true;
            return;
        }

        try
        {
            var shouldStickToBottom = gameLobbyModule is null || await gameLobbyModule.InvokeAsync<bool>("isNearBottom", timelineContainer);
            var updates = await GetMessageUpdatesHandler.HandleAsync(lobby.GameId, currentUserId, newestMessageId);
            if (updates is null || updates.Count == 0)
            {
                return;
            }

            UpsertPersistedMessages(updates);
            if (shouldStickToBottom)
            {
                shouldScrollTimelineToBottom = true;
            }
        }
        catch (Exception exception)
        {
            messageError = exception.Message;
        }
    }

    private async Task LoadOlderMessagesAsync()
    {
        if (lobby is null || !hasOlderMessages || isLoadingOlderMessages || oldestMessageId is null)
        {
            return;
        }

        isLoadingOlderMessages = true;

        try
        {
            var metrics = gameLobbyModule is null
                ? new ScrollMetrics()
                : await gameLobbyModule.InvokeAsync<ScrollMetrics>("getScrollMetrics", timelineContainer);
            var page = await GetMessagesHandler.HandleAsync(lobby.GameId, currentUserId, oldestMessageId);
            if (page is null)
            {
                return;
            }

            var existingIds = timelineItems.Where(entry => entry.Message is not null).Select(entry => entry.Message!.Id).ToHashSet();
            var olderItems = page.Items
                .Where(entry => !existingIds.Contains(entry.Id))
                .OrderBy(entry => entry.Id)
                .Select(entry => new LobbyTimelineItem
                {
                    Key = entry.Id,
                    Message = entry
                })
                .ToList();

            if (olderItems.Count > 0)
            {
                timelineItems.InsertRange(0, olderItems);
                oldestMessageId = timelineItems.FirstOrDefault(entry => entry.Message is not null)?.Message?.Id;
                restoreScrollHeight = metrics.ScrollHeight;
                restoreScrollTop = metrics.ScrollTop;
                shouldRestoreScrollAfterOlderLoad = true;
            }

            hasOlderMessages = page.HasMore;
        }
        catch (Exception exception)
        {
            messageError = exception.Message;
        }
        finally
        {
            isLoadingOlderMessages = false;
        }
    }

    private async Task SendMessageAsync()
    {
        if (lobby is null || !lobby.IsCurrentUserActive || isSendingMessage)
        {
            return;
        }

        messageError = null;
        var body = composerText.Trim();
        if (string.IsNullOrWhiteSpace(body))
        {
            messageError = "Messages cannot be empty.";
            return;
        }

        var recipient = GetSelectedRecipient();
        var pendingItem = CreatePendingMessage(body, recipient);
        timelineItems.Add(pendingItem);
        composerText = string.Empty;
        selectedRecipientPlayerIdString = null;
        shouldScrollTimelineToBottom = true;
        isSendingMessage = true;

        try
        {
            GameMessageCommandResult result;
            if (recipient is null)
            {
                result = await SendPublicMessageHandler.HandleAsync(lobby.GameId, currentUserId, new SendGameMessageRequest(body));
            }
            else
            {
                result = await SendPrivateMessageHandler.HandleAsync(lobby.GameId, currentUserId, recipient.PlayerId, new SendGameMessageRequest(body));
            }

            if (!result.Succeeded || result.Message is null)
            {
                pendingItem.Pending!.Failed = true;
                messageError = result.ErrorMessage ?? "The message could not be sent.";
                return;
            }

            ReplacePendingWithPersistedMessage(pendingItem.Key, result.Message);
        }
        catch (Exception exception)
        {
            pendingItem.Pending!.Failed = true;
            messageError = exception.Message;
        }
        finally
        {
            isSendingMessage = false;
        }
    }

    private async Task RetryPendingMessageAsync(Guid itemKey)
    {
        var item = timelineItems.SingleOrDefault(entry => entry.Key == itemKey && entry.Pending is not null);
        if (item?.Pending is null || isSendingMessage || lobby is null)
        {
            return;
        }

        item.Pending.Failed = false;
        isSendingMessage = true;
        messageError = null;

        try
        {
            GameMessageCommandResult result;
            if (item.Pending.RecipientPlayerId is null)
            {
                result = await SendPublicMessageHandler.HandleAsync(lobby.GameId, currentUserId, new SendGameMessageRequest(item.Pending.Body));
            }
            else
            {
                result = await SendPrivateMessageHandler.HandleAsync(lobby.GameId, currentUserId, item.Pending.RecipientPlayerId.Value, new SendGameMessageRequest(item.Pending.Body));
            }

            if (!result.Succeeded || result.Message is null)
            {
                item.Pending.Failed = true;
                messageError = result.ErrorMessage ?? "The message could not be sent.";
                return;
            }

            ReplacePendingWithPersistedMessage(itemKey, result.Message);
        }
        catch (Exception exception)
        {
            item.Pending.Failed = true;
            messageError = exception.Message;
        }
        finally
        {
            isSendingMessage = false;
        }
    }

    private void DismissPendingMessage(Guid itemKey)
    {
        timelineItems.RemoveAll(entry => entry.Key == itemKey && entry.Pending is not null);
    }

    private void BeginEdit(GameMessageView message)
    {
        editingMessageId = message.Id;
        editMessageText = message.Body;
    }

    private void CancelEdit()
    {
        editingMessageId = null;
        editMessageText = string.Empty;
        isSavingEdit = false;
    }

    private async Task SaveEditAsync()
    {
        if (lobby is null || editingMessageId is null || isSavingEdit)
        {
            return;
        }

        isSavingEdit = true;
        messageError = null;

        try
        {
            var result = await EditMessageHandler.HandleAsync(lobby.GameId, currentUserId, editingMessageId.Value, new UpdateGameMessageRequest(editMessageText));
            if (!result.Succeeded || result.Message is null)
            {
                messageError = result.ErrorMessage ?? "The message could not be updated.";
                return;
            }

            UpsertPersistedMessages([result.Message]);
            CancelEdit();
        }
        catch (Exception exception)
        {
            messageError = exception.Message;
        }
        finally
        {
            isSavingEdit = false;
        }
    }

    private async Task DeleteMessageAsync(Guid messageId)
    {
        if (lobby is null)
        {
            return;
        }

        messageError = null;

        try
        {
            var result = await DeleteMessageHandler.HandleAsync(lobby.GameId, currentUserId, messageId);
            if (!result.Succeeded || result.Message is null)
            {
                messageError = result.ErrorMessage ?? "The message could not be deleted.";
                return;
            }

            UpsertPersistedMessages([result.Message]);
            if (editingMessageId == messageId)
            {
                CancelEdit();
            }
        }
        catch (Exception exception)
        {
            messageError = exception.Message;
        }
    }

    [JSInvokable]
    public Task HandleComposerEnterAsync()
        => SendMessageAsync();

    [JSInvokable]
    public Task HandleTimelineNearTopAsync()
        => LoadOlderMessagesAsync();

    public async ValueTask DisposeAsync()
    {
        await DisposeSubscriptionsAsync();

        if (gameLobbyModule is not null)
        {
            try
            {
                await gameLobbyModule.InvokeVoidAsync("disposeTimelineObserver", timelineTopSentinel);
                await gameLobbyModule.InvokeVoidAsync("clearComposerSubmit", composerTextArea);
                await gameLobbyModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }

        dotNetReference?.Dispose();
    }

    private async Task<string> GetUserIdAsync()
    {
        var authenticationState = await AuthenticationStateTask;
        return authenticationState.User.FindFirstValue(ClaimTypes.NameIdentifier)
            ?? throw new InvalidOperationException("The current user does not have an identity id claim.");
    }

    private async Task DisposeSubscriptionsAsync()
    {
        if (lobbySubscription is not null)
        {
            await lobbySubscription.DisposeAsync();
            lobbySubscription = null;
        }

        if (messageSubscription is not null)
        {
            await messageSubscription.DisposeAsync();
            messageSubscription = null;
        }

        subscribedGameId = null;
    }

    private void ResetTimelineState()
    {
        timelineItems.Clear();
        oldestMessageId = null;
        newestMessageId = null;
        hasOlderMessages = false;
        isTimelineLoading = true;
        isLoadingOlderMessages = false;
        messageError = null;
        composerText = string.Empty;
        selectedRecipientPlayerIdString = null;
        editingMessageId = null;
        editMessageText = string.Empty;
    }

    private void UpsertPersistedMessages(IEnumerable<GameMessageView> messages)
    {
        foreach (var message in messages)
        {
            var existingItem = timelineItems.SingleOrDefault(entry => entry.Message?.Id == message.Id);
            if (existingItem is not null)
            {
                existingItem.Message = message;
                continue;
            }

            timelineItems.Add(new LobbyTimelineItem
            {
                Key = message.Id,
                Message = message
            });
        }

        timelineItems.Sort(static (left, right) => CompareTimelineItems(left, right));
        oldestMessageId = timelineItems.FirstOrDefault(entry => entry.Message is not null)?.Message?.Id;
        newestMessageId = timelineItems.LastOrDefault(entry => entry.Message is not null)?.Message?.Id;
    }

    private void ReplacePendingWithPersistedMessage(Guid itemKey, GameMessageView message)
    {
        timelineItems.RemoveAll(entry => entry.Key == itemKey);
        UpsertPersistedMessages([message]);
    }

    private PendingRecipient? GetSelectedRecipient()
    {
        if (!Guid.TryParse(selectedRecipientPlayerIdString, out var recipientPlayerId) || lobby is null)
        {
            return null;
        }

        var player = lobby.Players.SingleOrDefault(entry => entry.PlayerId == recipientPlayerId);
        return player is null ? null : new PendingRecipient(player.PlayerId, player.Name);
    }

    private LobbyTimelineItem CreatePendingMessage(string body, PendingRecipient? recipient)
        => new()
        {
            Key = Guid.NewGuid(),
            Pending = new PendingTimelineMessage(
                body,
                recipient?.PlayerId,
                recipient?.Name ?? string.Empty,
                DateTime.UtcNow,
                recipient is not null,
                false)
        };

    private static int CompareTimelineItems(LobbyTimelineItem left, LobbyTimelineItem right)
    {
        if (left.Message is null && right.Message is not null)
        {
            return 1;
        }

        if (left.Message is not null && right.Message is null)
        {
            return -1;
        }

        if (left.Message is null && right.Message is null)
        {
            return DateTime.Compare(left.Pending?.CreatedAtUtc ?? DateTime.MinValue, right.Pending?.CreatedAtUtc ?? DateTime.MinValue);
        }

        return left.Message!.Id.CompareTo(right.Message!.Id);
    }

    private string GetPlayerPanelMessage()
        => lobby?.IsCurrentUserActive == true
            ? "Leaving removes your active seat. If you are the last active player, the game ends."
            : "You previously played in this game. This page remains available for archived timeline review.";

    private static string GetTimelineCardBorderClass(LobbyTimelineItem item)
    {
        if (IsFailed(item))
        {
            return "border-red-400/30";
        }

        if (IsPrivate(item))
        {
            return "border-amber-400/30";
        }

        return item.Message?.Kind switch
        {
            Spx.Games.GameMessageKind.GameCreated or Spx.Games.GameMessageKind.PlayerJoined or Spx.Games.GameMessageKind.PlayerLeft or Spx.Games.GameMessageKind.GameEnded => "border-emerald-400/30",
            _ => "border-white/10"
        };
    }

    private string GetTimelineTitle(LobbyTimelineItem item)
    {
        if (item.Message is null)
        {
            return lobby?.CurrentPlayerName ?? "You";
        }

        return item.Message.Kind switch
        {
            Spx.Games.GameMessageKind.GameCreated => "Game created",
            Spx.Games.GameMessageKind.PlayerJoined => "Player joined",
            Spx.Games.GameMessageKind.PlayerLeft => "Player left",
            Spx.Games.GameMessageKind.GameEnded => "Game ended",
            _ => item.Message.SenderDisplayName
        };
    }

    private string GetTimelineBody(LobbyTimelineItem item)
    {
        if (item.Message is null)
        {
            return item.Pending?.Body ?? string.Empty;
        }

        if (item.Message.DeletedAtUtc is not null)
        {
            return "Message deleted.";
        }

        return item.Message.Kind switch
        {
            Spx.Games.GameMessageKind.GameCreated => $"{item.Message.SenderDisplayName} created the game.",
            Spx.Games.GameMessageKind.PlayerJoined => $"{item.Message.SenderDisplayName} joined the game.",
            Spx.Games.GameMessageKind.PlayerLeft => $"{item.Message.SenderDisplayName} left the game.",
            Spx.Games.GameMessageKind.GameEnded => "The game ended.",
            _ => item.Message.Body
        };
    }

    private string GetPrivateBadgeText(LobbyTimelineItem item)
    {
        if (item.Message is null)
        {
            return item.Pending?.RecipientDisplayName is { Length: > 0 } recipientName
                ? $"Private to {recipientName}"
                : "Private";
        }

        return item.Message.IsCurrentUserSender && !string.IsNullOrWhiteSpace(item.Message.RecipientDisplayName)
            ? $"Private to {item.Message.RecipientDisplayName}"
            : "Private";
    }

    private static bool IsPrivate(LobbyTimelineItem item)
        => item.Message?.IsPrivate == true || item.Pending?.IsPrivate == true;

    private static bool IsPending(LobbyTimelineItem item)
        => item.Pending is not null && !item.Pending.Failed;

    private static bool IsFailed(LobbyTimelineItem item)
        => item.Pending?.Failed == true;

    private static bool IsEdited(LobbyTimelineItem item)
        => item.Message?.EditedAtUtc is not null;

    private static bool IsDeleted(LobbyTimelineItem item)
        => item.Message?.DeletedAtUtc is not null;

    private static DateTime GetTimelineCreatedAt(LobbyTimelineItem item)
        => item.Message?.CreatedAtUtc ?? item.Pending?.CreatedAtUtc ?? DateTime.UtcNow;

    private static string FormatTimelineCursor(Guid? cursor)
        => cursor?.ToString()[^8..] ?? "none";

    private static string FormatDateTime(DateTime value)
        => value.ToLocalTime().ToString("g");

    private sealed class LobbyTimelineItem
    {
        public Guid Key { get; init; }

        public GameMessageView? Message { get; set; }

        public PendingTimelineMessage? Pending { get; set; }
    }

    private sealed record PendingTimelineMessage(
        string Body,
        Guid? RecipientPlayerId,
        string RecipientDisplayName,
        DateTime CreatedAtUtc,
        bool IsPrivate,
        bool Failed)
    {
        public bool Failed { get; set; } = Failed;
    }

    private sealed record PendingRecipient(Guid PlayerId, string Name);

    private sealed class ScrollMetrics
    {
        public double ScrollTop { get; set; }

        public double ScrollHeight { get; set; }

        public double ClientHeight { get; set; }
    }
