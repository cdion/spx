@page "/forgot-password"
@attribute [AllowAnonymous]

<PageTitle>Forgot password</PageTitle>

<FormPage Eyebrow="Identity" Title="Reset your password"
          Description="Enter your email address and, if the account exists, a reset link will be sent.">
    @if (!string.IsNullOrWhiteSpace(Status))
    {
        <AlertBanner Tone="AlertBanner.AlertTone.Success" Role="status">@Status</AlertBanner>
    }

    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <AlertBanner>@Error</AlertBanner>
    }

    <form method="post" action="/account/forgot-password" class="ui-flow">
        <AntiforgeryToken />

        <div class="ui-field">
            <label class="ui-label" for="email">Email</label>
            <input id="email" name="email" type="email" value="@Email" autocomplete="email" required class="ui-input" />
        </div>

        <button class="ui-button-primary" type="submit">
            Send reset link
        </button>
    </form>

    <p class="text-sm text-slate-300">
        Remembered it?
        <a class="ui-inline-link" href="/login">Sign in</a>
    </p>
</FormPage>

@code {
    [SupplyParameterFromQuery(Name = "status")]
    public string? Status { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }
}