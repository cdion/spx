@using System.Reflection

<div class="ui-app-nav">
    <div class="ui-app-brand">
        <a class="ui-app-brand-link" href="">Spx</a>
        <span class="ui-app-version">
            Version @AppVersion
        </span>
    </div>

    <nav class="ui-app-nav-links">
        <NavLink class="ui-nav-pill" href="" Match="NavLinkMatch.All">
            Lobby Home
        </NavLink>

        <AuthorizeView>
            <Authorized>
                <NavLink class="ui-nav-pill" href="/games">
                    My Games
                </NavLink>
                <NavLink class="ui-nav-pill" href="/games/create">
                    Create Game
                </NavLink>
                <NavLink class="ui-nav-pill" href="/games/join">
                    Join Game
                </NavLink>
                <form method="post" action="/account/logout" class="contents">
                    <AntiforgeryToken />
                    <button class="ui-nav-pill-danger" type="submit">
                        Sign out
                    </button>
                </form>
            </Authorized>
            <NotAuthorized>
                <NavLink class="ui-nav-pill" href="/login">
                    Sign in
                </NavLink>
                <NavLink class="ui-nav-pill" href="/register">
                    Register
                </NavLink>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private static readonly string AppVersion =
        typeof(NavMenu).Assembly
            .GetCustomAttribute<AssemblyInformationalVersionAttribute>()
            ?.InformationalVersion ?? typeof(NavMenu).Assembly.GetName().Version?.ToString() ?? "dev";
}

