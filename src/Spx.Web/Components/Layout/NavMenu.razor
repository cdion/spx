<div class="flex items-center justify-between border-b border-white/10 px-5 py-4 lg:block lg:space-y-6 lg:border-b-0 lg:px-0 lg:py-0">
    <a class="text-lg font-semibold tracking-[0.2em] text-white uppercase" href="">Spx</a>

    <nav class="flex items-center gap-3 lg:flex-col lg:items-stretch">
        <NavLink class="rounded-full border border-white/10 px-4 py-2 text-sm font-medium text-slate-300 transition hover:border-sky-400/40 hover:text-white [&.active]:border-sky-300/60 [&.active]:bg-sky-400/10 [&.active]:text-white lg:rounded-2xl" href="" Match="NavLinkMatch.All">
            Lobby Home
        </NavLink>

        <AuthorizeView>
            <Authorized>
                <NavLink class="rounded-full border border-white/10 px-4 py-2 text-sm font-medium text-slate-300 transition hover:border-sky-400/40 hover:text-white [&.active]:border-sky-300/60 [&.active]:bg-sky-400/10 [&.active]:text-white lg:rounded-2xl" href="/games">
                    My Games
                </NavLink>
                <NavLink class="rounded-full border border-white/10 px-4 py-2 text-sm font-medium text-slate-300 transition hover:border-sky-400/40 hover:text-white [&.active]:border-sky-300/60 [&.active]:bg-sky-400/10 [&.active]:text-white lg:rounded-2xl" href="/games/create">
                    Create Game
                </NavLink>
                <NavLink class="rounded-full border border-white/10 px-4 py-2 text-sm font-medium text-slate-300 transition hover:border-sky-400/40 hover:text-white [&.active]:border-sky-300/60 [&.active]:bg-sky-400/10 [&.active]:text-white lg:rounded-2xl" href="/games/join">
                    Join Game
                </NavLink>
                <form method="post" action="/account/logout" class="contents">
                    <AntiforgeryToken />
                    <button class="rounded-full border border-white/10 px-4 py-2 text-sm font-medium text-slate-300 transition hover:border-rose-400/40 hover:text-white lg:rounded-2xl" type="submit">
                        Sign out
                    </button>
                </form>
            </Authorized>
            <NotAuthorized>
                <NavLink class="rounded-full border border-white/10 px-4 py-2 text-sm font-medium text-slate-300 transition hover:border-sky-400/40 hover:text-white [&.active]:border-sky-300/60 [&.active]:bg-sky-400/10 [&.active]:text-white lg:rounded-2xl" href="/login">
                    Sign in
                </NavLink>
                <NavLink class="rounded-full border border-white/10 px-4 py-2 text-sm font-medium text-slate-300 transition hover:border-sky-400/40 hover:text-white [&.active]:border-sky-300/60 [&.active]:bg-sky-400/10 [&.active]:text-white lg:rounded-2xl" href="/register">
                    Register
                </NavLink>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

