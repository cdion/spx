@using Spx.Game.Domain

@{
    var colorClass = GameCardStyles.GetCardColorClass(Definition);
    var interactiveClass = IsInteractive && !IsDisabled ? "ui-game-card-interactive" : "";
    var selectedClass = IsSelected ? "ui-game-card-selected" : "";
    var disabledClass = IsDisabled ? "ui-game-card-disabled" : "";
}

@if (OnClick.HasDelegate)
{
    <button type="button" class="ui-game-card @colorClass @interactiveClass @selectedClass @disabledClass"
            disabled="@IsDisabled" @onclick="HandleClickAsync">
        <div class="ui-game-card-body">
            <p class="ui-game-card-name">@DisplayName</p>
            <p class="ui-game-card-category">@Category</p>
        </div>
    </button>
}
else
{
    <div class="ui-game-card @colorClass @selectedClass @disabledClass">
        <div class="ui-game-card-body">
            <p class="ui-game-card-name">@DisplayName</p>
            <p class="ui-game-card-category">@Category</p>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public GameCardDefinition Definition { get; set; }

    [Parameter, EditorRequired]
    public string DisplayName { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public GameCardCategory Category { get; set; }

    [Parameter]
    public bool IsSelected { get; set; }

    [Parameter]
    public bool IsInteractive { get; set; }

    [Parameter]
    public bool IsDisabled { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private Task HandleClickAsync() => OnClick.InvokeAsync();
}
