<header class="@(Compact ? "ui-page-header-compact" : "ui-page-header")">
    @if (!string.IsNullOrWhiteSpace(Eyebrow))
    {
        <p class="ui-page-eyebrow">@Eyebrow</p>
    }

    <h1 class="@(Compact ? "text-3xl font-semibold tracking-tight text-white" : "ui-page-title")">@Title</h1>

    @if (!string.IsNullOrWhiteSpace(Description))
    {
        <p class="@(Compact ? "text-base leading-7 text-slate-300" : "ui-page-copy")">@Description</p>
    }

    @ChildContent
</header>

@code {
    [Parameter]
    public string? Eyebrow { get; set; }

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public bool Compact { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}