<div class="ui-section-header">
    @if (!string.IsNullOrWhiteSpace(Eyebrow))
    {
        <p class="@EyebrowCssClass">@Eyebrow</p>
    }

    @if (PageTitle)
    {
        <h1 class="ui-page-title">@Title</h1>
    }
    else
    {
        <h2 class="ui-section-title">@Title</h2>
    }

    @if (!string.IsNullOrWhiteSpace(Description))
    {
        <p class="@DescriptionCssClass">@Description</p>
    }

    @ChildContent
</div>

@code {
    public enum EyebrowTone { Default, Accent, Muted }

    [Parameter]
    public string? Eyebrow { get; set; }

    [Parameter]
    public EyebrowTone Tone { get; set; } = EyebrowTone.Default;

    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public bool PageTitle { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string EyebrowCssClass => Tone switch
    {
        EyebrowTone.Accent => "ui-section-eyebrow text-emerald-300",
        EyebrowTone.Muted => "ui-section-eyebrow text-slate-400",
        _ => "ui-section-eyebrow"
    };

    private string DescriptionCssClass => PageTitle
        ? "ui-page-copy"
        : "max-w-xl ui-type-body";
}
