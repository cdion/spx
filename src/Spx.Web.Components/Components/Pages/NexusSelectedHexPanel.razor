@using System.Collections.Immutable

<section class="ui-surface-section h-full min-h-0 space-y-4 overflow-y-auto p-4 lg:p-5">
    <div class="flex items-center justify-between gap-2">
        <div class="flex items-center gap-2">
            <p class="@GetSystemLabelClass()">@GetSystemLabel()</p>
            @if (System.HomePlayerId.HasValue)
            {
                <span class="inline-flex h-6 w-6 items-center justify-center rounded-full border border-white/15 bg-white/5" aria-label="Home system">
                    <svg viewBox="-5 -5 10 10" class="h-3.5 w-3.5 fill-white/85" aria-hidden="true" focusable="false">
                        <polygon points="0,-4 1.1,-1.5 3.8,-1.2 1.8,0.8 2.4,3.6 0,2.2 -2.4,3.6 -1.8,0.8 -3.8,-1.2 -1.1,-1.5" />
                    </svg>
                </span>
            }
            else
            {
                <span class="ui-type-meta text-yellow-400/80">+@System.IncomeValue⚡</span>
            }
        </div>
    </div>

    <div class="space-y-3">
        <div>
            <p class="mb-2 text-base font-semibold @MyForcesClass">Your units</p>
            @if (_myUnits.Count == 0)
            {
                <p class="text-base text-slate-500">No forces present.</p>
            }
            else
            {
                <div class="grid gap-2 sm:grid-cols-3">
                    @foreach (var group in UnitGroups)
                    {
                        var hasAny = group.UnitTypes.Any(unitType => _myUnits.GetValueOrDefault(unitType) > 0);
                        <div class="rounded-lg border border-white/10 bg-slate-950/35 p-2">
                            <p class="mb-1 text-base font-semibold uppercase tracking-wide text-slate-400">@group.Label</p>
                            @if (!hasAny)
                            {
                                <p class="text-base text-slate-600">None</p>
                            }
                            else
                            {
                                <div class="space-y-1">
                                    @foreach (var unitType in group.UnitTypes.Where(unit => _myUnits.GetValueOrDefault(unit) > 0))
                                    {
                                        var available = AvailableUnits.GetValueOrDefault(unitType);
                                        var selected = _selection.GetValueOrDefault(unitType);
                                        var canInteract = IsEditable && available > 0;
                                        <button type="button"
                                                class="@GetFleetRowClass(unitType, canInteract)"
                                                disabled="@(!canInteract)"
                                                @onclick="e => OnFleetRowClickAsync(unitType, e)"
                                                @ondblclick="() => SelectAllFleetAsync(unitType)"
                                                @oncontextmenu:preventDefault="true"
                                                @oncontextmenu="() => RemoveOneFleetAsync(unitType)">
                                            <span class="text-base text-slate-100">@unitType</span>
                                            <span class="text-base text-slate-400">
                                                @if (selected > 0)
                                                {
                                                    <span class="@SelectionCountClass">@selected</span><span class="text-slate-600"> / </span>
                                                }
                                                @available
                                            </span>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        @if (_enemyUnits.Count > 0)
        {
            <div>
                <p class="mb-2 text-base font-semibold @EnemyForcesClass">Enemy forces</p>
                <div class="grid gap-2 sm:grid-cols-3">
                    @foreach (var group in UnitGroups)
                    {
                        var hasAny = group.UnitTypes.Any(unitType => _enemyUnits.GetValueOrDefault(unitType) > 0);
                        <div class="rounded-lg border border-white/10 bg-slate-950/35 p-2">
                            <p class="mb-1 text-base font-semibold uppercase tracking-wide text-slate-400">@group.Label</p>
                            @if (!hasAny)
                            {
                                <p class="text-base text-slate-600">None</p>
                            }
                            else
                            {
                                <div class="space-y-1">
                                    @foreach (var unitType in group.UnitTypes.Where(unit => _enemyUnits.GetValueOrDefault(unit) > 0))
                                    {
                                        var count = _enemyUnits.GetValueOrDefault(unitType);
                                        <div class="flex items-center justify-between rounded-lg px-2 py-1.5">
                                            <span class="text-base text-slate-300">@unitType</span>
                                            <span class="text-base text-slate-500">@count</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @if (IsEditable && HasSelection)
    {
        <div class="space-y-2 border-t border-white/10 pt-3">
            <div class="flex items-center justify-between gap-2 rounded-lg border border-white/10 bg-slate-950/40 px-3 py-1.5">
                <p class="text-base text-slate-300">Carry: @SlotsNeeded / @CarryCapacity slots</p>
                @if (!SelectionIsValid)
                {
                    <p class="text-base text-rose-400">Need ships</p>
                }
            </div>
            @if (SelectionIsValid)
            {
                <p class="text-base text-sky-400/80">Click a highlighted sector on the map.</p>
            }
        </div>
    }

    @if (IsEditable && System.HomePlayerId == CurrentPlayerId)
    {
        <div class="space-y-2 border-t border-white/10 pt-3">
            <p class="text-base font-semibold text-slate-300">Build units</p>
            <div class="grid gap-2 sm:grid-cols-3">
                @foreach (var group in UnitGroups)
                {
                    <div class="rounded-lg border border-white/10 bg-slate-950/35 p-2">
                        <p class="mb-1 text-base font-semibold uppercase tracking-wide text-slate-400">@group.Label</p>
                        <div class="space-y-1">
                            @foreach (var unitType in group.UnitTypes)
                            {
                                var cost = unitType.Cost();
                                var count = PendingBuildOrders.FirstOrDefault(o => o.UnitType == unitType)?.Count ?? 0;
                                var canAdd = ProjectedEnergy >= cost;
                                <button type="button"
                                        class="@GetBuildRowClass(unitType, count, canAdd)"
                                        @onclick="e => OnBuildRowClickAsync(unitType, e)"
                                        @ondblclick="() => OnBuildAddMax.InvokeAsync(unitType)"
                                        @oncontextmenu:preventDefault="true"
                                        @oncontextmenu="() => OnBuildRemoveOne.InvokeAsync(unitType)">
                                    <span class="text-base text-slate-100">@unitType <span class="ml-1 text-yellow-400">@cost⚡</span></span>
                                    <span class="text-base text-slate-400">@count</span>
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (IsEditable && CanShowGateOption)
    {
        <div class="space-y-2 border-t border-white/10 pt-3">
            <p class="text-base font-semibold text-slate-300">Nexus Gate</p>
            <button class="@GateButtonClass" @onclick="OnToggleNexusGate">
                <span>Begin Nexus Gate</span>
                <span class="text-yellow-400">12⚡</span>
            </button>
        </div>
    }
</section>

@code {
    private static readonly UnitGroup[] UnitGroups =
    [
        new("Squadrons", Enum.GetValues<NexusUnitType>().Where(unitType => unitType.IsSquadron()).ToArray()),
        new("Ships", Enum.GetValues<NexusUnitType>().Where(unitType => unitType.IsShip()).ToArray()),
        new("Ground forces", Enum.GetValues<NexusUnitType>().Where(unitType => unitType.IsGroundForce()).ToArray()),
    ];

    [Parameter, EditorRequired]
    public NexusSystemView System { get; set; } = default!;

    [Parameter, EditorRequired]
    public Guid CurrentPlayerId { get; set; }

    [Parameter]
    public string CurrentPlayerName { get; set; } = "You";

    [Parameter]
    public Guid? OpponentPlayerId { get; set; }

    [Parameter]
    public string OpponentPlayerName { get; set; } = "Opponent";

    [Parameter]
    public NexusFactionColor CurrentPlayerFaction { get; set; }

    [Parameter]
    public NexusGateProgress CurrentPlayerGateProgress { get; set; }

    [Parameter]
    public bool PendingBeginNexusGate { get; set; }

    [Parameter]
    public bool IsEditable { get; set; }

    [Parameter]
    public int ProjectedEnergy { get; set; }

    [Parameter]
    public ImmutableDictionary<NexusUnitType, int> AvailableUnits { get; set; } =
        ImmutableDictionary<NexusUnitType, int>.Empty;

    [Parameter]
    public IReadOnlyList<NexusBuildOrder> PendingBuildOrders { get; set; } = [];

    [Parameter]
    public EventCallback<ImmutableDictionary<NexusUnitType, int>> OnFleetSelectionChanged { get; set; }

    [Parameter]
    public EventCallback<NexusUnitType> OnBuildAddOne { get; set; }

    [Parameter]
    public EventCallback<NexusUnitType> OnBuildAddMax { get; set; }

    [Parameter]
    public EventCallback<NexusUnitType> OnBuildRemoveOne { get; set; }

    [Parameter]
    public EventCallback<NexusUnitType> OnBuildRemoveAll { get; set; }

    [Parameter]
    public EventCallback OnToggleNexusGate { get; set; }

    private readonly Dictionary<NexusUnitType, int> _selection = [];
    private HexCoord _previousCoord;
    private Dictionary<NexusUnitType, int> _myUnits = [];
    private Dictionary<NexusUnitType, int> _enemyUnits = [];

    private int CarryCapacity => _selection.Sum(kv => kv.Key.CarryCapacity() * kv.Value);

    private int SlotsNeeded => _selection.Where(kv => !kv.Key.IsShip()).Sum(kv => kv.Value);

    private bool HasSelection => _selection.Values.Any(v => v > 0);

    private bool SelectionIsValid => HasSelection && SlotsNeeded <= CarryCapacity;

    private bool CanShowGateOption =>
        CurrentPlayerGateProgress != NexusGateProgress.Completed
        && System.IsNexus
        && _myUnits.Any(kv => kv.Key.IsGroundForce() && kv.Value > 0);

    private string MyForcesClass =>
        CurrentPlayerFaction == NexusFactionColor.Red ? "text-red-400" : "text-sky-400";

    private string EnemyForcesClass =>
        CurrentPlayerFaction == NexusFactionColor.Red ? "text-sky-400" : "text-red-400";

    private string SelectionCountClass =>
        CurrentPlayerFaction == NexusFactionColor.Red ? "text-red-300" : "text-sky-300";

    private string GateButtonClass =>
        PendingBeginNexusGate
            ? "flex w-full items-center justify-between gap-2 rounded-lg border border-purple-500/50 bg-purple-600/20 px-3 py-2 text-sm text-purple-300 transition-colors"
            : "flex w-full items-center justify-between gap-2 rounded-lg border border-white/10 bg-slate-950/60 px-3 py-2 text-sm text-slate-200 transition-colors hover:border-purple-500/30";

    private NexusFactionColor OpponentFactionColor =>
        CurrentPlayerFaction == NexusFactionColor.Red ? NexusFactionColor.Blue : NexusFactionColor.Red;

    private string GetSystemLabel()
    {
        if (!System.HomePlayerId.HasValue)
            return NexusMap.GetSectorDisplayName(System.Coord);

        if (System.HomePlayerId == CurrentPlayerId)
            return $"{CurrentPlayerName}'s System";

        if (OpponentPlayerId.HasValue && System.HomePlayerId == OpponentPlayerId.Value)
            return $"{OpponentPlayerName}'s System";

        return "Player's System";
    }

    private string GetSystemLabelClass()
    {
        if (System.HomePlayerId == CurrentPlayerId)
            return CurrentPlayerFaction == NexusFactionColor.Red
                ? "ui-panel-label text-red-300"
                : "ui-panel-label text-sky-300";

        if (OpponentPlayerId.HasValue && System.HomePlayerId == OpponentPlayerId.Value)
            return OpponentFactionColor == NexusFactionColor.Red
                ? "ui-panel-label text-red-300"
                : "ui-panel-label text-sky-300";

        return "ui-panel-label";
    }

    protected override async Task OnParametersSetAsync()
    {
        _myUnits = System.Units.TryGetValue(CurrentPlayerId, out var myUnits)
            ? myUnits.ToDictionary()
            : [];

        _enemyUnits =
            OpponentPlayerId.HasValue
            && System.Units.TryGetValue(OpponentPlayerId.Value, out var enemyUnits)
                ? enemyUnits.ToDictionary()
                : [];

        if (_previousCoord != System.Coord)
        {
            _selection.Clear();
            _previousCoord = System.Coord;
            await PublishSelectionAsync();
            return;
        }

        var changed = false;
        foreach (var unitType in _selection.Keys.ToList())
        {
            var available = AvailableUnits.GetValueOrDefault(unitType);
            var next = Math.Clamp(_selection[unitType], 0, available);
            if (next <= 0)
            {
                _selection.Remove(unitType);
                changed = true;
            }
            else if (next != _selection[unitType])
            {
                _selection[unitType] = next;
                changed = true;
            }
        }

        if (changed)
            await PublishSelectionAsync();
    }

    private string GetFleetRowClass(NexusUnitType unitType, bool canInteract)
    {
        if (!canInteract)
            return "flex w-full items-center justify-between rounded-lg border border-transparent bg-transparent px-2.5 py-1.5 text-left opacity-35";

        var isSelected = _selection.GetValueOrDefault(unitType) > 0;
        if (!isSelected)
            return "flex w-full items-center justify-between rounded-lg border border-transparent px-2.5 py-1.5 text-left transition-colors hover:border-white/10 hover:bg-white/5";

        return CurrentPlayerFaction == NexusFactionColor.Red
            ? "flex w-full items-center justify-between rounded-lg border border-red-400/30 bg-red-950/30 px-2.5 py-1.5 text-left transition-colors hover:bg-red-950/50"
            : "flex w-full items-center justify-between rounded-lg border border-sky-400/30 bg-sky-950/30 px-2.5 py-1.5 text-left transition-colors hover:bg-sky-950/50";
    }

    private string GetBuildRowClass(NexusUnitType unitType, int count, bool canAdd)
    {
        if (count > 0)
        {
            return CurrentPlayerFaction == NexusFactionColor.Red
                ? "flex w-full items-center justify-between rounded-lg border border-red-400/30 bg-red-950/30 px-2 py-1 text-left transition-colors hover:bg-red-950/50"
                : "flex w-full items-center justify-between rounded-lg border border-sky-400/30 bg-sky-950/30 px-2 py-1 text-left transition-colors hover:bg-sky-950/50";
        }

        if (!canAdd)
            return "flex w-full items-center justify-between rounded-lg border border-transparent bg-transparent px-2.5 py-1.5 text-left opacity-35";

        return "flex w-full items-center justify-between rounded-lg border border-transparent px-2.5 py-1.5 text-left transition-colors hover:border-white/10 hover:bg-white/5";
    }

    private Task OnFleetRowClickAsync(NexusUnitType unitType, MouseEventArgs e)
    {
        if (e.ShiftKey)
        {
            _selection.Remove(unitType);
            return PublishSelectionAsync();
        }

        var available = AvailableUnits.GetValueOrDefault(unitType);
        if (available <= 0)
            return Task.CompletedTask;

        var current = _selection.GetValueOrDefault(unitType);
        _selection[unitType] = Math.Min(current + 1, available);
        return PublishSelectionAsync();
    }

    private Task RemoveOneFleetAsync(NexusUnitType unitType)
    {
        var current = _selection.GetValueOrDefault(unitType);
        if (current <= 1)
            _selection.Remove(unitType);
        else
            _selection[unitType] = current - 1;

        return PublishSelectionAsync();
    }

    private Task SelectAllFleetAsync(NexusUnitType unitType)
    {
        var available = AvailableUnits.GetValueOrDefault(unitType);
        if (available <= 0)
            return Task.CompletedTask;

        _selection[unitType] = available;
        return PublishSelectionAsync();
    }

    private Task OnBuildRowClickAsync(NexusUnitType unitType, MouseEventArgs e)
    {
        if (e.ShiftKey)
            return OnBuildRemoveAll.InvokeAsync(unitType);

        return OnBuildAddOne.InvokeAsync(unitType);
    }

    private Task PublishSelectionAsync()
    {
        if (!SelectionIsValid)
            return OnFleetSelectionChanged.InvokeAsync(ImmutableDictionary<NexusUnitType, int>.Empty);

        return OnFleetSelectionChanged.InvokeAsync(_selection.ToImmutableDictionary());
    }

    private sealed record UnitGroup(string Label, IReadOnlyList<NexusUnitType> UnitTypes);
}
