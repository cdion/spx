@using System.Collections.Immutable

<div class="space-y-3">
    <div class="flex items-center justify-between gap-2">
        <p class="text-xs font-semibold text-slate-200">Move from @Source.Coord</p>
        <button class="text-xs text-slate-500 transition-colors hover:text-slate-300" @onclick="OnCancelled">
            Cancel
        </button>
    </div>

    @foreach (var unitType in AllUnitTypes)
    {
        var available = AvailableUnits.GetValueOrDefault(unitType);
        if (available == 0) continue;
        var selected = _counts.GetValueOrDefault(unitType);
        <div class="flex items-center justify-between gap-2">
            <span class="flex-1 text-xs text-slate-200">
                @unitType <span class="text-slate-500">(@available)</span>
            </span>
            <div class="flex items-center gap-1">
                <button
                class="flex h-5 w-5 items-center justify-center rounded text-xs text-slate-400 transition-colors enabled:hover:text-white disabled:opacity-30"
                disabled="@(selected <= 0)" @onclick="() => AdjustCount(unitType, -1)">−</button>
                <span class="w-4 text-center text-xs font-semibold text-white">@selected</span>
                <button
                class="flex h-5 w-5 items-center justify-center rounded text-xs text-slate-400 transition-colors enabled:hover:text-white disabled:opacity-30"
                disabled="@(selected >= available)" @onclick="() => AdjustCount(unitType, +1)">+</button>
            </div>
        </div>
    }

    @if (SlotsNeeded > 0 || CarryCapacity > 0)
    {
        <div class="flex items-center justify-between gap-2 rounded-lg border border-white/10 bg-slate-950/40 px-3 py-1.5">
            <p class="text-xs text-slate-400">Carry: @SlotsNeeded / @CarryCapacity slots</p>
            @if (SlotsNeeded > CarryCapacity)
            {
                <p class="text-xs text-rose-400">Exceeded</p>
            }
        </div>
    }

    <button class="ui-button-primary w-full text-sm" disabled="@(!CanConfirm)" @onclick="ConfirmAsync">
        Pick destination →
    </button>
</div>

@code {
    private static readonly NexusUnitType[] AllUnitTypes = Enum.GetValues<NexusUnitType>();

    [Parameter, EditorRequired]
    public NexusSystemView Source { get; set; } = default!;

    [Parameter, EditorRequired]
    public ImmutableDictionary<NexusUnitType, int> AvailableUnits { get; set; } =
        ImmutableDictionary<NexusUnitType, int>.Empty;

    [Parameter]
    public EventCallback<ImmutableDictionary<NexusUnitType, int>> OnConfirmed { get; set; }

    [Parameter]
    public EventCallback OnCancelled { get; set; }

    private readonly Dictionary<NexusUnitType, int> _counts = [];
    private HexCoord _prevSourceCoord;

    protected override void OnParametersSet()
    {
        if (Source.Coord != _prevSourceCoord)
        {
            _counts.Clear();
            _prevSourceCoord = Source.Coord;
        }
    }

    private int CarryCapacity => _counts.Sum(kv => kv.Key.CarryCapacity() * kv.Value);

    private int SlotsNeeded => _counts.Where(kv => !kv.Key.IsShip()).Sum(kv => kv.Value);

    private bool CanConfirm => _counts.Any(kv => kv.Value > 0) && SlotsNeeded <= CarryCapacity;

    private void AdjustCount(NexusUnitType type, int delta)
    {
        var available = AvailableUnits.GetValueOrDefault(type);
        var next = Math.Clamp(_counts.GetValueOrDefault(type) + delta, 0, available);
        if (next == 0)
            _counts.Remove(type);
        else
            _counts[type] = next;
    }

    private Task ConfirmAsync()
    {
        if (!CanConfirm)
            return Task.CompletedTask;

        return OnConfirmed.InvokeAsync(_counts.ToImmutableDictionary());
    }
}
