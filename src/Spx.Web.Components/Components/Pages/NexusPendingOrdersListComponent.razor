@if (!MoveOrders.Any() && !BuildOrders.Any() && !BeginNexusGate)
{
    <p class="text-base text-slate-500">No orders yet.</p>
}
else
{
    <ul class="space-y-2">
        @foreach (var order in MoveOrders)
        {
            <li class="flex items-center justify-between gap-2 rounded-xl border border-white/10 bg-slate-950/60 px-3 py-2">
                <span class="text-base text-slate-300">@GetMoveDescription(order)</span>
                @if (IsEditable)
                {
                    <button class="text-base text-slate-500 transition-colors hover:text-rose-400" title="Remove order"
                            @onclick="() => OnRemoveMoveOrder.InvokeAsync(order)">
                        ×
                    </button>
                }
            </li>
        }
        @foreach (var order in BuildOrders)
        {
            <li class="flex items-center justify-between gap-2 rounded-xl border border-white/10 bg-slate-950/60 px-3 py-2">
                <span class="text-base text-slate-300">Build @order.Count× @order.UnitType (@(order.UnitType.Cost() *
                                                    order.Count)⚡)</span>
                    @if (IsEditable)
                    {
                        <button class="text-base text-slate-500 transition-colors hover:text-rose-400" title="Remove order"
                                @onclick="() => OnRemoveBuildOrder.InvokeAsync(order)">
                            ×
                        </button>
                    }
                </li>
            }
            @if (BeginNexusGate)
            {
                <li class="flex items-center justify-between gap-2 rounded-xl border border-white/10 bg-slate-950/60 px-3 py-2">
                    <span class="text-base text-slate-300">Begin Nexus Gate (12⚡)</span>
                    @if (IsEditable)
                    {
                        <button class="text-base text-slate-500 transition-colors hover:text-rose-400" title="Remove order"
                                @onclick="OnRemoveGateOrder">
                            ×
                        </button>
                    }
                </li>
            }
        </ul>
    }

@code {
    [Parameter]
    public string CurrentPlayerName { get; set; } = "Player";

    [Parameter]
    public HexCoord? CurrentPlayerHomeCoord { get; set; }

    [Parameter, EditorRequired]
    public IReadOnlyList<NexusMoveOrder> MoveOrders { get; set; } = [];

    [Parameter, EditorRequired]
    public IReadOnlyList<NexusBuildOrder> BuildOrders { get; set; } = [];

    [Parameter]
    public bool BeginNexusGate { get; set; }

    [Parameter]
    public bool IsEditable { get; set; }

    [Parameter]
    public EventCallback<NexusMoveOrder> OnRemoveMoveOrder { get; set; }

    [Parameter]
    public EventCallback<NexusBuildOrder> OnRemoveBuildOrder { get; set; }

    [Parameter]
    public EventCallback OnRemoveGateOrder { get; set; }

    private string GetMoveDescription(NexusMoveOrder order)
    {
        var unitSummary = string.Join(", ", order.Units.Select(kv => $"{kv.Value}× {kv.Key}"));
        return $"{GetSystemDisplayName(order.From)} → {GetSystemDisplayName(order.To)}: {unitSummary}";
    }

    private string GetSystemDisplayName(HexCoord coord)
    {
        if (CurrentPlayerHomeCoord.HasValue && coord == CurrentPlayerHomeCoord.Value)
            return $"{CurrentPlayerName}'s System";

        return NexusMap.GetSectorDisplayName(coord);
    }
}
