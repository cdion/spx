@using System.Collections.Immutable
@implements IDisposable

<SectionHeader Eyebrow="Gameplay" Title="@GetHeadline()">
    <p class="text-sm leading-6 text-slate-300">@GetDescription()</p>
</SectionHeader>

@if (!string.IsNullOrWhiteSpace(GameplayError))
{
    <AlertBanner>@GameplayError</AlertBanner>
}

@* Top info bar *@
<div class="grid gap-3 lg:grid-cols-3">
    <article class="ui-panel-row items-start">
        <div>
            <p class="ui-panel-label">Round</p>
            <p class="mt-2 text-2xl font-semibold text-white">@Session.RoundNumber</p>
        </div>
        <StatusBadge>@Session.Phase</StatusBadge>
    </article>

    <article class="ui-panel-row items-start">
        <div class="space-y-1">
            <p class="ui-panel-label">Your faction</p>
            <p class="text-base font-semibold text-white">@CurrentPlayerName</p>
            <p class="text-sm text-slate-400">vs @OpponentPlayerName</p>
        </div>
        <StatusBadge>@Session.CurrentPlayer.Faction</StatusBadge>
    </article>

    <article class="ui-panel-row items-start">
        <div>
            <p class="ui-panel-label">Nexus gate</p>
            <p class="mt-2 text-base font-semibold text-white">@Session.CurrentPlayer.GateProgress</p>
        </div>
        @if (Session.CurrentPlayer.HasSubmittedOrders)
        {
            <StatusBadge Tone="StatusBadge.BadgeTone.Success">Orders in</StatusBadge>
        }
        else if (Session.Opponent.HasSubmittedOrders)
        {
            <StatusBadge Tone="StatusBadge.BadgeTone.Warning">Waiting</StatusBadge>
        }
    </article>
</div>

@if (Session.Completion is not null)
{
    <AlertBanner Tone="AlertBanner.AlertTone.Success" Role="status">
        @GetCompletionMessage()

    </AlertBanner>
}

@* Main 3-column layout *@
<div class="grid gap-4 lg:grid-cols-[0.3fr_1fr_0.38fr]">
    @* Left sidebar: energy + pending orders *@
    <aside class="space-y-4">
        <section class="ui-surface-section p-4 lg:p-5">
            <p class="ui-panel-label mb-3">Energy</p>
            <div class="space-y-3">
                <div class="ui-panel-card-inner">
                    <div class="flex items-center justify-between gap-2">
                        <p class="text-sm font-semibold text-white">@CurrentPlayerName</p>
                        <StatusBadge>@Session.CurrentPlayer.Faction</StatusBadge>
                    </div>
                    <p class="mt-1 text-2xl font-semibold text-yellow-400">@Session.CurrentPlayer.Energy⚡</p>
                    @if (ProjectedSpend > 0)
                    {
                        <p class="mt-1 text-xs text-slate-400">After orders: @ProjectedEnergy⚡</p>
                    }
                </div>
                <div class="ui-panel-card-inner">
                    <div class="flex items-center justify-between gap-2">
                        <p class="text-sm font-semibold text-white">@OpponentPlayerName</p>
                        <StatusBadge>@Session.Opponent.Faction</StatusBadge>
                    </div>
                    <p class="mt-1 text-sm text-slate-400">
                        @(Session.Opponent.HasSubmittedOrders ? "Orders submitted" : "Waiting...")
                    </p>
                </div>
            </div>
        </section>

        @if (ShowOrdersForm)
        {
            @if (_pickingMoveDest)
            {
                <section class="ui-surface-section space-y-3 p-4 lg:p-5">
                    <p class="ui-panel-label">Select destination</p>
                    <p class="text-xs text-slate-300">Click a highlighted system on the map.</p>
                    <button
                        class="w-full rounded-lg border border-white/10 py-1.5 text-xs text-slate-400 transition-colors hover:text-slate-200"
                        @onclick="CancelDestPick">
                        Cancel
                    </button>
                </section>
            }
            else if (_selectedSystem.HasValue
                && Session.Systems.FirstOrDefault(s => s.Coord == _selectedSystem.Value) is { } selSys)
            {
                <section class="ui-surface-section space-y-4 p-4 lg:p-5">
                    <div class="flex items-center justify-between gap-2">
                        <p class="ui-panel-label">@_selectedSystem.Value</p>
                        <button class="text-xs text-slate-500 transition-colors hover:text-slate-300"
                                @onclick="ClearSelection">✕</button>
                    </div>

                    @if (GetAvailableUnits(_selectedSystem.Value).Count > 0)
                    {
                        <div class="space-y-2">
                            <p class="text-xs font-semibold text-slate-400">Move units</p>
                            <NexusUnitSelectionPanel Source="selSys" AvailableUnits="@GetAvailableUnits(_selectedSystem.Value)"
                                                     OnConfirmed="OnMoveUnitsConfirmed" OnCancelled="ClearSelection" />
                        </div>
                    }

                    @if (selSys.HomePlayerId == Session.CurrentPlayer.PlayerId)
                    {
                        <div class="space-y-2">
                            <p class="text-xs font-semibold text-slate-400">Build units</p>
                            @foreach (var unitType in Enum.GetValues<NexusUnitType>())
                            {
                                var cost = unitType.Cost();
                                var count = _pendingBuildOrders.FirstOrDefault(o => o.UnitType == unitType)?.Count ?? 0;
                                <div class="flex items-center justify-between gap-2">
                                    <div class="flex-1">
                                        <span class="text-xs text-slate-200">@unitType</span>
                                        <span class="ml-1 text-xs text-yellow-400">@cost⚡</span>
                                    </div>
                                    <div class="flex items-center gap-1">
                                        <button
                                        class="flex h-5 w-5 items-center justify-center rounded text-xs text-slate-400 transition-colors enabled:hover:text-white disabled:opacity-30"
                                        disabled="@(count <= 0)" @onclick="() => RemoveBuildOrder(unitType)">−</button>
                                        <span class="w-4 text-center text-xs font-semibold text-white">@count</span>
                                        <button
                                        class="flex h-5 w-5 items-center justify-center rounded text-xs text-slate-400 transition-colors enabled:hover:text-white disabled:opacity-30"
                                        disabled="@(ProjectedEnergy < cost)" @onclick="() => AddBuildOrder(unitType)">+</button>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    @if (CanShowGateOption(_selectedSystem.Value))
                    {
                        <div class="space-y-2">
                            <p class="text-xs font-semibold text-slate-400">Nexus Gate</p>
                            <button class="@GateButtonClass()" @onclick="() => _pendingBeginNexusGate = !_pendingBeginNexusGate">
                                <span>Begin Nexus Gate</span>
                                <span class="text-yellow-400">12⚡</span>
                            </button>
                        </div>
                    }
                </section>
            }

            <section class="ui-surface-section space-y-4 p-4 lg:p-5">
                <div class="flex items-center justify-between gap-2">
                    <p class="ui-panel-label">Your orders</p>
                    <StatusBadge Tone="StatusBadge.BadgeTone.Info">Your turn</StatusBadge>
                </div>

                <NexusPendingOrdersListComponent MoveOrders="@_pendingMoveOrders" BuildOrders="@_pendingBuildOrders"
                                                 BeginNexusGate="@_pendingBeginNexusGate" IsEditable OnRemoveMoveOrder="RemoveMoveOrder"
                                                 OnRemoveBuildOrder="RemoveBuildOrder" OnRemoveGateOrder="() => _pendingBeginNexusGate = false" />

                <button class="ui-button-primary w-full" @onclick="SubmitOrdersAsync" disabled="@IsSubmittingAction">
                    @(IsSubmittingAction ? "Submitting..." : "Submit orders")
                </button>
            </section>
        }
    </aside>

    @* Center: hex map *@
    <section class="ui-surface-section flex flex-col p-4 lg:p-5">
        <p class="ui-panel-label mb-4">Hex map</p>
        <div class="min-h-0 flex-1">
            <NexusHexGridComponent Systems="@Session.Systems" CurrentPlayerId="@Session.CurrentPlayer.PlayerId"
                                   OpponentPlayerId="@Session.Opponent.PlayerId" CurrentPlayerFaction="@Session.CurrentPlayer.Faction"
                                   CurrentPlayerGateProgress="@Session.CurrentPlayer.GateProgress" IsEditable="@ShowOrdersForm"
                                   PendingMoveOrders="@_pendingMoveOrders" SelectedSystem="@_selectedSystem"
                                   ValidMoveTargets="@_validMoveTargets" OnSystemClicked="OnSystemClicked" />
        </div>
    </section>

    @* Right sidebar: resolve events *@
    <aside class="space-y-4">
        @if (_resolveDisplayIndex > 0)
        {
            <section class="ui-surface-section space-y-3 p-4 lg:p-5">
                <p class="ui-panel-label">Last round</p>
                @foreach (var evt in Session.LastResolveEvents.Take(_resolveDisplayIndex))
                {
                    <p class="text-sm text-slate-300">
                        @NexusResolveEventMessageFormatter.Format(evt, GetPlayerNames())
                    </p>
                }
                @if (_resolveDisplayIndex < Session.LastResolveEvents.Length)
                {
                    <p class="animate-pulse text-xs text-slate-500">Resolving...</p>
                }
            </section>
        }
    </aside>
</div>

@code {
    [Parameter, EditorRequired]
    public NexusGameView Session { get; set; } = default!;

    [Parameter, EditorRequired]
    public GameLobbyView Lobby { get; set; } = default!;

    [Parameter]
    public bool IsSubmittingAction { get; set; }

    [Parameter]
    public string? GameplayError { get; set; }

    [Parameter]
    public EventCallback<NexusTurnOrdersCommand> OnSubmitOrders { get; set; }

    private readonly List<NexusMoveOrder> _pendingMoveOrders = [];
    private readonly List<NexusBuildOrder> _pendingBuildOrders = [];
    private bool _pendingBeginNexusGate;
    private int _resolveDisplayIndex;
    private int? _lastKnownRound;
    private CancellationTokenSource? _playbackCts;
    private HexCoord? _selectedSystem;
    private bool _pickingMoveDest;
    private ImmutableDictionary<NexusUnitType, int> _stagedMoveUnits = ImmutableDictionary<NexusUnitType, int>.Empty;
    private IReadOnlyList<HexCoord> _validMoveTargets = [];

    protected override void OnParametersSet()
    {
        if (Session.RoundNumber == _lastKnownRound)
            return;

        _lastKnownRound = Session.RoundNumber;
        _pendingMoveOrders.Clear();
        _pendingBuildOrders.Clear();
        _pendingBeginNexusGate = false;
        ClearSelection();

        if (Session.LastResolveEvents.Length > 0)
            StartResolvePlayback(Session.LastResolveEvents.Length);
        else
            _resolveDisplayIndex = 0;
    }

    private void StartResolvePlayback(int count)
    {
        _playbackCts?.Cancel();
        _playbackCts?.Dispose();
        _playbackCts = new CancellationTokenSource();
        var token = _playbackCts.Token;
        _resolveDisplayIndex = 0;
        _ = InvokeAsync(async () =>
        {
            for (var i = 1; i <= count; i++)
            {
                try
                {
                    await Task.Delay(400, token);
                }
                catch (OperationCanceledException)
                {
                    break;
                }

                if (token.IsCancellationRequested)
                    break;

                _resolveDisplayIndex = i;
                StateHasChanged();
            }
        });
    }

    public void Dispose()
    {
        _playbackCts?.Cancel();
        _playbackCts?.Dispose();
    }

    private bool ShowOrdersForm =>
        Lobby.IsCurrentUserActive
        && Session.Phase == NexusGamePhase.Planning
        && !Session.CurrentPlayer.HasSubmittedOrders
        && Session.Completion is null;

    private string CurrentPlayerName => Lobby.CurrentPlayerName;

    private string OpponentPlayerName =>
        Lobby.Players.FirstOrDefault(p => p.PlayerId != Lobby.CurrentPlayerId)?.Name
        ?? "your opponent";

    private IReadOnlyDictionary<Guid, string> GetPlayerNames() =>
        new Dictionary<Guid, string>
        {
            [Session.CurrentPlayer.PlayerId] = CurrentPlayerName,
            [Session.Opponent.PlayerId] = OpponentPlayerName,
        };

    private void OnSystemClicked(HexCoord coord)
    {
        if (!ShowOrdersForm)
            return;

        if (_pickingMoveDest)
        {
            if (_validMoveTargets.Contains(coord))
                ConfirmMoveOrder(coord);
            // else: click outside valid targets — do nothing
            return;
        }

        _selectedSystem = _selectedSystem == coord ? null : (HexCoord?)coord;
    }

    private void RemoveMoveOrder(NexusMoveOrder order) => _pendingMoveOrders.Remove(order);

    private void RemoveBuildOrder(NexusUnitType unit)
    {
        var idx = _pendingBuildOrders.FindIndex(o => o.UnitType == unit);
        if (idx < 0)
            return;
        if (_pendingBuildOrders[idx].Count <= 1)
            _pendingBuildOrders.RemoveAt(idx);
        else
            _pendingBuildOrders[idx] = _pendingBuildOrders[idx] with { Count = _pendingBuildOrders[idx].Count - 1 };
    }

    private void RemoveBuildOrder(NexusBuildOrder order)
    {
        _pendingBuildOrders.RemoveAll(o => o.UnitType == order.UnitType);
    }

    private void ClearSelection()
    {
        _selectedSystem = null;
        _pickingMoveDest = false;
        _stagedMoveUnits = ImmutableDictionary<NexusUnitType, int>.Empty;
        _validMoveTargets = [];
    }

    private void OnMoveUnitsConfirmed(ImmutableDictionary<NexusUnitType, int> units)
    {
        _stagedMoveUnits = units;
        _validMoveTargets = NexusGameViewQueries.GetValidMoveDestinations(
            Session, Session.CurrentPlayer.PlayerId, _selectedSystem!.Value);
        _pickingMoveDest = true;
    }

    private void ConfirmMoveOrder(HexCoord destination)
    {
        if (_selectedSystem is null)
            return;

        _pendingMoveOrders.Add(new NexusMoveOrder(_selectedSystem.Value, destination, _stagedMoveUnits));
        ClearSelection();
    }

    private void CancelDestPick()
    {
        _stagedMoveUnits = ImmutableDictionary<NexusUnitType, int>.Empty;
        _pickingMoveDest = false;
        _validMoveTargets = [];
    }

    private void AddBuildOrder(NexusUnitType unit)
    {
        if (ProjectedEnergy < unit.Cost())
            return;
        var idx = _pendingBuildOrders.FindIndex(o => o.UnitType == unit);
        if (idx >= 0)
            _pendingBuildOrders[idx] = _pendingBuildOrders[idx] with { Count = _pendingBuildOrders[idx].Count + 1 };
        else
            _pendingBuildOrders.Add(new NexusBuildOrder(unit, 1));
    }

    private bool CanShowGateOption(HexCoord coord)
    {
        if (Session.CurrentPlayer.GateProgress == NexusGateProgress.Completed)
            return false;

        var system = Session.Systems.FirstOrDefault(s => s.Coord == coord);
        if (system is null || !system.IsNexus)
            return false;

        var (_, _, gnd) = NexusHexHelpers.GetUnitCounts(system, Session.CurrentPlayer.PlayerId);
        return gnd > 0;
    }

    private ImmutableDictionary<NexusUnitType, int> GetAvailableUnits(HexCoord coord)
    {
        var system = Session.Systems.FirstOrDefault(s => s.Coord == coord);
        if (system is null)
            return ImmutableDictionary<NexusUnitType, int>.Empty;

        if (!system.Units.TryGetValue(Session.CurrentPlayer.PlayerId, out var unitsAtSystem))
            return ImmutableDictionary<NexusUnitType, int>.Empty;

        var assigned = _pendingMoveOrders
            .Where(o => o.From == coord)
            .SelectMany(o => o.Units)
            .GroupBy(kv => kv.Key)
            .ToDictionary(g => g.Key, g => g.Sum(kv => kv.Value));

        return unitsAtSystem
            .Select(kv => (Type: kv.Key, Count: kv.Value - assigned.GetValueOrDefault(kv.Key)))
            .Where(x => x.Count > 0)
            .ToImmutableDictionary(x => x.Type, x => x.Count);
    }

    private int ProjectedSpend =>
        _pendingBuildOrders.Sum(o => o.UnitType.Cost() * o.Count) + (_pendingBeginNexusGate ? 12 : 0);

    private int ProjectedEnergy => Session.CurrentPlayer.Energy - ProjectedSpend;

    private string GateButtonClass() =>
        _pendingBeginNexusGate
            ? "flex w-full items-center justify-between gap-2 rounded-lg border border-purple-500/50 bg-purple-600/20 px-3 py-1.5 text-xs text-purple-300 transition-colors"
            : "flex w-full items-center justify-between gap-2 rounded-lg border border-white/10 bg-slate-950/60 px-3 py-1.5 text-xs text-slate-200 transition-colors hover:border-purple-500/30";

    private Task SubmitOrdersAsync()
    {
        var command = new NexusTurnOrdersCommand(
            Session.CurrentPlayer.PlayerId,
            Session.RoundNumber,
            _pendingMoveOrders.ToImmutableArray(),
            _pendingBuildOrders.ToImmutableArray(),
            _pendingBeginNexusGate
        );

        _pendingMoveOrders.Clear();
        _pendingBuildOrders.Clear();
        _pendingBeginNexusGate = false;

        return OnSubmitOrders.InvokeAsync(command);
    }

    private string GetHeadline() =>
        Session switch
        {
            { Completion: not null } => "Match complete",
            { Phase: NexusGamePhase.Planning, CurrentPlayer.HasSubmittedOrders: false } =>
                "Submit your orders",
            { Phase: NexusGamePhase.Planning } => "Waiting for opponent",
            _ => "Gameplay",
        };

    private string GetDescription() =>
        Session switch
        {
            { Completion: not null } => GetCompletionMessage(),
            { Phase: NexusGamePhase.Planning, CurrentPlayer.HasSubmittedOrders: false } =>
                "Choose your orders and submit. Both players resolve simultaneously once both have submitted.",
            { Phase: NexusGamePhase.Planning } =>
                $"Waiting for {OpponentPlayerName} to submit their orders.",
            _ => "Game state is resolving.",
        };

    private string GetCompletionMessage()
    {
        if (Session.Completion is null)
            return string.Empty;

        return Session.Completion.Outcome switch
        {
            NexusGameOutcome.Victory
                when Session.Completion.WinnerId == Session.CurrentPlayer.PlayerId =>
                "You activated the Nexus gate. Victory!",
            NexusGameOutcome.Victory => $"{OpponentPlayerName} activated the Nexus gate.",
            NexusGameOutcome.Draw => "The match ended in a draw.",
            _ => "The match has ended.",
        };
    }
}
