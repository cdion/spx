@using Spx.Game.Domain
@using System.Text

<g @onclick="HandleClick" class="@(IsClickable ? "cursor-pointer" : "")">
    <polygon points="@NexusHexHelpers.HexPoints(Center)" fill="@NexusHexHelpers.GetHexFill(System, CurrentPlayerId, CurrentPlayerFaction)"
             stroke="rgba(255,255,255,0.12)" stroke-width="1" opacity="0.92" />

    @* Triangle cap — home system indicator or Nexus gold *@
    @if (NexusHexHelpers.GetCapFill(System, CurrentPlayerId, CurrentPlayerFaction) is { } capFill)
    {
        <polygon points="@NexusHexHelpers.CapPoints(Center)" fill="@capFill" />
    }

    @* Star glyph on home systems *@
    @if (System.HomePlayerId.HasValue)
    {
        <polygon points="@NexusHexHelpers.StarPoints(Center)" fill="rgba(255,255,255,0.85)" />
    }

    @* Coord label, income, unit counts, gate badge *@
    @((MarkupString)CoordLabel)
    @((MarkupString)IncomeLabelMarkup)
    @((MarkupString)UnitCountsMarkup)
    @((MarkupString)NexusGateBadgeMarkup)
</g>

@code {
    [Parameter, EditorRequired]
    public NexusSystemView System { get; set; } = default!;

    [Parameter, EditorRequired]
    public (double X, double Y) Center { get; set; }

    [Parameter, EditorRequired]
    public Guid CurrentPlayerId { get; set; }

    [Parameter]
    public Guid? OpponentPlayerId { get; set; }

    [Parameter]
    public NexusGateProgress CurrentPlayerGateProgress { get; set; }

    [Parameter]
    public NexusFactionColor CurrentPlayerFaction { get; set; }

    [Parameter]
    public bool IsClickable { get; set; }

    [Parameter]
    public EventCallback<HexCoord> OnClicked { get; set; }

    private string CoordLabel
    {
        get
        {
            const string style =
                "fill=\"rgba(148,163,184,0.4)\" font-size=\"6.5\" font-family=\"monospace\"";
            var y = NexusHexHelpers.Fmt(Center.Y - 11);
            var cx = NexusHexHelpers.Fmt(Center.X);
            return $"<text x=\"{cx}\" y=\"{y}\" text-anchor=\"end\" {style}>{System.Coord.Q},</text>"
                + $"<text x=\"{cx}\" y=\"{y}\" text-anchor=\"start\" {style}>{System.Coord.R}</text>";
        }
    }

    private string IncomeLabelMarkup
    {
        get
        {
            if (System.IsNexus || System.IncomeValue == 0)
                return string.Empty;

            return $"<text x=\"{NexusHexHelpers.Fmt(Center.X)}\" y=\"{NexusHexHelpers.Fmt(Center.Y + 22)}\" "
                + "text-anchor=\"middle\" fill=\"rgba(250,204,21,0.7)\" font-size=\"7\" font-family=\"monospace\">"
                + $"+{System.IncomeValue}&#x26A1;</text>";
        }
    }

    private string UnitCountsMarkup
    {
        get
        {
            var sb = new StringBuilder();

            // Current player's units — diamond at bottom-left, colored by faction
            var myColor = CurrentPlayerFaction == NexusFactionColor.Red ? "#f87171" : "#60a5fa";
            var (myS, myQ, myG) = NexusHexHelpers.GetUnitCounts(System, CurrentPlayerId);
            if (myS + myQ + myG > 0)
            {
                var cx = NexusHexHelpers.Fmt(Center.X - 13);
                var cy = NexusHexHelpers.Fmt(Center.Y + 10);
                var cy4 = NexusHexHelpers.Fmt(Center.Y + 6);
                var cy8 = NexusHexHelpers.Fmt(Center.Y + 14);
                var cx4l = NexusHexHelpers.Fmt(Center.X - 17);
                var cx4r = NexusHexHelpers.Fmt(Center.X - 9);
                sb.Append(
                    $"<polygon points=\"{cx},{cy4} {cx4r},{cy} {cx},{cy8} {cx4l},{cy}\" "
                    + $"fill=\"{myColor}\" stroke=\"rgba(255,255,255,0.15)\" stroke-width=\"0.5\"/>"
                );
            }

            // Opponent's units — diamond at bottom-right, opposite faction color
            var opColor = CurrentPlayerFaction == NexusFactionColor.Red ? "#60a5fa" : "#f87171";
            if (OpponentPlayerId.HasValue)
            {
                var (opS, opQ, opG) = NexusHexHelpers.GetUnitCounts(System, OpponentPlayerId.Value);
                if (opS + opQ + opG > 0)
                {
                    var cx = NexusHexHelpers.Fmt(Center.X + 13);
                    var cy = NexusHexHelpers.Fmt(Center.Y + 10);
                    var cy4 = NexusHexHelpers.Fmt(Center.Y + 6);
                    var cy8 = NexusHexHelpers.Fmt(Center.Y + 14);
                    var cx4l = NexusHexHelpers.Fmt(Center.X + 9);
                    var cx4r = NexusHexHelpers.Fmt(Center.X + 17);
                    sb.Append(
                        $"<polygon points=\"{cx},{cy4} {cx4r},{cy} {cx},{cy8} {cx4l},{cy}\" "
                        + $"fill=\"{opColor}\" stroke=\"rgba(255,255,255,0.15)\" stroke-width=\"0.5\"/>"
                    );
                }
            }

            return sb.ToString();
        }
    }

    private string NexusGateBadgeMarkup
    {
        get
        {
            if (!System.IsNexus || CurrentPlayerGateProgress == NexusGateProgress.None)
                return string.Empty;

            var (activeFill, dimFill) = CurrentPlayerFaction == NexusFactionColor.Red
                ? ("#f87171", "rgba(248,113,113,0.18)")
                : ("#60a5fa", "rgba(96,165,250,0.18)");

            var cx1 = NexusHexHelpers.Fmt(Center.X - 5);
            var cx2 = NexusHexHelpers.Fmt(Center.X + 5);
            var cy = NexusHexHelpers.Fmt(Center.Y - 2);

            var pip2Fill =
                CurrentPlayerGateProgress >= NexusGateProgress.Completed ? activeFill : dimFill;

            return $"<circle cx=\"{cx1}\" cy=\"{cy}\" r=\"3.5\" fill=\"{activeFill}\"/>"
                + $"<circle cx=\"{cx2}\" cy=\"{cy}\" r=\"3.5\" fill=\"{pip2Fill}\"/>";
        }
    }

    private Task HandleClick() =>
        IsClickable ? OnClicked.InvokeAsync(System.Coord) : Task.CompletedTask;
}
