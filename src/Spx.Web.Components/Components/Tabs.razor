@typeparam TItem

<div class="@ContainerClass" role="tablist" aria-label="@AriaLabel">
    @foreach (var item in Items)
    {
        var selected = EqualityComparer<TItem>.Default.Equals(item, SelectedItem);
        var disabled = DisabledSelector?.Invoke(item) ?? false;
        <button type="button" class="@(selected ? ActiveItemClass : InactiveItemClass)"
                role="tab" aria-selected="@selected" disabled="@disabled"
                @onclick="() => OnSelected.InvokeAsync(item)">
            @ItemLabelSelector(item)
        </button>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<TItem> Items { get; set; } = [];

    [Parameter, EditorRequired]
    public TItem SelectedItem { get; set; } = default!;

    [Parameter, EditorRequired]
    public Func<TItem, string> ItemLabelSelector { get; set; } = default!;

    [Parameter]
    public Func<TItem, bool>? DisabledSelector { get; set; }

    [Parameter]
    public EventCallback<TItem> OnSelected { get; set; }

    [Parameter]
    public string ContainerClass { get; set; } = "flex items-center gap-2";

    [Parameter]
    public string ActiveItemClass { get; set; } =
        "rounded-md border border-white/15 bg-white/10 px-3 py-1.5 text-sm font-semibold text-white";

    [Parameter]
    public string InactiveItemClass { get; set; } =
        "rounded-md border border-white/10 px-3 py-1.5 text-sm text-slate-400 transition-colors hover:text-slate-200";

    [Parameter]
    public string AriaLabel { get; set; } = "Tabs";
}
