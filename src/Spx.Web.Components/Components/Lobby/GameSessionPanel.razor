@using Spx.Web.Components.Gameplay
@implements IGameMessagesViewport

@* Routes between the pre-game waiting state and the active gameplay panel. *@
<section class="ui-surface-form-tight space-y-5">
    @if (HasMessagesShell)
    {
        <div class="space-y-4">
            <Tabs TItem="GameSessionTab" Items="VisibleTabs" SelectedItem="@_selectedTab"
                  ItemIdSelector="GetTabId" PanelIdSelector="GetPanelId"
                  ActiveItemClass="rounded-md border border-white/15 bg-white/10 px-3.5 py-2 text-base font-semibold text-white"
                  InactiveItemClass="rounded-md border border-white/10 px-3.5 py-2 text-base text-slate-400 transition-colors hover:text-slate-200"
                  ItemLabelSelector="GetTabLabel" OnSelected="SetTabAsync" AriaLabel="Session view" />

            <div id="@ActivePanelId" role="tabpanel" aria-labelledby="@ActiveTabId" class="space-y-4">
                @if (_selectedTab == GameSessionTab.Timeline)
                {
                    @if (ResolvedSessionState.Session is null)
                    {
                        <p class="text-sm leading-6 text-slate-300">@GetTimelineDescription()</p>
                    }

                    @if (ResolvedSessionState.Session is null && !string.IsNullOrWhiteSpace(ResolvedSessionState.GameplayError))
                    {
                        <AlertBanner>@ResolvedSessionState.GameplayError</AlertBanner>
                    }

                    <div class="grid gap-4 lg:grid-cols-[1.35fr_0.85fr] lg:gap-5">
                        <GameTimelinePanel @key="GetTimelinePanelKey()" @ref="timelinePanel"
                                           CurrentUserName="@ResolvedMessagesState.CurrentUserName" TimelineItems="ResolvedMessagesState.Items"
                                           MessageError="@ResolvedMessagesState.MessageError"
                                           IsTimelineLoading="@ResolvedMessagesState.IsTimelineLoading"
                                           IsLoadingOlderMessages="@ResolvedMessagesState.IsLoadingOlderMessages"
                                           HasOlderMessages="@ResolvedMessagesState.HasOlderMessages"
                                           EditingMessageId="@ResolvedMessagesState.EditingMessageId"
                                           EditMessageText="@ResolvedMessagesState.EditMessageText"
                                           EditMessageTextChanged="HandleEditMessageTextChanged"
                                           IsSavingEdit="@ResolvedMessagesState.IsSavingEdit"
                                           OnLoadOlderMessages="HandleLoadOlderMessages"
                                           OnBeginEdit="HandleBeginEdit"
                                           OnCancelEdit="HandleCancelEdit"
                                           OnSaveEdit="HandleSaveEdit"
                                           OnDeleteMessage="HandleDeleteMessage"
                                           OnRetryPendingMessage="HandleRetryPendingMessage"
                                           OnDismissPendingMessage="HandleDismissPendingMessage" />

                        <GameMessageComposer @key="GetMessageComposerKey()"
                                             IsCurrentUserActive="@ResolvedMessagesState.IsCurrentUserActive"
                                             CurrentPlayerId="@ResolvedMessagesState.CurrentPlayerId"
                                             Players="@ResolvedMessagesState.Players"
                                             Text="@ResolvedMessagesState.ComposerText"
                                             TextChanged="HandleComposerTextChanged"
                                             SelectedRecipientPlayerIdString="@ResolvedMessagesState.SelectedRecipientPlayerIdString"
                                             SelectedRecipientPlayerIdStringChanged="HandleRecipientChanged"
                                             IsSendingMessage="@ResolvedMessagesState.IsSendingMessage"
                                             OnSend="HandleSendMessage" />
                    </div>
                }
                else if (ResolvedSessionState.Session is not null)
                {
                    <NexusGameplayPanel Session="ResolvedSessionState.Session" Lobby="ResolvedSessionState.Lobby"
                                        IsSubmittingAction="@ResolvedSessionState.IsSubmittingGameplayAction"
                                        GameplayError="@ResolvedSessionState.GameplayError"
                                        OnSubmitOrders="OnSubmitOrders" />
                }
            </div>
        </div>
    }
    else if (Session is null)
    {
        <p class="text-sm leading-6 text-slate-300">@GetDescription()</p>

        @if (!string.IsNullOrWhiteSpace(GameplayError))
        {
            <AlertBanner>@GameplayError</AlertBanner>
        }

        <div class="ui-empty-state">
            @GetEmptyStateMessage()
        </div>
    }
    else
    {
        <NexusGameplayPanel Session="Session" Lobby="Lobby" IsSubmittingAction="IsSubmittingAction"
                            GameplayError="@GameplayError" OnSubmitOrders="OnSubmitOrders" />
    }
</section>

@code {
    [Parameter]
    public GameSessionState? State { get; set; }

    [Parameter]
    public GameMessagesState? MessagesState { get; set; }

    [Parameter]
    public GameMessagesCallbacks? MessagesCallbacks { get; set; }

    [Parameter]
    public GameSessionTab? SelectedTab { get; set; }

    [Parameter]
    public EventCallback<GameSessionTab> SelectedTabChanged { get; set; }

    [Parameter]
    public GameLobbyView? Lobby { get; set; }

    [Parameter]
    public NexusGameView? Session { get; set; }

    [Parameter]
    public bool IsSubmittingAction { get; set; }

    [Parameter]
    public string? GameplayError { get; set; }

    [Parameter]
    public EventCallback<NexusTurnOrdersCommand> OnSubmitOrders { get; set; }

    private GameSessionTab _selectedTab = GameSessionTab.Timeline;
    private GameTimelinePanel? timelinePanel;

    private bool HasMessagesShell => MessagesState is not null && MessagesCallbacks is not null;

    private GameSessionState ResolvedSessionState =>
        State
        ?? new GameSessionState
        {
            Lobby = Lobby ?? throw new InvalidOperationException("GameSessionPanel requires either State or Lobby."),
            Session = Session,
            IsSubmittingGameplayAction = IsSubmittingAction,
            GameplayError = GameplayError,
        };

    private GameMessagesState ResolvedMessagesState => MessagesState!;

    private IReadOnlyList<GameSessionTab> VisibleTabs => GetVisibleTabs().ToArray();

    private string ActiveTabId => GetTabId(_selectedTab);

    private string ActivePanelId => GetPanelId(_selectedTab);

    public Task<TimelineScrollMetrics> GetScrollMetricsAsync() =>
        timelinePanel?.GetScrollMetricsAsync() ?? Task.FromResult(new TimelineScrollMetrics());

    public Task RestoreScrollAfterPrependAsync(double previousScrollHeight, double previousScrollTop) =>
        timelinePanel?.RestoreScrollAfterPrependAsync(previousScrollHeight, previousScrollTop) ?? Task.CompletedTask;

    public Task ScrollToBottomAsync() =>
        timelinePanel?.ScrollToBottomAsync() ?? Task.CompletedTask;

    public Task<bool> IsNearBottomAsync() =>
        timelinePanel?.IsNearBottomAsync() ?? Task.FromResult(true);

    protected override void OnParametersSet()
    {
        if (!HasMessagesShell)
        {
            return;
        }

        var visibleTabs = VisibleTabs;
        var requestedTab = SelectedTab ?? _selectedTab;
        _selectedTab = visibleTabs.Contains(requestedTab)
            ? requestedTab
            : GetDefaultTab();
    }

    private string GetHeadline() =>
        !ResolvedSessionState.Lobby.IsCurrentUserActive ? "Archived seat" :
        ResolvedSessionState.Lobby.Players.Count < ResolvedSessionState.Lobby.MaxPlayers ? "Waiting for an opponent" :
        "Session syncing";

    private string GetTimelineDescription() =>
        ResolvedSessionState.Session is null
            ? GetDescription()
            : "Read system events, public chat, and private coordination without leaving the session shell.";

    private string GetDescription() =>
        !ResolvedSessionState.Lobby.IsCurrentUserActive
            ? "Gameplay is only available while you still occupy an active seat in the match."
            : ResolvedSessionState.Lobby.Players.Count < ResolvedSessionState.Lobby.MaxPlayers
                ? "The match begins automatically after another player joins this lobby."
                : "The match is active, but your session view is still catching up.";

    private string GetEmptyStateMessage() =>
        !ResolvedSessionState.Lobby.IsCurrentUserActive
            ? "You can still read the lobby timeline, but gameplay controls are disabled because you already left this game."
            : ResolvedSessionState.Lobby.Players.Count < ResolvedSessionState.Lobby.MaxPlayers
                ? "Share the invite code and wait for the second player to join. Gameplay will appear here as soon as the match initializes."
                : "The match state is still loading. This panel updates automatically.";

    private IEnumerable<GameSessionTab> GetVisibleTabs()
    {
        yield return GameSessionTab.Timeline;

        if (ResolvedSessionState.Session is null || !ResolvedSessionState.Lobby.IsCurrentUserActive)
        {
            yield break;
        }

        yield return GameSessionTab.Game;
    }

    private GameSessionTab GetDefaultTab()
    {
        if (ResolvedSessionState.Session is null || !ResolvedSessionState.Lobby.IsCurrentUserActive)
        {
            return GameSessionTab.Timeline;
        }

        return GameSessionTab.Game;
    }

    private async Task SetTabAsync(GameSessionTab tab)
    {
        if (!VisibleTabs.Contains(tab) || _selectedTab == tab)
        {
            return;
        }

        _selectedTab = tab;
        if (SelectedTabChanged.HasDelegate)
        {
            await SelectedTabChanged.InvokeAsync(tab);
        }
    }

    private static string GetTabLabel(GameSessionTab tab) =>
        tab switch
        {
            GameSessionTab.Timeline => "Timeline",
            GameSessionTab.Game => "Game",
            _ => tab.ToString(),
        };

    private static string GetTabId(GameSessionTab tab) => $"game-session-tab-{tab.ToString().ToLowerInvariant()}";

    private static string GetPanelId(GameSessionTab tab) => $"game-session-panel-{tab.ToString().ToLowerInvariant()}";

    private object GetTimelinePanelKey() =>
        (nameof(GameTimelinePanel), ResolvedSessionState.Lobby.GameId);

    private object GetMessageComposerKey() =>
        (nameof(GameMessageComposer), ResolvedSessionState.Lobby.GameId);

    private Task HandleLoadOlderMessages() => MessagesCallbacks!.LoadOlderMessagesAsync();

    private Task HandleBeginEdit(GameTimelineEntryView message) => MessagesCallbacks!.BeginEditAsync(message);

    private Task HandleEditMessageTextChanged(string value) => MessagesCallbacks!.SetEditMessageTextAsync(value);

    private Task HandleCancelEdit() => MessagesCallbacks!.CancelEditAsync();

    private Task HandleSaveEdit() => MessagesCallbacks!.SaveEditAsync();

    private Task HandleDeleteMessage(Guid messageId) => MessagesCallbacks!.DeleteMessageAsync(messageId);

    private Task HandleRetryPendingMessage(Guid key) => MessagesCallbacks!.RetryPendingMessageAsync(key);

    private Task HandleDismissPendingMessage(Guid key) => MessagesCallbacks!.DismissPendingMessageAsync(key);

    private Task HandleComposerTextChanged(string value) => MessagesCallbacks!.SetComposerTextAsync(value);

    private Task HandleRecipientChanged(string? value) => MessagesCallbacks!.SetRecipientPlayerIdStringAsync(value);

    private Task HandleSendMessage() => MessagesCallbacks!.SendMessageAsync();
}