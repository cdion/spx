@implements IAsyncDisposable
@inject IJSRuntime JS
@inject ILogger<LobbyMessageComposer> Logger

<div class="ui-panel-card flex h-full min-h-0 flex-col space-y-4">

    @if (IsCurrentUserActive)
    {
        <div class="flex min-h-0 flex-1 flex-col space-y-4">
            <div class="space-y-2">
                <label class="ui-panel-label" for="message-recipient">Recipient</label>
                <select id="message-recipient" class="ui-select" @bind="draftRecipientPlayerIdString">
                    <option value="">All active players</option>
                    @foreach (var player in Players.Where(player => player.PlayerId != CurrentPlayerId))
                    {
                        <option value="@player.PlayerId">@player.Name</option>
                    }
                </select>
            </div>

            <div class="flex min-h-0 flex-1 flex-col space-y-2">
                <label class="ui-panel-label" for="message-composer">Message</label>
                <textarea id="message-composer" class="ui-textarea min-h-32 flex-1"
                          placeholder="Write something for the game timeline..." @bind="draftText" @bind:event="oninput"
                          @ref="composerTextArea"></textarea>
                <p class="text-sm leading-6 text-slate-300">
                    <span>Enter sends. Shift+Enter adds a new line. Choose a player to send privately.</span>
                </p>
            </div>

            <div class="ui-lobby-row">
                <p class="ui-type-overline text-slate-500">
                    @draftText.Length / 1024 characters
                </p>
                <button class="ui-button-primary" @onclick="SubmitAsync" disabled="@IsSendingMessage">
                    @(IsSendingMessage ? "Sending..." : "Send message")
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="ui-empty-state">
            This composer is disabled because you are no longer an active player in this game.
        </div>
    }
</div>

@code {
    [Parameter]
    public bool IsCurrentUserActive { get; set; }

    [Parameter, EditorRequired]
    public Guid CurrentPlayerId { get; set; }

    [Parameter, EditorRequired]
    public IReadOnlyList<GamePlayerView> Players { get; set; } = [];

    [Parameter]
    public int ComposerResetVersion { get; set; }

    [Parameter]
    public bool IsSendingMessage { get; set; }

    [Parameter]
    public EventCallback<LobbyMessageComposerSubmitRequest> OnSend { get; set; }

    private ElementReference composerTextArea;
    private IJSObjectReference? module;
    private DotNetObjectReference<LobbyMessageComposer>? dotNetReference;
    private bool isSubmitAttached;
    private int lastComposerResetVersion;
    private string draftText = string.Empty;
    private string draftRecipientPlayerIdString = string.Empty;

    protected override void OnParametersSet()
    {
        if (ComposerResetVersion == lastComposerResetVersion)
        {
            return;
        }

        draftText = string.Empty;
        draftRecipientPlayerIdString = string.Empty;
        lastComposerResetVersion = ComposerResetVersion;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                module = await JS.InvokeAsync<IJSObjectReference>(
                    "import",
                    "./_content/Spx.Web.Components/Components/Lobby/LobbyMessageComposer.razor.js"
                );
                dotNetReference = DotNetObjectReference.Create(this);
            }
            catch (TaskCanceledException exception)
            {
                LogIgnoredInteropException(exception, "importing the message composer module");
            }
            catch (JSDisconnectedException exception)
            {
                LogIgnoredInteropException(exception, "importing the message composer module");
            }
        }

        if (module is null || dotNetReference is null)
        {
            return;
        }

        if (IsCurrentUserActive && !isSubmitAttached)
        {
            try
            {
                await module.InvokeVoidAsync("setComposerSubmit", composerTextArea, dotNetReference);
                isSubmitAttached = true;
            }
            catch (TaskCanceledException exception)
            {
                LogIgnoredInteropException(exception, "attaching the composer submit handler");
            }
            catch (JSDisconnectedException exception)
            {
                LogIgnoredInteropException(exception, "attaching the composer submit handler");
            }
        }
        else if (!IsCurrentUserActive && isSubmitAttached)
        {
            try
            {
                await module.InvokeVoidAsync("clearComposerSubmit", composerTextArea);
            }
            catch (TaskCanceledException exception)
            {
                LogIgnoredInteropException(exception, "clearing the composer submit handler");
            }
            catch (JSDisconnectedException exception)
            {
                LogIgnoredInteropException(exception, "clearing the composer submit handler");
            }

            isSubmitAttached = false;
        }
    }

    [JSInvokable]
    public Task HandleComposerEnterAsync() => SubmitAsync();

    public async ValueTask DisposeAsync()
    {
        if (module is not null)
        {
            try
            {
                await module.InvokeVoidAsync("clearComposerSubmit", composerTextArea);
                await module.DisposeAsync();
            }
            catch (TaskCanceledException exception)
            {
                LogIgnoredInteropException(exception, "disposing the message composer module");
            }
            catch (JSDisconnectedException exception)
            {
                LogIgnoredInteropException(exception, "disposing the message composer module");
            }
        }

        dotNetReference?.Dispose();
    }

    private void LogIgnoredInteropException(Exception exception, string operation)
        => Logger.LogDebug(exception, "Ignoring expected JS interop interruption while {Operation}.", operation);

    private Task SubmitAsync() =>
        IsSendingMessage
            ? Task.CompletedTask
            : OnSend.InvokeAsync(
                new LobbyMessageComposerSubmitRequest(
                    draftText,
                    string.IsNullOrWhiteSpace(draftRecipientPlayerIdString)
                        ? null
                        : draftRecipientPlayerIdString
                )
            );
}