<div class="ui-panel-card flex h-full min-h-0 flex-col space-y-4">

    @if (State.IsCurrentUserActive)
    {
        <div class="flex min-h-0 flex-1 flex-col space-y-4">
            <div class="space-y-2">
                <label class="ui-panel-label" for="message-recipient">Recipient</label>
                <select id="message-recipient" data-testid="@LobbyMessageComposerTestIds.Recipient" class="ui-select"
                        @bind="draftRecipientPlayerIdString">
                    <option value="">All active players</option>
                    @foreach (var player in State.Players.Where(player => player.PlayerId != State.CurrentPlayerId))
                    {
                        <option value="@player.PlayerId">@player.Name</option>
                    }
                </select>
            </div>

            <div class="flex min-h-0 flex-1 flex-col space-y-2">
                <label class="ui-panel-label" for="message-composer">Message</label>
                <textarea id="message-composer" data-testid="@LobbyMessageComposerTestIds.Composer"
                          class="ui-textarea min-h-32 flex-1" placeholder="Write something for the game timeline..."
                          @bind="draftText" @bind:event="oninput"></textarea>
            </div>

            @if (!string.IsNullOrWhiteSpace(State.ComposerError))
            {
                <AlertBanner>@State.ComposerError</AlertBanner>
            }

            <div class="ui-lobby-row">
                <p class="ui-type-overline text-slate-500">
                    @draftText.Length / 1024 characters
                </p>
                <button class="ui-button-primary" data-testid="@LobbyMessageComposerTestIds.SendButton"
                        @onclick="SubmitAsync" disabled="@State.IsSendingMessage">
                    @(State.IsSendingMessage ? "Sending..." : "Send message")
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="ui-empty-state">
            This composer is disabled because you are no longer an active player in this game.
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public LobbyMessagesState State { get; set; } = null!;

    [Parameter]
    public EventCallback<LobbyMessageComposerSubmitRequest> OnSend { get; set; }

    private int lastComposerResetVersion;
    private string draftText = string.Empty;
    private string draftRecipientPlayerIdString = string.Empty;

    protected override void OnParametersSet()
    {
        if (State.ComposerResetVersion == lastComposerResetVersion)
        {
            return;
        }

        draftText = string.Empty;
        draftRecipientPlayerIdString = string.Empty;
        lastComposerResetVersion = State.ComposerResetVersion;
    }

    private Task SubmitAsync() =>
        State.IsSendingMessage
            ? Task.CompletedTask
            : OnSend.InvokeAsync(
                new LobbyMessageComposerSubmitRequest(
                    draftText,
                    string.IsNullOrWhiteSpace(draftRecipientPlayerIdString)
                        ? null
                        : draftRecipientPlayerIdString
                )
            );
}