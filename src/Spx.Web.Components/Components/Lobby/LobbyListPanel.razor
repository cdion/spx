@if (IsLoading)
{
    <section class="ui-surface-empty mx-auto max-w-5xl text-slate-300">
        Loading your games...
    </section>
}
else if (!string.IsNullOrWhiteSpace(LoadError))
{
    <section class="mx-auto max-w-5xl">
        <AlertBanner>@LoadError</AlertBanner>
    </section>
}
else if (Games is not null)
{
    <section class="ui-page max-w-6xl">
        <header class="ui-surface-form flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div class="flex-1">
                <SectionHeader Eyebrow="Lobby" Title="My games" PageTitle
                               Description="Open games stay actionable, while ended games remain available as lightweight history." />
            </div>

            <div class="ui-actions">
                <a class="ui-button-primary" href="@CreateGameHref">
                    Create game
                </a>
                <a class="ui-button-secondary" href="@JoinGameHref">
                    Join with code
                </a>
            </div>
        </header>

        <div class="grid gap-6 xl:grid-cols-[1.4fr_1fr]">
            <div class="space-y-6">
                <section class="ui-surface-form">
                    <div class="ui-lobby-row items-start">
                        <SectionHeader Eyebrow="Open" Title="Active seats" Tone="SectionHeader.EyebrowTone.Accent" />
                        <StatusBadge Tone="StatusBadge.BadgeTone.Success">
                            @Games.OpenGames.Count game(s)
                        </StatusBadge>
                    </div>

                    @if (Games.OpenGames.Count == 0)
                    {
                        <p class="mt-6 ui-empty-state">You are not currently seated in any open games.</p>
                    }
                    else
                    {
                        <div class="mt-6 space-y-4">
                            @foreach (var game in Games.OpenGames)
                            {
                                <LobbyGameSummaryCard Title="@game.Name" InviteCode="@game.InviteCode"
                                                      PlayerSummary="@($"You are playing as {game.CurrentPlayerName}.")">
                                    <TrailingContent>
                                        <div class="flex flex-wrap gap-3">
                                            <StatusBadge>
                                                @game.ActivePlayerCount / @game.MaxPlayers players
                                            </StatusBadge>
                                            <a class="ui-button-primary-sm" href="@($"{GameHrefBase}/{game.GameId}")">
                                                Open lobby
                                            </a>
                                        </div>
                                    </TrailingContent>
                                </LobbyGameSummaryCard>
                            }
                        </div>
                    }
                </section>

                <section class="ui-surface-form">
                    <div class="ui-lobby-row items-start">
                        <SectionHeader Eyebrow="Ended" Title="History" Tone="SectionHeader.EyebrowTone.Muted" />
                        <StatusBadge>
                            @Games.EndedGames.Count game(s)
                        </StatusBadge>
                    </div>

                    @if (Games.EndedGames.Count == 0)
                    {
                        <p class="mt-6 ui-empty-state">Ended games will appear here after their final player leaves.</p>
                    }
                    else
                    {
                        <div class="mt-6 space-y-4">
                            @foreach (var game in Games.EndedGames)
                            {
                                <LobbyGameSummaryCard Title="@game.Name" InviteCode="@game.InviteCode"
                                                      PlayerSummary="@($"Your last player name was {game.CurrentPlayerName}.")"
                                                      InviteCodeCssClass="ui-code-token text-slate-100">
                                    <TrailingContent>
                                        <div class="space-y-2 text-sm text-slate-400 sm:text-right">
                                            <p>Ended @UiFormatHelpers.FormatDateTime(game.EndedAtUtc ?? game.CreatedAtUtc)</p>
                                            <p>Created @UiFormatHelpers.FormatDateTime(game.CreatedAtUtc)</p>
                                        </div>
                                    </TrailingContent>
                                </LobbyGameSummaryCard>
                            }
                        </div>
                    }
                </section>
            </div>

            <aside class="ui-surface-form space-y-6">
                <SectionHeader Eyebrow="Notes" Title="Current rules" />

                <ul class="space-y-3 text-sm leading-6 text-slate-300">
                    <li>Every game supports exactly two active player seats in this first slice.</li>
                    <li>Player names must be unique within a game and can be updated when you reattach.</li>
                    <li>Active and former players can open the lobby page for a game; only active players can take actions.
                    </li>
                    <li>Ended games appear in history for anyone who played in them, whether or not they had left before the
                        game ended.</li>
                    </ul>
                </aside>
            </div>
        </section>
    }

@code {
    [Parameter]
    public UserGamesView? Games { get; set; }

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public string? LoadError { get; set; }

    [Parameter]
    public string CreateGameHref { get; set; } = "/games/create";

    [Parameter]
    public string JoinGameHref { get; set; } = "/games/join";

    [Parameter]
    public string GameHrefBase { get; set; } = "/games";
}