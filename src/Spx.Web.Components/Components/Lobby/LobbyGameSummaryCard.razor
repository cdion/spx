<article class="ui-panel-card">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div class="space-y-2">
            <h3 class="text-xl font-semibold text-white">@Title</h3>
            <p class="text-sm text-slate-300">
                Invite code: <span class="@InviteCodeCssClass">@InviteCode</span>
            </p>
            <p class="text-sm text-slate-400">@PlayerSummary</p>
        </div>

        @if (TrailingContent is not null)
        {
            @TrailingContent
        }
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string InviteCode { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string PlayerSummary { get; set; } = string.Empty;

    [Parameter]
    public string InviteCodeCssClass { get; set; } = "ui-code-token text-sky-300";

    [Parameter]
    public RenderFragment? TrailingContent { get; set; }
}