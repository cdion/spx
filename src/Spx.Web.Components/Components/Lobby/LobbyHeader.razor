@using Spx.Game.Application

<header class="ui-surface-form-tight space-y-4">
    <div class="flex flex-wrap items-center justify-between gap-3">
        <a class="ui-button-secondary" href="@BackHref">
            Back to My Games
        </a>

        <div class="flex flex-wrap items-center gap-3 text-sm text-slate-300">
            <StatusBadge>
                @Lobby.Status
            </StatusBadge>
            <p>
                Invite code <span class="font-semibold tracking-[0.25em] text-sky-300">@Lobby.InviteCode</span>
            </p>
        </div>
    </div>

    <div class="flex flex-wrap items-center justify-between gap-3">
        <h1 class="ui-page-title">@Lobby.Name</h1>

        <StatusBadge Tone="StatusBadge.BadgeTone.Success">
            @Lobby.Players.Count / @Lobby.MaxPlayers players
        </StatusBadge>
    </div>

    <div class="flex overflow-x-auto">
        <div class="ml-auto flex min-w-max items-center gap-4 text-sm text-slate-300">
            @foreach (var player in Lobby.Players)
            {
                <div class="flex items-center gap-2">
                    <span class="font-semibold text-white">@player.Name</span>

                    @if (Presence.OnlinePlayerIds.Contains(player.PlayerId))
                    {
                        <StatusBadge Tone="StatusBadge.BadgeTone.Success">Online</StatusBadge>
                    }
                    else
                    {
                        <StatusBadge Tone="StatusBadge.BadgeTone.Offline">Offline</StatusBadge>
                    }

                    @if (player.PlayerId == Lobby.CurrentPlayerId)
                    {
                        <StatusBadge Tone="StatusBadge.BadgeTone.Info">You</StatusBadge>
                    }
                </div>
            }
        </div>
    </div>

</header>

@code {
    [Parameter, EditorRequired]
    public GameLobbyView Lobby { get; set; } = default!;

    [Parameter, EditorRequired]
    public GamePresenceView Presence { get; set; } = default!;

    [Parameter]
    public string BackHref { get; set; } = "/games";

}