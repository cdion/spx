<section class="ui-surface-empty mx-auto flex max-w-2xl flex-col gap-6">
    <PageHero Eyebrow="Authentication required" Title="@Title" Description="@Message" Compact />

    <div class="ui-actions">
        <a class="ui-button-primary" href="@SignInHref">@SignInText</a>
        <a class="ui-button-secondary" href="@RegisterHref">@RegisterText</a>
    </div>
</section>

@code {
    [Parameter] public string Title { get; set; } = "Sign in to continue";
    [Parameter] public string Message { get; set; } = "This page is only available to authenticated users.";
    [Parameter] public string SignInHref { get; set; } = "/login";
    [Parameter] public string SignInText { get; set; } = "Sign in";
    [Parameter] public string RegisterHref { get; set; } = "/register";
    [Parameter] public string RegisterText { get; set; } = "Create account";
}
