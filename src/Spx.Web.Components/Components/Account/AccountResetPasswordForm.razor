<FormPage Title="Choose a new password"
          Description="Set a new password for your account using the reset link sent to your email address.">
    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <AlertBanner>@Error</AlertBanner>
    }

    @if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Code))
    {
        <AlertBanner Tone="AlertBanner.AlertTone.Warning" Role="status">
            The reset link is incomplete. Request a new password reset email.
        </AlertBanner>
        <a class="ui-button-primary" href="/forgot-password">
            Request new link
        </a>
    }
    else
    {
        <form method="post" action="/account/reset-password" class="ui-flow">
            @FormTokens
            <input type="hidden" name="email" value="@Email" />
            <input type="hidden" name="code" value="@Code" />

            <FormField For="password" Label="New password">
                <input id="password" name="password" type="password" autocomplete="new-password" required
                       class="ui-input" />
            </FormField>

            <FormField For="confirmPassword" Label="Confirm new password">
                <input id="confirmPassword" name="confirmPassword" type="password" autocomplete="new-password" required
                       class="ui-input" />
            </FormField>

            <button class="ui-button-primary" type="submit">Reset password</button>
        </form>
    }
</FormPage>

@code {
    [Parameter] public string? Email { get; set; }
    [Parameter] public string? Code { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public RenderFragment? FormTokens { get; set; }
}
