<FormPage Title="Sign in" Description="Use your email and password to sign in">
    @if (!string.IsNullOrWhiteSpace(Status))
    {
        <AlertBanner Tone="AlertBanner.AlertTone.Success" Role="status">@Status</AlertBanner>
    }

    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <AlertBanner>@Error</AlertBanner>
    }

    <form method="post" action="/account/login" class="ui-flow">
        @FormTokens

        <FormField For="email" Label="Email">
            <input id="email" name="email" type="email" value="@Email" autocomplete="email" required class="ui-input" />
        </FormField>

        <FormField For="password" Label="Password">
            <input id="password" name="password" type="password" autocomplete="current-password" required
                   class="ui-input" />
        </FormField>

        <button class="ui-button-primary" type="submit">Sign in</button>
    </form>

    <div class="ui-inline-links">
        <a class="ui-inline-link" href="/register">Create an account</a>
        <a class="ui-inline-link" href="/forgot-password">Forgot your password?</a>
        <a class="ui-inline-link" href="/resend-confirmation?email=@Uri.EscapeDataString(Email ?? string.Empty)">Resend
            confirmation email</a>
        </div>
    </FormPage>

@code {
    [Parameter] public string? Email { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public string? Status { get; set; }
    [Parameter] public RenderFragment? FormTokens { get; set; }
}
