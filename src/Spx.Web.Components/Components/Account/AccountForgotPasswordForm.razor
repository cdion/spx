<FormPage Title="Reset your password"
          Description="Enter your email address and you will receive an email with a reset link if an account with that email exists.">
    @if (!string.IsNullOrWhiteSpace(Status))
    {
        <AlertBanner Tone="AlertBanner.AlertTone.Success" Role="status">@Status</AlertBanner>
    }

    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <AlertBanner>@Error</AlertBanner>
    }

    <form method="post" action="/account/forgot-password" class="ui-flow">
        @FormTokens

        <FormField For="email" Label="Email">
            <input id="email" name="email" type="email" value="@Email" autocomplete="email" required class="ui-input" />
        </FormField>

        <button class="ui-button-primary" type="submit">Send reset link</button>
    </form>

    <p class="text-sm text-slate-300">
        Remembered it?
        <a class="ui-inline-link" href="/login">Sign in</a>
    </p>
</FormPage>

@code {
    [Parameter] public string? Email { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public string? Status { get; set; }
    [Parameter] public RenderFragment? FormTokens { get; set; }
}
