@using Spx.Nexus.Domain

@{
    var direction = Event.IsRetreat ? "retreated from" : "advanced from";
}

<span>
    <span class="font-semibold @Context.PlayerNameClass(Event.PlayerId)">@Context.PlayerName(Event.PlayerId)</span>'s units @direction
    <NexusSystemBadge Coord="Event.From"
                       CurrentPlayer="@Context.CurrentPlayer"
                       Opponent="@Context.Opponent" />
    to
    <NexusSystemBadge Coord="Event.To"
                       CurrentPlayer="@Context.CurrentPlayer"
                       Opponent="@Context.Opponent" />:
    @foreach (var stack in Event.Stacks)
    {
        <NexusUnitBadge Category="stack.Category"
                         DesignName="@stack.DesignName"
                         Count="@stack.Count"
                         RemainingHits="@stack.RemainingHits" />
    }
</span>

@code {
    [Parameter, EditorRequired]
    public NexusUnitsMovedEvent Event { get; set; } = default!;

    [Parameter, EditorRequired]
    public EventRowContext Context { get; set; } = default!;
}
