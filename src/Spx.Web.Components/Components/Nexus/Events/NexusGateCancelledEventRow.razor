@using Spx.Nexus.Domain

<span>
    <span class="font-semibold @Context.PlayerNameClass(Event.PlayerId)">@Context.PlayerName(Event.PlayerId)</span>'s
    Nexus Gate construction at
    <NexusSystemBadge Coord="Event.System"
                       CurrentPlayer="@Context.CurrentPlayer"
                       Opponent="@Context.Opponent" />
    was cancelled
</span>

@code {
    [Parameter, EditorRequired]
    public NexusGateCancelledEvent Event { get; set; } = default!;

    [Parameter, EditorRequired]
    public EventRowContext Context { get; set; } = default!;
}
