@using Spx.Nexus.Domain

@{
    var design = Context.DesignLookup[Event.DesignId];
}

<span class="whitespace-normal"><span class="font-semibold @Context.PlayerNameClass(Event.PlayerId)">@Context.PlayerName(Event.PlayerId)</span> deployed <NexusUnitBadge Category="@design.Hull" DesignName="@Event.DesignName" Design="@design" Count="@Event.Count" Player="@Context.PlayerContext(Event.PlayerId)" /> at <NexusSystemBadge Coord="@Event.HomeSystem" CurrentPlayer="@Context.CurrentPlayer" Opponent="@Context.Opponent" /></span>

@code {
    [Parameter, EditorRequired]
    public NexusUnitDeployedEvent Event { get; set; } = default!;

    [Parameter, EditorRequired]
    public EventRowContext Context { get; set; } = default!;
}
