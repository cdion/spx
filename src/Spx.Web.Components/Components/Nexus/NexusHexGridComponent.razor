@using System.Collections.Immutable

<div class="relative h-full w-full select-none">
    <svg viewBox="@ViewBox" class="h-full w-full" xmlns="http://www.w3.org/2000/svg" @onclick="OnBackgroundClicked">
        @* Pass 1: Hex cells *@
        @foreach (var system in Systems)
        {
            var center = NexusHexHelpers.HexCenter(system.Coord);
            <NexusHexCellComponent System="system" Center="center" CurrentPlayerId="CurrentPlayerId"
                                   OpponentPlayerId="@OpponentPlayerId" CurrentPlayerFaction="CurrentPlayerFaction"
                                   CurrentPlayerGateProgress="CurrentPlayerGateProgress" IsClickable="IsEditable"
                                   OnClicked="OnSystemClicked" />
        }

        @* Pass 2a: Valid-target rings *@
        @foreach (var coord in ValidMoveTargets)
        {
            <polygon points="@NexusHexHelpers.HexPoints(NexusHexHelpers.HexCenter(coord))" fill="none" stroke="#38bdf8"
                     stroke-width="2" pointer-events="none" />
        }

        @* Pass 2b: Selection ring *@
        @if (SelectedSystem.HasValue)
        {
            <polygon points="@NexusHexHelpers.HexPoints(NexusHexHelpers.HexCenter(SelectedSystem.Value))" fill="none"
                     stroke="rgba(226,232,240,0.9)" stroke-width="2.5" pointer-events="none" />
        }

        @* Pass 2c: Event-focus rings and path *@
        @foreach (var coord in EventFocusSystems)
        {
            <polygon points="@NexusHexHelpers.HexPoints(NexusHexHelpers.HexCenter(coord))" fill="none"
                     stroke="rgba(245,158,11,0.9)" stroke-width="2.5" pointer-events="none" />
        }

        @if (EventFocusFrom.HasValue && EventFocusTo.HasValue)
        {
            var from = NexusHexHelpers.HexCenter(EventFocusFrom.Value);
            var to = NexusHexHelpers.HexCenter(EventFocusTo.Value);
            var dx = to.X - from.X;
            var dy = to.Y - from.Y;
            var len = Math.Sqrt(dx * dx + dy * dy);
            @if (len >= 1)
            {
                var ux = dx / len;
                var uy = dy / len;
                var px = -uy;
                var py = ux;
                var mx = (from.X + to.X) / 2.0;
                var my = (from.Y + to.Y) / 2.0;
                const double h = 4.5;
                const double w = 7;
                const string focusColor = "rgba(245,158,11,0.9)";
                var lx = mx - ux * h - px * w;
                var ly = my - uy * h - py * w;
                var tx = mx + ux * h;
                var ty = my + uy * h;
                var rx = mx - ux * h + px * w;
                var ry = my - uy * h + py * w;
                var outlinePts = $"{NexusHexHelpers.Fmt(lx)},{NexusHexHelpers.Fmt(ly)} "
                           + $"{NexusHexHelpers.Fmt(tx)},{NexusHexHelpers.Fmt(ty)} "
                           + $"{NexusHexHelpers.Fmt(rx)},{NexusHexHelpers.Fmt(ry)}";
                var mlx = tx + (lx - tx) * 0.5;
                var mly = ty + (ly - ty) * 0.5;
                var mrx = tx + (rx - tx) * 0.5;
                var mry = ty + (ry - ty) * 0.5;
                var fillPts = $"{NexusHexHelpers.Fmt(mlx)},{NexusHexHelpers.Fmt(mly)} "
                        + $"{NexusHexHelpers.Fmt(tx)},{NexusHexHelpers.Fmt(ty)} "
                        + $"{NexusHexHelpers.Fmt(mrx)},{NexusHexHelpers.Fmt(mry)}";

                <polygon points="@fillPts" fill="@focusColor" fill-opacity="0.7" stroke="none" pointer-events="none" />
                <polyline points="@outlinePts" fill="none" stroke="@focusColor" stroke-width="2" stroke-linecap="round"
                          stroke-linejoin="round" pointer-events="none" />
            }
        }

        @* Pass 3: Move order chevrons *@
        @foreach (var order in PendingMoveOrders)
        {
            var from = NexusHexHelpers.HexCenter(order.From);
            var to = NexusHexHelpers.HexCenter(order.To);
            var dx = to.X - from.X;
            var dy = to.Y - from.Y;
            var len = Math.Sqrt(dx * dx + dy * dy);
            @if (len >= 1)
            {
                var ux = dx / len;
                var uy = dy / len;
                var px = -uy;
                var py = ux;
                var mx = (from.X + to.X) / 2.0;
                var my = (from.Y + to.Y) / 2.0;
                const double h = 4.5;
                const double w = 7;
                var chevronColor = CurrentPlayerFaction == NexusFactionColor.Red ? "#f87171" : "#60a5fa";
                var lx = mx - ux * h - px * w;
                var ly = my - uy * h - py * w;
                var tx = mx + ux * h;
                var ty = my + uy * h;
                var rx = mx - ux * h + px * w;
                var ry = my - uy * h + py * w;
                var outlinePts = $"{NexusHexHelpers.Fmt(lx)},{NexusHexHelpers.Fmt(ly)} "
                           + $"{NexusHexHelpers.Fmt(tx)},{NexusHexHelpers.Fmt(ty)} "
                           + $"{NexusHexHelpers.Fmt(rx)},{NexusHexHelpers.Fmt(ry)}";

                // Fill the forward half of the chevron by using arm midpoints toward the tip.
                var mlx = tx + (lx - tx) * 0.5;
                var mly = ty + (ly - ty) * 0.5;
                var mrx = tx + (rx - tx) * 0.5;
                var mry = ty + (ry - ty) * 0.5;
                var fillPts = $"{NexusHexHelpers.Fmt(mlx)},{NexusHexHelpers.Fmt(mly)} "
                        + $"{NexusHexHelpers.Fmt(tx)},{NexusHexHelpers.Fmt(ty)} "
                        + $"{NexusHexHelpers.Fmt(mrx)},{NexusHexHelpers.Fmt(mry)}";

                <polygon points="@fillPts" fill="@chevronColor" fill-opacity="0.7" stroke="none" pointer-events="none" />
                <polyline points="@outlinePts" fill="none" stroke="@chevronColor" stroke-width="2" stroke-linecap="round"
                          stroke-linejoin="round" pointer-events="none" />
            }
        }
    </svg>
</div>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<NexusSystemSnapshot> Systems { get; set; } = [];

    [Parameter, EditorRequired]
    public Guid CurrentPlayerId { get; set; }

    [Parameter]
    public Guid? OpponentPlayerId { get; set; }

    [Parameter]
    public NexusFactionColor CurrentPlayerFaction { get; set; }

    [Parameter]
    public NexusGateProgress CurrentPlayerGateProgress { get; set; }

    [Parameter]
    public bool IsEditable { get; set; }

    [Parameter]
    public IReadOnlyList<NexusMoveRequest> PendingMoveOrders { get; set; } = [];

    [Parameter]
    public HexCoord? SelectedSystem { get; set; }

    [Parameter]
    public IReadOnlyList<HexCoord> ValidMoveTargets { get; set; } = [];

    [Parameter]
    public IReadOnlyList<HexCoord> EventFocusSystems { get; set; } = [];

    [Parameter]
    public HexCoord? EventFocusFrom { get; set; }

    [Parameter]
    public HexCoord? EventFocusTo { get; set; }

    [Parameter]
    public EventCallback<HexCoord> OnSystemClicked { get; set; }

    [Parameter]
    public EventCallback OnMapBackgroundClicked { get; set; }

    private Task OnBackgroundClicked() => OnMapBackgroundClicked.InvokeAsync();

    private string ViewBox
    {
        get
        {
            if (Systems.Count == 0)
                return "-150 -140 300 280";

            const double pad = 10;
            var minX = double.MaxValue;
            var minY = double.MaxValue;
            var maxX = double.MinValue;
            var maxY = double.MinValue;

            foreach (var system in Systems)
            {
                var (cx, cy) = NexusHexHelpers.HexCenter(system.Coord);
                if (cx - NexusHexHelpers.HexSize < minX) minX = cx - NexusHexHelpers.HexSize;
                if (cy - NexusHexHelpers.HexSize < minY) minY = cy - NexusHexHelpers.HexSize;
                if (cx + NexusHexHelpers.HexSize > maxX) maxX = cx + NexusHexHelpers.HexSize;
                if (cy + NexusHexHelpers.HexSize > maxY) maxY = cy + NexusHexHelpers.HexSize;
            }

            var vx = NexusHexHelpers.Fmt(minX - pad);
            var vy = NexusHexHelpers.Fmt(minY - pad);
            var vw = NexusHexHelpers.Fmt(maxX - minX + pad * 2);
            var vh = NexusHexHelpers.Fmt(maxY - minY + pad * 2);
            return $"{vx} {vy} {vw} {vh}";
        }
    }
}
