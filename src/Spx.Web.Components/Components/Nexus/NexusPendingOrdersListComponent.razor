@if (!MoveOrders.Any() && !BuildOrders.Any() && !BeginNexusGate)
{
    <p class="text-base text-slate-500">No orders yet.</p>
}
else
{
    <ul class="space-y-2">
        @for (var index = 0; index < MoveOrders.Count; index++)
        {
            var order = MoveOrders[index];
            <li class="ui-list-item-row"
                data-testid="@NexusGameplayPanelTestIds.PendingMoveOrder(index, order.From, order.To)">
                <span class="flex flex-wrap items-center gap-x-1.5 gap-y-1 text-sm text-slate-300">
                    <span class="font-semibold text-slate-200">@GetSystemDisplayName(order.From)</span>
                    <span class="text-slate-500">→</span>
                    <span class="font-semibold text-slate-200">@GetSystemDisplayName(order.To)</span>
                    @foreach (var stack in order.Stacks)
                    {
                        var design = Designs.FirstOrDefault(d => d.DesignId == stack.DesignId);
                        <NexusUnitBadge Category="@stack.Category"
                                         DesignName="@stack.DesignName"
                                         Count="@stack.Count"
                                         RemainingHits="@stack.RemainingHits"
                                         Design="@design"
                                         FactionColor="@CurrentPlayer?.Faction" />
                    }
                </span>
                @if (IsEditable)
                {
                    <button class="ui-button-icon-danger" title="Remove order"
                            data-testid="@NexusGameplayPanelTestIds.PendingMoveOrderRemove(index, order.From, order.To)"
                            @onclick="() => OnPendingOrderRequested.InvokeAsync(PendingOrderRequest.MoveOrderRemovalRequested(order))">
                        ×
                    </button>
                }
            </li>
        }
        @foreach (var order in BuildOrders)
        {
            var designName = GetDesignName(order.DesignId);
            <li class="ui-list-item-row"
                data-testid="@NexusGameplayPanelTestIds.PendingBuildOrder(designName)">
                <span class="text-base text-slate-300">Build @order.Count× @designName</span>
                    @if (IsEditable)
                    {
                        <button class="ui-button-icon-danger" title="Remove order"
                                data-testid="@NexusGameplayPanelTestIds.PendingBuildOrderRemove(designName)"
                                @onclick="() => OnPendingOrderRequested.InvokeAsync(PendingOrderRequest.BuildOrderRemovalRequested(order))">
                            ×
                        </button>
                    }
                </li>
            }
            @if (BeginNexusGate)
            {
                <li class="ui-list-item-row"
                    data-testid="@NexusGameplayPanelTestIds.PendingGateOrder">
                    <span class="text-base text-slate-300">Begin Nexus Gate (@NexusEngine.GateCost⚡)</span>
                    @if (IsEditable)
                    {
                        <button class="ui-button-icon-danger" title="Remove order"
                                data-testid="@NexusGameplayPanelTestIds.PendingGateOrderRemove"
                                @onclick="() => OnPendingOrderRequested.InvokeAsync(PendingOrderRequest.NexusGateCleared())">
                            ×
                        </button>
                    }
                </li>
            }
        </ul>
    }

@code {
    [Parameter]
    public NexusPlayerContext? CurrentPlayer { get; set; }

    [Parameter]
    public HexCoord? CurrentPlayerHomeCoord { get; set; }

    [Parameter]
    public NexusPlayerContext? Opponent { get; set; }

    [Parameter]
    public HexCoord? OpponentPlayerHomeCoord { get; set; }

    [Parameter]
    public ImmutableArray<NexusUnitDesign> Designs { get; set; } = [];

    [Parameter, EditorRequired]
    public IReadOnlyList<NexusMoveOrder> MoveOrders { get; set; } = [];

    [Parameter, EditorRequired]
    public IReadOnlyList<NexusBuildOrder> BuildOrders { get; set; } = [];

    [Parameter]
    public bool BeginNexusGate { get; set; }

    [Parameter]
    public bool IsEditable { get; set; }

    [Parameter]
    public EventCallback<PendingOrderRequest> OnPendingOrderRequested { get; set; }

    private string GetDesignName(Guid designId)
    {
        var design = Designs.FirstOrDefault(d => d.DesignId == designId);
        return design?.Name ?? designId.ToString("N")[..8];
    }

    private string GetSystemDisplayName(HexCoord coord)
    {
        if (CurrentPlayerHomeCoord.HasValue && coord == CurrentPlayerHomeCoord.Value)
            return NexusHomeSystemNames.GetDisplayName(CurrentPlayer?.DisplayName ?? "Player");

        if (OpponentPlayerHomeCoord.HasValue && coord == OpponentPlayerHomeCoord.Value)
            return NexusHomeSystemNames.GetDisplayName(Opponent?.DisplayName ?? "Opponent");

        return NexusMapTopology.GetSectorDisplayName(coord);
    }
}
