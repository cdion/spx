<div class="grid gap-3 sm:grid-cols-3">
    <article class="ui-panel-row items-start">
        <div class="space-y-1">
            <p class="@NexusFactionCss.PlayerNameClass(CurrentPlayer.Faction)">@CurrentPlayer.PlayerName</p>
            <div class="flex gap-4">
                <p class="text-lg font-semibold text-yellow-400">⚡@CurrentPlayer.Energy</p>
                <p class="text-lg font-semibold text-sky-400">⬢@CurrentPlayer.SupplyPool</p>
            </div>
            <p class="text-sm text-slate-400">@CurrentPlayer.CapitalCount Capital</p>
        </div>
        <div class="flex flex-col items-end gap-1 pt-1">
            <StatusBadge Tone="@SubmissionTone(CurrentPlayer.HasSubmittedOrders)">
                @SubmissionLabel(CurrentPlayer.HasSubmittedOrders)</StatusBadge>
            </div>
        </article>

        <article class="ui-panel-row items-center justify-center">
            <div class="text-center">
                <p class="tracking-[0.2em] text-base font-semibold uppercase text-slate-300">Round</p>
                <p class="mt-1 text-3xl font-semibold text-white">@RoundNumber</p>
            </div>
        </article>

        <article class="ui-panel-row items-start">
            <div class="space-y-1">
                <p class="@NexusFactionCss.PlayerNameClass(Opponent.Faction)">@Opponent.PlayerName</p>
                <div class="flex gap-4">
                    <p class="text-lg font-semibold text-yellow-400">⚡@Opponent.Energy</p>
                    <p class="text-lg font-semibold text-sky-400">⬢@Opponent.SupplyPool</p>
                </div>
                <p class="text-sm text-slate-400">@Opponent.CapitalCount Capital</p>
            </div>
            <div class="flex flex-col items-end gap-1 pt-1">
                <StatusBadge Tone="@SubmissionTone(Opponent.HasSubmittedOrders)">@SubmissionLabel(Opponent.HasSubmittedOrders)
                </StatusBadge>
            </div>
        </article>
    </div>

@code {
    [Parameter]
    public int RoundNumber { get; set; }

    [Parameter, EditorRequired]
    public NexusPlayerInfoBarModel CurrentPlayer { get; set; } = default!;

    [Parameter, EditorRequired]
    public NexusPlayerInfoBarModel Opponent { get; set; } = default!;

    private static string SubmissionLabel(bool hasSubmittedOrders) =>
        hasSubmittedOrders ? "Orders in" : "Orders pending";

    private static StatusBadge.BadgeTone SubmissionTone(bool hasSubmittedOrders) =>
        hasSubmittedOrders ? StatusBadge.BadgeTone.Success : StatusBadge.BadgeTone.Warning;
}
