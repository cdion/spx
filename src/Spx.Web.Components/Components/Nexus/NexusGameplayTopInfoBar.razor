<div class="grid gap-3 sm:grid-cols-3">
    <article class="ui-panel-row items-start">
        <div class="space-y-1">
            <p class="@FactionCss.PlayerNameClass(CurrentPlayer.Faction)">@CurrentPlayer.PlayerName</p>
            <p class="text-2xl font-semibold text-yellow-400">@CurrentPlayer.Energy⚡</p>
            <p class="text-sm text-slate-300">@CurrentPlayer.CapitalCount / @CurrentPlayer.SupplyPool ⚓</p>
        </div>
        <div class="flex flex-col items-end gap-1 pt-1">
            <StatusBadge Tone="@SubmissionTone(CurrentPlayer.HasSubmittedOrders)">
                @SubmissionLabel(CurrentPlayer.HasSubmittedOrders)</StatusBadge>
            </div>
        </article>

        <article class="ui-panel-row items-center justify-center">
            <div class="text-center">
                <p class="text-base font-semibold uppercase text-slate-300" style="letter-spacing: 0.2em;">Round</p>
                <p class="mt-1 text-3xl font-semibold text-white">@RoundNumber</p>
            </div>
        </article>

        <article class="ui-panel-row items-start">
            <div class="space-y-1">
                <p class="@FactionCss.PlayerNameClass(Opponent.Faction)">@Opponent.PlayerName</p>
                <p class="text-2xl font-semibold text-yellow-400">@Opponent.Energy⚡</p>
                <p class="text-sm text-slate-300">@Opponent.CapitalCount / @Opponent.SupplyPool ⚓</p>
            </div>
            <div class="flex flex-col items-end gap-1 pt-1">
                <StatusBadge Tone="@SubmissionTone(Opponent.HasSubmittedOrders)">@SubmissionLabel(Opponent.HasSubmittedOrders)
                </StatusBadge>
            </div>
        </article>
    </div>

@code {
    [Parameter]
    public int RoundNumber { get; set; }

    [Parameter, EditorRequired]
    public PlayerInfoBarModel CurrentPlayer { get; set; } = default!;

    [Parameter, EditorRequired]
    public PlayerInfoBarModel Opponent { get; set; } = default!;

    private static string SubmissionLabel(bool hasSubmittedOrders) =>
        hasSubmittedOrders ? "Orders in" : "Orders pending";

    private static StatusBadge.BadgeTone SubmissionTone(bool hasSubmittedOrders) =>
        hasSubmittedOrders ? StatusBadge.BadgeTone.Success : StatusBadge.BadgeTone.Warning;
}
