@using System.Collections.Immutable
@using Spx.Nexus.Domain

<section class="ui-surface-section h-full min-h-0 space-y-4 overflow-y-auto p-3 lg:p-4">
    <div class="flex flex-wrap items-start justify-between gap-3">
        <div class="space-y-1">
            <div class="flex items-center gap-2">
                <p class="@GetSystemLabelClass()">@GetSystemLabel()</p>
                @if (System.IncomeValue > 0)
                {
                    <span class="ui-type-meta text-yellow-400/80">+@System.IncomeValue ⚡</span>
                }
                @if (System.HomePlayerId.HasValue)
                {
                    <span
                        class="inline-flex h-6 w-6 items-center justify-center rounded-full border border-white/15 bg-white/5"
                        aria-label="Home system">
                        <svg viewBox="-5 -5 10 10" class="h-3.5 w-3.5 fill-white/85" aria-hidden="true" focusable="false">
                            <polygon
                            points="0,-4 1.1,-1.5 3.8,-1.2 1.8,0.8 2.4,3.6 0,2.2 -2.4,3.6 -1.8,0.8 -3.8,-1.2 -1.1,-1.5" />
                        </svg>
                    </span>
                }
            </div>
        </div>
    </div>

    <div class="space-y-4">
        @* My fleet --- editable selection *@
        @if (_myStacks.Length > 0)
        {
            <section class="space-y-3">
                <div class="flex items-center gap-3">
                    <p class="ui-type-overline mb-1 @FactionCss.ForcesClass(CurrentPlayerFaction)">Fleet</p>
                    @if (IsEditable && HasSelection)
                    {
                        <span class="text-xs tabular-nums @(SelectionIsValid ? "text-slate-400" : "text-red-400")">Capacity:
                            @SlotsNeeded / @CarryCapacity</span>
                    }
                    @if (IsEditable)
                    {
                        <button type="button" class="text-xs text-slate-500 transition-colors hover:text-slate-300"
                                @onclick="@(HasSelection ? ClearSelectionAsync : SelectWholeFleetAsync)">
                            @(HasSelection ? "Clear" : "Select All")
                        </button>
                    }
                </div>

                <UnitStackList Stacks="@_myStacks"
                               DesignLookup="@_designLookupImmutable"
                               RowClass="ui-button-row-available"
                               ActiveRowClass="@FactionCss.ButtonActiveRow(CurrentPlayerFaction)"
                               StackNameClass="text-slate-200"
                               ActiveStackNameClass="@FactionCss.ActiveStackNameClass(CurrentPlayerFaction)"
                               SelectedCountClass="@FactionCss.SelectedCountClass(CurrentPlayerFaction)"
                               IsEditable="@IsEditable"
                               Selection="@_selection"
                               OnAdjustment="HandleStackAdjustment"
                               OnToggleWholeStack="HandleToggleWholeStack"
                               GetTestId="GetFleetTestId" />
            </section>
        }

        @if (_myStacks.Length == 0)
        {
            <div class="rounded-xl border border-white/10 bg-slate-950/35 p-3 text-base text-slate-500">No movable units in this system.</div>
        }

        @* My committed planetary --- read-only *@
        @if (_myCommittedStacks.Length > 0)
        {
            <section class="space-y-3 ui-panel-separator">
                <p class="ui-type-overline mb-1 @FactionCss.ForcesClass(CurrentPlayerFaction)">Your Committed Planetary</p>
                <UnitStackList Stacks="@_myCommittedStacks"
                               DesignLookup="@_designLookupImmutable"
                               RowClass="ui-button-row-available cursor-default"
                               HideGroupLabels="true" />
            </section>
        }

        @* Enemy fleet --- read-only *@
        @if (_enemyStacks.Length > 0)
        {
            <section class="space-y-3 ui-panel-separator">
                <p class="ui-type-overline mb-1 @FactionCss.ForcesClass(OpponentFactionColor)">Enemy Fleet</p>
                <UnitStackList Stacks="@_enemyStacks"
                               DesignLookup="@_designLookupImmutable"
                               RowClass="ui-button-row-available cursor-default"
                               HideGroupLabels="true" />
            </section>
        }

        @* Enemy committed planetary --- read-only *@
        @if (_enemyCommittedStacks.Length > 0)
        {
            <section class="space-y-3 ui-panel-separator">
                <p class="ui-type-overline mb-1 @FactionCss.ForcesClass(OpponentFactionColor)">Enemy Committed Planetary</p>
                <UnitStackList Stacks="@_enemyCommittedStacks"
                               DesignLookup="@_designLookupImmutable"
                               RowClass="ui-button-row-available cursor-default"
                               HideGroupLabels="true" />
            </section>
        }
    </div>

    @* Build orders *@
    @if (IsEditable && System.HomePlayerId == CurrentPlayerId)
    {
        <div class="space-y-2 ui-panel-separator">
            <p class="text-base font-semibold text-slate-300">Build units</p>
            <div class="grid gap-2">
                @foreach (var group in UnitGroups)
                {
                    <div class="ui-panel-card-tight">
                        <p class="mb-1 text-base font-semibold uppercase tracking-wide text-slate-400">
                    <CategoryPip Category="group.Category" Size="PipSize.Small" /> @group.Label
                </p>
                        <div class="space-y-1">
                            @foreach (var design in PlayerDesigns.Where(d => d.Hull == group.Category))
                            {
                                var cost = NexusHullBaselines.GetProfile(design).Cost;
                                var count = PendingBuildOrders.FirstOrDefault(o => o.DesignId == design.DesignId)?.Count ?? 0;
                                var canAdd = ProjectedEnergy >= cost;

                                <button type="button" class="@GetBuildRowClass(design, count, canAdd)"
                                        data-testid="@GetBuildButtonTestId(design)" @onclick="e => OnBuildRowClickAsync(design, e)"
                                        @ondblclick="() => OnOrderDraftRequested.InvokeAsync(OrderDraftRequest.BuildDraftAdjusted(design.DesignId, BuildDraftAdjustmentKind.AddMax))"
                                        @oncontextmenu:preventDefault="true"
                                        @oncontextmenu="() => OnOrderDraftRequested.InvokeAsync(OrderDraftRequest.BuildDraftAdjusted(design.DesignId, BuildDraftAdjustmentKind.RemoveOne))">
                                    <span class="min-w-0 flex-1 whitespace-nowrap text-base text-slate-100">@design.Name <span class="ml-1 text-yellow-400">@cost ⚡</span></span>
                                    <span class="shrink-0 whitespace-nowrap pl-3 text-base text-slate-400">@count</span>
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* Nexus gate *@
    @if (IsEditable && CanShowGateOption)
    {
        <div class="space-y-2 ui-panel-separator">
            <p class="text-base font-semibold text-slate-300">Nexus Gate</p>
            <button class="@GateButtonClass" data-testid="@NexusGameplayPanelTestIds.NexusGateDraftToggle"
                    @onclick="OnNexusGateDraftChangedAsync" disabled="@(!CanAffordGate && !PendingBeginNexusGate)">
                <span>Begin Nexus Gate</span>
                <span class="text-yellow-400">@NexusEngine.GateCost ⚡</span>
            </button>
        </div>
    }
</section>

@code {
    private static readonly (NexusUnitCategory Category, string Label)[] UnitGroups =
    [
        (NexusUnitCategory.Strike, "Strike"),
        (NexusUnitCategory.Capital, "Capital"),
        (NexusUnitCategory.Planetary, "Planetary"),
    ];

    [Parameter, EditorRequired]
    public NexusSystemView System { get; set; } = default!;

    [Parameter, EditorRequired]
    public Guid CurrentPlayerId { get; set; }

    [Parameter]
    public string CurrentPlayerName { get; set; } = "You";

    [Parameter]
    public Guid? OpponentPlayerId { get; set; }

    [Parameter]
    public string OpponentPlayerName { get; set; } = "Opponent";

    [Parameter]
    public NexusFactionColor CurrentPlayerFaction { get; set; }

    [Parameter]
    public NexusGateProgress CurrentPlayerGateProgress { get; set; }

    [Parameter]
    public bool PendingBeginNexusGate { get; set; }

    [Parameter]
    public bool IsEditable { get; set; }

    [Parameter]
    public int ProjectedEnergy { get; set; }

    [Parameter]
    public ImmutableArray<NexusUnitStackGroup> AvailableStacks { get; set; } = [];

    [Parameter]
    public IReadOnlyList<NexusBuildOrder> PendingBuildOrders { get; set; } = [];

    [Parameter]
    public ImmutableArray<NexusUnitDesign> PlayerDesigns { get; set; } = [];

    [Parameter]
    public ImmutableArray<NexusUnitDesign> OpponentDesigns { get; set; } = [];

    [Parameter]
    public EventCallback<OrderDraftRequest> OnOrderDraftRequested { get; set; }

    private readonly Dictionary<UnitStackList.StackKey, int> _selection = [];
    private ImmutableDictionary<Guid, NexusUnitDesign> _designLookupImmutable = ImmutableDictionary<Guid, NexusUnitDesign>.Empty;
    private Dictionary<Guid, NexusUnitDesign> _designLookup = [];
    private HexCoord _previousCoord;
    private ImmutableArray<NexusUnitStackGroup> _myStacks = [];
    private ImmutableArray<NexusUnitStackGroup> _myCommittedStacks = [];
    private ImmutableArray<NexusUnitStackGroup> _enemyStacks = [];
    private ImmutableArray<NexusUnitStackGroup> _enemyCommittedStacks = [];

    private int CarryCapacity => SelectedStacks.Sum(stack =>
    {
        if (!_designLookup.TryGetValue(stack.DesignId, out var d)) return 0;
        return NexusHullBaselines.GetProfile(d).CarryCapacity * stack.Count;
    });

    private int SlotsNeeded => SelectedStacks.Sum(stack =>
    {
        if (!_designLookup.TryGetValue(stack.DesignId, out var d)) return 0;
        return NexusHullBaselines.GetProfile(d).RequiresCarrier ? stack.Count : 0;
    });

    private bool HasSelection => _selection.Values.Any(value => value > 0);

    private IEnumerable<NexusUnitStackGroup> SelectedStacks => _myStacks
        .Select(stack => stack with { Count = _selection.GetValueOrDefault(new UnitStackList.StackKey(stack.DesignId, stack.RemainingHits)) })
        .Where(stack => stack.Count > 0);

    private bool SelectionIsValid => HasSelection && SlotsNeeded <= CarryCapacity;

    private bool CanShowGateOption =>
        CurrentPlayerGateProgress != NexusGateProgress.Completed
        && System.IsNexus
        && System.GetPlayerStacks(CurrentPlayerId).Any(stack => stack.Category == NexusUnitCategory.Planetary && stack.Count > 0)
        && (!OpponentPlayerId.HasValue || System.GetPlayerStacks(OpponentPlayerId.Value).Length == 0);

    private bool CanAffordGate => ProjectedEnergy >= NexusEngine.GateCost;

    private NexusFactionColor OpponentFactionColor =>
        CurrentPlayerFaction == NexusFactionColor.Red ? NexusFactionColor.Blue : NexusFactionColor.Red;

    private string GateButtonClass =>
        PendingBeginNexusGate
            ? "ui-button-control-info flex w-full justify-between gap-2"
            : CanAffordGate
                ? "ui-button-control flex w-full justify-between gap-2"
                : "ui-button-row-disabled flex w-full justify-between gap-2";

    private string GetSystemLabel() => NexusMapTopology.GetSectorDisplayName(System.Coord);

    private string GetSystemLabelClass()
    {
        if (!System.HomePlayerId.HasValue)
        {
            if (System.ControlOwner == CurrentPlayerId)
                return FactionCss.AccentText(CurrentPlayerFaction);

            if (OpponentPlayerId.HasValue && System.ControlOwner == OpponentPlayerId.Value)
                return FactionCss.AccentText(OpponentFactionColor);

            return "ui-panel-label";
        }

        if (System.HomePlayerId == CurrentPlayerId)
            return FactionCss.AccentText(CurrentPlayerFaction);

        if (OpponentPlayerId.HasValue && System.HomePlayerId == OpponentPlayerId.Value)
            return FactionCss.AccentText(OpponentFactionColor);

        return "ui-panel-label";
    }

    protected override async Task OnParametersSetAsync()
    {
        _designLookup = PlayerDesigns.Concat(OpponentDesigns)
            .GroupBy(d => d.DesignId)
            .ToDictionary(g => g.Key, g => g.First());
        _designLookupImmutable = _designLookup.ToImmutableDictionary();
        _myStacks = AvailableStacks;
        var isContested =
            OpponentPlayerId.HasValue
            && System.GetPlayerStacks(CurrentPlayerId).Length > 0
            && System.GetPlayerStacks(OpponentPlayerId.Value).Length > 0;
        _myCommittedStacks = isContested
            ? System
                .GetPlayerStacks(CurrentPlayerId)
                .Where(s => s.Category == NexusUnitCategory.Planetary)
                .ToImmutableArray()
            : ImmutableArray<NexusUnitStackGroup>.Empty;
        _enemyStacks = OpponentPlayerId.HasValue
            ? System.GetPlayerMovableStacks(OpponentPlayerId.Value)
            : [];
        _enemyCommittedStacks =
            isContested && OpponentPlayerId.HasValue
                ? System
                    .GetPlayerStacks(OpponentPlayerId.Value)
                    .Where(s => s.Category == NexusUnitCategory.Planetary)
                    .ToImmutableArray()
                : ImmutableArray<NexusUnitStackGroup>.Empty;

        if (_previousCoord != System.Coord)
        {
            _selection.Clear();
            _previousCoord = System.Coord;
            await PublishSelectionAsync();
            return;
        }

        var changed = false;
        foreach (var stackKey in _selection.Keys.ToList())
        {
            var available = GetAvailableCount(stackKey);
            var next = Math.Clamp(_selection[stackKey], 0, available);

            if (next <= 0)
            {
                _selection.Remove(stackKey);
                changed = true;
            }
            else if (next != _selection[stackKey])
            {
                _selection[stackKey] = next;
                changed = true;
            }
        }

        if (changed)
            await PublishSelectionAsync();
    }

    private int GetAvailableCount(UnitStackList.StackKey stackKey) =>
        _myStacks
            .Where(stack => stack.DesignId == stackKey.DesignId && stack.RemainingHits == stackKey.RemainingHits)
            .Sum(stack => stack.Count);

    private Task HandleToggleWholeStack(UnitStackList.StackKey stackKey)
    {
        var available = GetAvailableCount(stackKey);
        if (available <= 0)
            return Task.CompletedTask;

        var current = _selection.GetValueOrDefault(stackKey);
        if (current >= available)
            _selection.Remove(stackKey);
        else
            _selection[stackKey] = available;

        return PublishSelectionAsync();
    }

    private Task HandleStackAdjustment(UnitStackList.StackAdjustment adjustment)
    {
        var available = GetAvailableCount(adjustment.Key);
        if (available <= 0)
            return Task.CompletedTask;

        var next = Math.Clamp(_selection.GetValueOrDefault(adjustment.Key) + adjustment.Delta, 0, available);
        if (next <= 0)
            _selection.Remove(adjustment.Key);
        else
            _selection[adjustment.Key] = next;

        return PublishSelectionAsync();
    }

    private Task SelectWholeFleetAsync()
    {
        _selection.Clear();
        foreach (var stack in _myStacks)
        {
            _selection[new UnitStackList.StackKey(stack.DesignId, stack.RemainingHits)] = stack.Count;
        }

        return PublishSelectionAsync();
    }

    private Task ClearSelectionAsync()
    {
        if (_selection.Count == 0)
            return Task.CompletedTask;

        _selection.Clear();
        return PublishSelectionAsync();
    }

    private string GetBuildRowClass(NexusUnitDesign design, int count, bool canAdd)
    {
        if (count > 0)
            return FactionCss.ButtonActiveRow(CurrentPlayerFaction);

        if (!canAdd)
            return "ui-button-row-disabled";

        return "ui-button-row-available";
    }

    private Task OnBuildRowClickAsync(NexusUnitDesign design, MouseEventArgs e)
    {
        if (e.ShiftKey)
        {
            return OnOrderDraftRequested.InvokeAsync(
                OrderDraftRequest.BuildDraftAdjusted(design.DesignId, BuildDraftAdjustmentKind.RemoveAll)
            );
        }

        return OnOrderDraftRequested.InvokeAsync(
            OrderDraftRequest.BuildDraftAdjusted(design.DesignId, BuildDraftAdjustmentKind.AddOne)
        );
    }

    private Task PublishSelectionAsync()
    {
        if (!SelectionIsValid)
        {
            return OnOrderDraftRequested.InvokeAsync(
                OrderDraftRequest.MoveDraftChanged(ImmutableArray<NexusUnitStackGroup>.Empty)
            );
        }

        return OnOrderDraftRequested.InvokeAsync(
            OrderDraftRequest.MoveDraftChanged(SelectedStacks.ToImmutableArray())
        );
    }

    private Task OnNexusGateDraftChangedAsync() =>
        OnOrderDraftRequested.InvokeAsync(
            OrderDraftRequest.NexusGateDraftChanged(!PendingBeginNexusGate)
        );

    private static string GetFleetTestId(NexusUnitStackGroup stack) =>
        NexusGameplayPanelTestIds.FleetStack(stack.DesignName, stack.RemainingHits);

    private static string GetBuildButtonTestId(NexusUnitDesign design) =>
        NexusGameplayPanelTestIds.BuildUnit(design.Name);
}
