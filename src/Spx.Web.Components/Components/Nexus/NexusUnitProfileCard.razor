<div class="w-56 space-y-2 rounded-xl border border-white/15 bg-slate-900 p-3 text-sm shadow-xl">
    <div class="flex items-center gap-1.5">
        <NexusCategoryPip Category="Category" Size="NexusPipSize.Small" />
        <span class="ui-type-overline">@HullLabel</span>
        <span class="font-semibold text-slate-200">@Name</span>
    </div>

    @{
        var baseline = NexusHullBaselines.GetBaseline(Category);
        var profile = NexusHullBaselines.GetProfile(Design);
    }
    <dl class="space-y-1">
        @StatRow("Hits", baseline.Hits, profile.Hits, isCost: false)
        @StatRow("Move", baseline.Move, profile.Move, isCost: false)
        @StatRow("Silhouette", baseline.Silhouette, profile.Silhouette, isCost: false)
        @StatRow("Cost", baseline.Cost, profile.Cost, isCost: true)
    </dl>

    @if (profile.Attacks.Count > 0)
    {
        <div class="border-t border-white/10 pt-2">
            <p class="ui-type-overline mb-1">Attacks</p>
            <ul class="space-y-0.5">
                @foreach (var (cat, spec) in profile.Attacks)
                {
                    var label = NexusDomainLabels.GetHullLabel(cat);
                    var timing = spec.Contact > 0 && spec.Battle > 0
                        ? "Contact+Battle"
                        : spec.Contact > 0 ? "Contact" : "Battle";
                    var count = spec.Battle + spec.Contact;
                    <li class="text-xs text-slate-300">
                        @count×
                        <span class="font-semibold text-slate-200">vs @label</span>
                        @spec.Threshold+
                        <span class="text-slate-500">(@timing)</span>
                    </li>
                }
            </ul>
        </div>
    }

    @if (Design.Modules.Count > 0)
    {
        <div class="border-t border-white/10 pt-2">
            <p class="ui-type-overline mb-1">Modules</p>
            <ul class="space-y-0.5">
                @foreach (var module in Design.Modules)
                {
                    <li class="text-xs text-slate-300">@GetModuleLabel(module)</li>
                }
            </ul>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public NexusUnitCategory Category { get; set; }

    [Parameter, EditorRequired]
    public NexusUnitDesign Design { get; set; } = default!;

    [Parameter, EditorRequired]
    public string Name { get; set; } = "";

    private string HullLabel => NexusDomainLabels.GetHullLabel(Category);

    private RenderFragment StatRow(string label, int baseVal, int finalVal, bool isCost)
    {
        var mods = finalVal - baseVal;
        var finalClass = isCost ? "text-yellow-400" : "text-slate-100";
        var suffix = isCost ? "⚡" : "";
        if (mods == 0)
        {
            return @<div class="flex justify-between gap-3">
                <dt class="text-slate-400">@label</dt>
                <dd class="tabular-nums"><span class="@finalClass">@finalVal@suffix</span></dd>
            </div>;
        }
        var modsClass = mods > 0 ? "text-green-400" : "text-red-400";
        var modsStr = mods > 0 ? $"+{mods}" : mods.ToString();
        return @<div class="flex justify-between gap-3">
            <dt class="text-slate-400">@label</dt>
            <dd class="tabular-nums">
                <span class="text-slate-500">@baseVal</span>
                <span class="@modsClass">@modsStr</span>
                → <span class="@finalClass">@finalVal@suffix</span>
            </dd>
        </div>;
    }

    private static string GetModuleLabel(NexusUnitModule module) =>
        NexusDomainLabels.GetModuleLabel(module);
}
