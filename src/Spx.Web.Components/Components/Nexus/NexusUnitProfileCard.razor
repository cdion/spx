<div class="w-56 space-y-2 rounded-xl border border-white/15 bg-slate-900 p-3 text-sm shadow-xl">
    <div>
        <span class="ui-type-overline mr-2">@HullLabel</span>
        <span class="font-semibold text-slate-200">@Name</span>
    </div>

    @{
        var baseline = NexusHullBaselines.GetBaseline(Category);
    }

    @{
        var profile = NexusHullBaselines.GetProfile(Design);
    }
    <dl class="space-y-1">
        @((MarkupString)StatRow("Hits", baseline.Hits, profile.Hits))
        @((MarkupString)StatRow("Move", baseline.Move, profile.Move))
        @((MarkupString)StatRow("Attacks", baseline.Attacks, profile.Attacks))
        @((MarkupString)ThresholdRow(profile.HitThreshold))
        @((MarkupString)StatRow("Silhouette", baseline.Silhouette, profile.Silhouette))
        @((MarkupString)CostRow(baseline.Cost, profile.Cost))
    </dl>

    @if (Design.Modules.Count > 0)
    {
        <div class="border-t border-white/10 pt-2">
            <p class="ui-type-overline mb-1">Modules</p>
            <ul class="space-y-0.5">
                @foreach (var module in Design.Modules)
                {
                    <li class="text-xs text-slate-300">@GetModuleLabel(module)</li>
                }
            </ul>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public NexusUnitCategory Category { get; set; }

    [Parameter, EditorRequired]
    public NexusUnitDesign Design { get; set; } = default!;

    [Parameter, EditorRequired]
    public string Name { get; set; } = "";

    private string HullLabel => NexusDomainLabels.GetHullLabel(Category);

    private static string StatRow(string label, int baseVal, int finalVal)
    {
        if (baseVal == finalVal)
            return $"<div class='flex justify-between gap-3'><dt class='text-slate-400'>{label}</dt><dd class='tabular-nums text-slate-200'>{finalVal}</dd></div>";

        var delta = finalVal - baseVal;
        var deltaClass = delta > 0 ? "text-green-400" : "text-red-400";
        var deltaStr = (delta > 0 ? "+" : "") + delta;
        return $"<div class='flex justify-between gap-3'><dt class='text-slate-400'>{label}</dt>"
            + $"<dd class='tabular-nums'><span class='text-slate-400'>{baseVal}</span> <span class='{deltaClass}'>{deltaStr}</span> <span class='text-slate-200'>= {finalVal}</span></dd></div>";
    }

    private static string ThresholdRow(int threshold) =>
        $"<div class='flex justify-between gap-3'><dt class='text-slate-400'>To Hit</dt><dd class='tabular-nums text-slate-200'>{threshold}+</dd></div>";

    private static string CostRow(int baseVal, int finalVal)
    {
        if (baseVal == finalVal)
            return $"<div class='flex justify-between gap-3'><dt class='text-slate-400'>Cost</dt><dd class='tabular-nums text-yellow-400'>{finalVal}⚡</dd></div>";

        var delta = finalVal - baseVal;
        return $"<div class='flex justify-between gap-3'><dt class='text-slate-400'>Cost</dt>"
            + $"<dd class='tabular-nums'><span class='text-slate-400'>{baseVal}</span>"
            + $" <span class='text-yellow-400/60'>+{delta}</span>"
            + $" <span class='text-yellow-400'>= {finalVal}⚡</span></dd></div>";
    }

    private static string GetModuleLabel(NexusUnitModule module) =>
        NexusDomainLabels.GetModuleLabel(module);
}
