@using System.Collections.Immutable

@if (!string.IsNullOrWhiteSpace(GameplayError))
{
    <AlertBanner>@FormattedGameplayError</AlertBanner>
}

<NexusGameplayTopInfoBar RoundNumber="@Session.RoundNumber" CurrentPlayerName="@CurrentPlayerName"
                         OpponentPlayerName="@OpponentPlayerName" CurrentPlayerFaction="@Session.CurrentPlayer.Faction"
                         CurrentPlayerEnergy="@Session.CurrentPlayer.Energy" CurrentPlayerSupplyPool="@Session.CurrentPlayer.SupplyPool"
                         CurrentPlayerCapitalCount="@Session.CurrentPlayer.CapitalCount"
                         CurrentPlayerHasSubmittedOrders="@Session.CurrentPlayer.HasSubmittedOrders"
                         OpponentFaction="@Session.Opponent.Faction" OpponentPlayerEnergy="@Session.Opponent.Energy"
                         OpponentSupplyPool="@Session.Opponent.SupplyPool" OpponentCapitalCount="@Session.Opponent.CapitalCount"
                         OpponentHasSubmittedOrders="@Session.Opponent.HasSubmittedOrders" />

@if (Session.Completion is not null)
{
    <AlertBanner Tone="AlertBanner.AlertTone.Success" Role="status">
        @GetCompletionMessage()

    </AlertBanner>
}

@* Main layout *@
<div class="mt-4 flex min-h-0 flex-col gap-4 xl:flex-row">
    <section class="ui-surface-section flex min-h-0 min-w-0 flex-col p-4 lg:p-5 xl:flex-[3_1_0%]">
        <div class="min-h-0 flex-1">
            <NexusHexGridComponent Systems="@Session.Systems" CurrentPlayerId="@Session.CurrentPlayer.PlayerId"
                                   OpponentPlayerId="@Session.Opponent.PlayerId" CurrentPlayerFaction="@Session.CurrentPlayer.Faction"
                                   CurrentPlayerGateProgress="@Session.CurrentPlayer.GateProgress"
                                   OpponentGateProgress="@Session.Opponent.GateProgress" IsEditable="@ShowOrdersForm"
                                   PendingMoveOrders="@_orderDraftState.PendingMoveOrders" SelectedSystem="@_selectionState.SelectedSystem"
                                   ValidMoveTargets="@_selectionState.ValidMoveTargets" EventFocusSystems="@ActiveEventFocusSystems"
                                   EventFocusFrom="@ActiveEventFocusFrom" EventFocusTo="@ActiveEventFocusTo"
                                   OnSelectionRequested="HandleSelectionRequest" />
        </div>
    </section>

    <aside class="flex min-h-0 min-w-0 flex-col gap-4 xl:flex-[2_1_0%]">
        <div class="min-h-0 flex-1">
            <NexusSidebarPanelShell>
                <HeaderContent>
                    @if (!HideTabHeader)
                    {
                        <Tabs TItem="NexusGameplayTab" Items="@SidebarTabs" SelectedItem="@_sidebarState.ActiveTab"
                              ItemIdSelector="GetSidebarTabId" PanelIdSelector="GetSidebarPanelId"
                              ActiveItemClass="ui-tab-button-lg-active" InactiveItemClass="ui-tab-button-lg"
                              ItemLabelSelector="GetSidebarTabLabel" DisabledSelector="IsSidebarTabDisabled"
                              OnSelected="SetTab" AriaLabel="Sidebar view" />
                    }
                </HeaderContent>
                <ChildContent>
                    <div id="@ActiveSidebarPanelId" role="tabpanel" aria-labelledby="@ActiveSidebarTabId">
                        @if (_sidebarState.ActiveTab == NexusGameplayTab.Events)
                        {
                            <NexusResolveEventsPanel Events="@Session.LastResolveEvents" PlayerNames="@GetPlayerNames()"
                                                     CurrentPlayerName="@CurrentPlayerName" OpponentPlayerName="@OpponentPlayerName"
                                                     ViewingPlayerId="@Session.CurrentPlayer.PlayerId" RowClassSelector="GetEventRowClass"
                                                     RowStateSelector="GetEventRowState" OnEventFocusRequested="HandleEventFocusRequest" />
                        }
                        else if (_sidebarState.ActiveTab == NexusGameplayTab.Designs)
                        {
                            <NexusDesignEditorPanel Designs="@(Session.CurrentPlayer.Designs ?? [])"
                                                    IsSubmitting="@IsSubmittingAction"
                                                    PlayerId="@Session.CurrentPlayer.PlayerId"
                                                    OnCreateDesign="OnCreateDesign"
                                                    OnDeleteDesign="OnDeleteDesign" />
                        }
                        else
                        {
                            <div class="space-y-4">
                                @if (_selectionState.SelectedSystem.HasValue && Session.Systems.FirstOrDefault(s => s.Coord
                            ==
                            _selectionState.SelectedSystem.Value) is { } selectedSystem)
                                {
                                    <NexusSelectedHexPanel System="selectedSystem"
                                                           CurrentPlayerId="@Session.CurrentPlayer.PlayerId" CurrentPlayerName="@CurrentPlayerName"
                                                           OpponentPlayerId="@Session.Opponent.PlayerId"
                                                           CurrentPlayerFaction="@Session.CurrentPlayer.Faction"
                                                           OpponentPlayerName="@OpponentPlayerName"
                                                           CurrentPlayerGateProgress="@Session.CurrentPlayer.GateProgress"
                                                           PendingBeginNexusGate="@_orderDraftState.PendingBeginNexusGate"
                                                           IsEditable="@ShowOrdersForm" ProjectedEnergy="@ProjectedEnergy"
                                                           AvailableStacks="@GetAvailableMoveStacks(selectedSystem.Coord)"
                                                           PendingBuildOrders="@_orderDraftState.PendingBuildOrders"
                                                           PlayerDesigns="@(Session.CurrentPlayer.Designs ?? [])"
                                                           OnOrderDraftRequested="HandleOrderDraftRequest" />
                                }
                                @if (_orderDraftState.PendingMoveOrders.Length > 0 ||
                            _orderDraftState.PendingBuildOrders.Length > 0 ||
                            _orderDraftState.PendingBeginNexusGate)
                                {
                                    <NexusOrdersPanel MoveOrders="@_orderDraftState.PendingMoveOrders"
                                                      BuildOrders="@_orderDraftState.PendingBuildOrders"
                                                      Designs="@(Session.CurrentPlayer.Designs ?? [])"
                                                      CurrentPlayerName="@CurrentPlayerName" CurrentPlayerHomeCoord="@CurrentPlayerHomeCoord"
                                                      OpponentPlayerName="@OpponentPlayerName"
                                                      OpponentPlayerHomeCoord="@OpponentPlayerHomeCoord"
                                                      BeginNexusGate="@_orderDraftState.PendingBeginNexusGate" IsEditable="@ShowOrdersForm"
                                                      OnPendingOrderRequested="HandlePendingOrderRequest" />
                                }
                            </div>
                        }
                    </div>
                </ChildContent>
            </NexusSidebarPanelShell>
        </div>
        @if (ShowOrdersForm)
        {
            <button class="ui-button-primary w-full" data-testid="@NexusGameplayPanelTestIds.SubmitOrdersButton"
                    @onclick="SubmitOrdersAsync" disabled="@IsSubmittingAction">
                @(IsSubmittingAction ? "Submitting..." : "Submit Orders")
            </button>
        }
    </aside>
</div>

@code {
    [Parameter, EditorRequired]
    public NexusGameView Session { get; set; } = default!;

    [Parameter, EditorRequired]
    public GameLobbyView Lobby { get; set; } = default!;

    [Parameter]
    public bool IsSubmittingAction { get; set; }

    [Parameter]
    public string? GameplayError { get; set; }

    [Parameter]
    public EventCallback<NexusTurnOrdersCommand> OnSubmitOrders { get; set; }

    [Parameter]
    public EventCallback<NexusCreateDesignCommand> OnCreateDesign { get; set; }

    [Parameter]
    public EventCallback<Guid> OnDeleteDesign { get; set; }

    [Parameter]
    public EventCallback GameplayErrorCleared { get; set; }

    [Parameter]
    public NexusGameplayTab? SelectedTab { get; set; }

    [Parameter]
    public bool HideTabHeader { get; set; }

    private Guid? _lastKnownGameId;
    private Guid? _lastKnownCurrentPlayerId;
    private int? _lastKnownRound;
    private static readonly NexusGameplayTab[] SidebarTabs = [NexusGameplayTab.Orders, NexusGameplayTab.Designs, NexusGameplayTab.Events];
    private OrderDraftState _orderDraftState = OrderDraftState.Empty;
    private SelectionState _selectionState = SelectionState.Empty;
    private SidebarState _sidebarState = SidebarState.Default;
    private EventFocusState _eventFocusState = EventFocusState.Empty;

    protected override void OnParametersSet()
    {
        if (!NexusGameplayPanelState.ShouldResetUiState(
                Session.GameId,
                Session.CurrentPlayer.PlayerId,
                Session.RoundNumber,
                _lastKnownGameId,
                _lastKnownCurrentPlayerId,
                _lastKnownRound
            ))
            return;

        _lastKnownGameId = Session.GameId;
        _lastKnownCurrentPlayerId = Session.CurrentPlayer.PlayerId;
        _lastKnownRound = Session.RoundNumber;
        _orderDraftState = OrderDraftState.Empty;
        _selectionState = SelectionState.Empty;
        _sidebarState = SidebarState.Default;
        _eventFocusState = EventFocusState.Empty;

        if (Session.LastResolveEvents.Length == 0)
        {
            _sidebarState = NexusGameplayPanelState.SetActiveSidebarTab(_sidebarState, NexusGameplayTab.Orders);
        }

        if (Session.LastResolveEvents.Length > 0)
        {
            _sidebarState = NexusGameplayPanelState.SetActiveSidebarTab(_sidebarState, NexusGameplayTab.Events);
        }

        ApplySelectedTabOverride();

        return;

        void ApplySelectedTabOverride()
        {
            if (!SelectedTab.HasValue)
            {
                return;
            }

            _sidebarState = NexusGameplayPanelState.SetActiveSidebarTab(
                _sidebarState,
                IsSidebarTabDisabled(SelectedTab.Value)
                    ? NexusGameplayTab.Orders
                    : SelectedTab.Value
            );
        }
    }

    private bool ShowOrdersForm =>
        Lobby.IsCurrentUserActive
        && !Session.CurrentPlayer.HasSubmittedOrders
        && Session.Completion is null;

    private string CurrentPlayerName => Lobby.CurrentPlayerName;

    private string OpponentPlayerName =>
        Lobby.Players.FirstOrDefault(p => p.PlayerId != Lobby.CurrentPlayerId)?.Name
        ?? "your opponent";

    private HexCoord? CurrentPlayerHomeCoord =>
        Session.Systems.FirstOrDefault(s => s.HomePlayerId == Session.CurrentPlayer.PlayerId)?.Coord;

    private HexCoord? OpponentPlayerHomeCoord =>
        Session.Systems.FirstOrDefault(s => s.HomePlayerId == Session.Opponent.PlayerId)?.Coord;

    private string? FormattedGameplayError =>
        GameplayError is null
            ? null
            : NexusHomeSystemNames.ReplacePerspectiveLabels(
                GameplayError,
                CurrentPlayerName,
                OpponentPlayerName
            );

    private IReadOnlyDictionary<Guid, string> GetPlayerNames() =>
        new Dictionary<Guid, string>
        {
            [Session.CurrentPlayer.PlayerId] = CurrentPlayerName,
            [Session.Opponent.PlayerId] = OpponentPlayerName,
        };

    private void HandleSelectionRequest(SelectionRequest request)
    {
        DismissEventFocus();
        ClearParentGameplayError();

        if (request.Kind == SelectionRequestKind.ClearSelection)
        {
            _selectionState = NexusGameplayPanelState.ClearSelection(_selectionState);
            return;
        }

        _sidebarState = NexusGameplayPanelState.SetActiveSidebarTab(
            _sidebarState,
            NexusGameplayTab.Orders
        );

        _selectionState = _selectionState with { EventFocusOwnsSelection = false };

        var coord = request.System!.Value;
        if (_selectionState.SelectedSystem.HasValue
            && !_selectionState.StagedMoveStacks.IsDefaultOrEmpty
            && _selectionState.ValidMoveTargets.Contains(coord))
        {
            _orderDraftState = NexusGameplayPanelState.QueueMoveOrder(
                _orderDraftState,
                _selectionState.SelectedSystem.Value,
                coord,
                _selectionState.StagedMoveStacks
            );
            _selectionState = _selectionState with
            {
                StagedMoveStacks = ImmutableArray<NexusUnitStackGroup>.Empty,
                ValidMoveTargets = [],
            };
            return;
        }

        _selectionState = NexusGameplayPanelState.ApplySelectionRequest(_selectionState, request);
    }

    private void HandleOrderDraftRequest(OrderDraftRequest request)
    {
        ClearParentGameplayError();

        switch (request.Kind)
        {
            case OrderDraftRequestKind.MoveDraftChanged:
                _selectionState = NexusGameplayPanelState.ApplyMoveDraft(
                    _selectionState,
                    request.MoveDraftStacks.IsDefault
                        ? ImmutableArray<NexusUnitStackGroup>.Empty
                        : request.MoveDraftStacks,
                    Session,
                    Session.CurrentPlayer.PlayerId
                );
                return;
            case OrderDraftRequestKind.BuildDraftAdjusted:
                _orderDraftState = NexusGameplayPanelState.ApplyBuildDraftAdjustment(
                    _orderDraftState,
                    request.DesignId!.Value,
                    request.BuildAdjustment!.Value,
                    ProjectedEnergy,
                    Session.CurrentPlayer.Designs ?? []
                );
                return;
            case OrderDraftRequestKind.NexusGateDraftChanged:
                ApplyNexusGateDraft(request.BeginNexusGate ?? false);
                return;
        }
    }

    private void HandlePendingOrderRequest(PendingOrderRequest request)
    {
        ClearParentGameplayError();
        _orderDraftState = NexusGameplayPanelState.ApplyPendingOrderRequest(_orderDraftState, request);
    }

    private void ApplyNexusGateDraft(bool beginNexusGate)
    {
        if (!beginNexusGate)
        {
            _orderDraftState = NexusGameplayPanelState.SetNexusGateDraft(_orderDraftState, false);
            return;
        }

        if (_selectionState.SelectedSystem is null || !CanShowGateOption(_selectionState.SelectedSystem.Value))
            return;

        _orderDraftState = NexusGameplayPanelState.SetNexusGateDraft(_orderDraftState, true);
    }

    private bool CanShowGateOption(HexCoord coord)
    {
        if (Session.CurrentPlayer.GateProgress == NexusGateProgress.Completed)
            return false;

        var system = Session.Systems.FirstOrDefault(s => s.Coord == coord);
        if (system is null || !system.IsNexus)
            return false;

        var (_, _, planetary) = NexusHexHelpers.GetUnitCounts(system, Session.CurrentPlayer.PlayerId);
        return planetary > 0 && !IsSystemContested(coord);
    }

    private ImmutableArray<NexusUnitStackGroup> GetAvailableMoveStacks(HexCoord coord)
    {
        var system = Session.Systems.FirstOrDefault(s => s.Coord == coord);
        if (system is null)
            return ImmutableArray<NexusUnitStackGroup>.Empty;

        var builder = system.GetPlayerMovableStacks(Session.CurrentPlayer.PlayerId).ToBuilder();
        foreach (var pendingStack in _orderDraftState.PendingMoveOrders.Where(o => o.From == coord).SelectMany(o => o.Stacks))
        {
            for (var index = 0; index < builder.Count; index++)
            {
                if (builder[index].DesignId != pendingStack.DesignId || builder[index].RemainingHits != pendingStack.RemainingHits)
                    continue;

                var nextCount = builder[index].Count - pendingStack.Count;
                if (nextCount > 0)
                    builder[index] = builder[index] with { Count = nextCount };
                else
                    builder.RemoveAt(index);

                break;
            }
        }

        return builder.ToImmutable();
    }

    private bool IsSystemContested(HexCoord coord)
    {
        var system = Session.Systems.FirstOrDefault(s => s.Coord == coord);
        if (system is null)
            return false;

        return system.GetPlayerStacks(Session.CurrentPlayer.PlayerId).Length > 0
            && system.GetPlayerStacks(Session.Opponent.PlayerId).Length > 0;
    }

    private int ProjectedSpend => _orderDraftState.ComputeProjectedSpend(Session.CurrentPlayer.Designs ?? []);

    private int ProjectedEnergy => Session.CurrentPlayer.Energy - ProjectedSpend;

    private void ClearParentGameplayError()
    {
        if (GameplayError is not null && GameplayErrorCleared.HasDelegate)
        {
            GameplayErrorCleared.InvokeAsync();
        }
    }

    private async Task SubmitOrdersAsync()
    {
        var command = new NexusTurnOrdersCommand(
            Session.CurrentPlayer.PlayerId,
            Session.RoundNumber,
            _orderDraftState.PendingMoveOrders,
            _orderDraftState.PendingBuildOrders,
            _orderDraftState.PendingBeginNexusGate
        );

        await OnSubmitOrders.InvokeAsync(command);
    }

    private void SetTab(NexusGameplayTab tab)
    {
        if (tab == NexusGameplayTab.Events && Session.LastResolveEvents.Length == 0)
            return;

        _sidebarState = NexusGameplayPanelState.SetActiveSidebarTab(_sidebarState, tab);

        if (tab != NexusGameplayTab.Events)
            DismissEventFocus();
    }

    private static string GetSidebarTabLabel(NexusGameplayTab tab) =>
        tab switch
        {
            NexusGameplayTab.Orders => "Orders",
            NexusGameplayTab.Designs => "Designs",
            NexusGameplayTab.Events => "Events",
            _ => tab.ToString(),
        };

    private bool IsSidebarTabDisabled(NexusGameplayTab tab) =>
        tab == NexusGameplayTab.Events && Session.LastResolveEvents.Length == 0;

    private string GetSidebarTabId(NexusGameplayTab tab) => $"nexus-sidebar-tab-{tab.ToString().ToLowerInvariant()}";

    private string GetSidebarPanelId(NexusGameplayTab tab) => $"nexus-sidebar-panel-{tab.ToString().ToLowerInvariant()}";

    private string ActiveSidebarTabId => GetSidebarTabId(_sidebarState.ActiveTab);

    private string ActiveSidebarPanelId => GetSidebarPanelId(_sidebarState.ActiveTab);

    private void HandleEventFocusRequest(EventFocusRequest request)
    {
        _eventFocusState = NexusGameplayPanelState.ApplyEventFocusRequest(_eventFocusState, request);
        SyncSelectedSystemToEventFocus();
    }

    private void ClearEventPreview()
    {
        HandleEventFocusRequest(EventFocusRequest.PreviewCleared());
    }

    private void DismissEventFocus()
    {
        HandleEventFocusRequest(EventFocusRequest.Dismissed());
    }

    private void SyncSelectedSystemToEventFocus()
    {
        _selectionState = NexusGameplayPanelState.SyncSelectedSystemToEventFocus(
            _selectionState,
            _eventFocusState
        );
    }

    private string GetEventRowClass(NexusResolveEvent evt)
    {
        const string baseRowClass =
            "w-full rounded-lg px-3 py-2.5 text-left text-base transition-colors";
        const string neutralRowClass =
            baseRowClass + " border border-white/10 bg-slate-950/40 text-slate-300 hover:border-amber-400/30 hover:text-slate-100";
        const string activeRowClass =
            baseRowClass + " border border-amber-400/40 bg-amber-500/10 text-amber-100";

        var focus = NexusGameplayPanelState.GetEventFocus(evt);
        if (!focus.HasTarget)
            return neutralRowClass;

        if (_eventFocusState.Preview.Matches(focus))
            return activeRowClass;

        return neutralRowClass;
    }

    private string GetEventRowState(NexusResolveEvent evt)
    {
        var focus = NexusGameplayPanelState.GetEventFocus(evt);
        if (!focus.HasTarget)
            return "inactive";

        return _eventFocusState.Preview.Matches(focus) ? "active" : "inactive";
    }

    private IReadOnlyList<HexCoord> ActiveEventFocusSystems =>
        _eventFocusState.Active.Systems;

    private HexCoord? ActiveEventFocusFrom =>
        _eventFocusState.Active.From;

    private HexCoord? ActiveEventFocusTo =>
        _eventFocusState.Active.To;

    private string GetCompletionMessage()
    {
        if (Session.Completion is null)
            return string.Empty;

        return Session.Completion.Outcome switch
        {
            NexusGameOutcome.Victory
                when Session.Completion.WinnerId == Session.CurrentPlayer.PlayerId =>
                "You activated the Nexus gate. Victory!",
            NexusGameOutcome.Victory => $"{OpponentPlayerName} activated the Nexus gate.",
            NexusGameOutcome.Draw => "The match ended in a draw.",
            _ => "The match has ended.",
        };
    }
}
