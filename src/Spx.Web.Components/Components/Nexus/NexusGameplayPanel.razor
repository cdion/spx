@using System.Collections.Immutable

@if (!string.IsNullOrWhiteSpace(GameplayError))
{
    <AlertBanner>@GameplayError</AlertBanner>
}

<NexusGameplayTopInfoBar RoundNumber="@Session.RoundNumber" CurrentPlayerName="@CurrentPlayerName"
                         OpponentPlayerName="@OpponentPlayerName" CurrentPlayerFaction="@Session.CurrentPlayer.Faction"
                         CurrentPlayerEnergy="@Session.CurrentPlayer.Energy" CurrentPlayerSupplyPool="@Session.CurrentPlayer.SupplyPool"
                         CurrentPlayerCapitalCount="@Session.CurrentPlayer.CapitalCount"
                         CurrentPlayerHasSubmittedOrders="@Session.CurrentPlayer.HasSubmittedOrders"
                         OpponentFaction="@Session.Opponent.Faction" OpponentPlayerEnergy="@Session.Opponent.Energy"
                         OpponentSupplyPool="@Session.Opponent.SupplyPool" OpponentCapitalCount="@Session.Opponent.CapitalCount"
                         OpponentHasSubmittedOrders="@Session.Opponent.HasSubmittedOrders" />

@if (Session.Completion is not null)
{
    <AlertBanner Tone="AlertBanner.AlertTone.Success" Role="status">
        @GetCompletionMessage()

    </AlertBanner>
}

@* Main layout *@
<div class="mt-4 flex min-h-0 flex-col gap-4 sm:flex-row">
    <section class="ui-surface-section flex min-h-0 flex-col p-4 lg:p-5 sm:min-w-0 sm:flex-[3_1_0%]">
        <div class="min-h-0 flex-1">
            <NexusHexGridComponent Systems="@Session.Systems" CurrentPlayerId="@Session.CurrentPlayer.PlayerId"
                                   OpponentPlayerId="@Session.Opponent.PlayerId" CurrentPlayerFaction="@Session.CurrentPlayer.Faction"
                                   CurrentPlayerGateProgress="@Session.CurrentPlayer.GateProgress" IsEditable="@ShowOrdersForm"
                                   PendingMoveOrders="@_pendingMoveOrders" SelectedSystem="@_selectedSystem"
                                   ValidMoveTargets="@_validMoveTargets" EventFocusSystems="@ActiveEventFocusSystems"
                                   EventFocusFrom="@ActiveEventFocusFrom" EventFocusTo="@ActiveEventFocusTo"
                                   OnSystemClicked="OnSystemClicked" OnMapBackgroundClicked="OnMapBackgroundClicked" />
        </div>
    </section>

    <aside class="flex min-h-0 flex-col gap-4 sm:min-w-0 sm:flex-[2_1_0%]">
        <div class="min-h-0 flex-1">
            <NexusSidebarPanelShell>
                <HeaderContent>
                    @if (!HideTabHeader)
                    {
                        <Tabs TItem="NexusGameplayTab" Items="@SidebarTabs" SelectedItem="@_activeSidebarTab"
                              ItemIdSelector="GetSidebarTabId" PanelIdSelector="GetSidebarPanelId"
                              ActiveItemClass="rounded-md border border-white/15 bg-white/10 px-3.5 py-2 text-base font-semibold text-white"
                              InactiveItemClass="rounded-md border border-white/10 px-3.5 py-2 text-base text-slate-400 transition-colors hover:text-slate-200"
                              ItemLabelSelector="GetSidebarTabLabel" DisabledSelector="IsSidebarTabDisabled"
                              OnSelected="SetTab" AriaLabel="Sidebar view" />
                    }
                </HeaderContent>
                <ChildContent>
                    <div id="@ActiveSidebarPanelId" role="tabpanel" aria-labelledby="@ActiveSidebarTabId">
                        @if (_activeSidebarTab == NexusGameplayTab.Events)
                        {
                            <NexusResolveEventsPanel Events="@Session.LastResolveEvents" PlayerNames="@GetPlayerNames()"
                                                     RowClassSelector="GetEventRowClass" OnEventClicked="OnEventClicked"
                                                     OnEventHovered="OnEventHovered" OnEventHoverCleared="OnEventHoverCleared" />
                        }
                        else
                        {
                            <div class="space-y-4">
                                @if (_selectedSystem.HasValue && Session.Systems.FirstOrDefault(s => s.Coord ==
                            _selectedSystem.Value) is { } selectedSystem)
                                {
                                    <NexusSelectedHexPanel System="selectedSystem"
                                                           CurrentPlayerId="@Session.CurrentPlayer.PlayerId" CurrentPlayerName="@CurrentPlayerName"
                                                           OpponentPlayerId="@Session.Opponent.PlayerId"
                                                           CurrentPlayerFaction="@Session.CurrentPlayer.Faction"
                                                           OpponentPlayerName="@OpponentPlayerName"
                                                           CurrentPlayerGateProgress="@Session.CurrentPlayer.GateProgress"
                                                           PendingBeginNexusGate="@_pendingBeginNexusGate" IsEditable="@ShowOrdersForm"
                                                           ProjectedEnergy="@ProjectedEnergy"
                                                           AvailableUnits="@GetAvailableUnits(selectedSystem.Coord)"
                                                           PendingBuildOrders="@_pendingBuildOrders"
                                                           OnFleetSelectionChanged="OnFleetSelectionChanged" OnBuildAddOne="AddBuildOrder"
                                                           OnBuildAddMax="AddBuildOrderMax" OnBuildRemoveOne="RemoveBuildOrder"
                                                           OnBuildRemoveAll="RemoveBuildOrdersForUnit" OnToggleNexusGate="ToggleNexusGate" />
                                }
                                @if (_pendingMoveOrders.Count > 0 || _pendingBuildOrders.Count > 0 ||
                            _pendingBeginNexusGate)
                                {
                                    <NexusOrdersPanel MoveOrders="@_pendingMoveOrders" BuildOrders="@_pendingBuildOrders"
                                                      CurrentPlayerName="@CurrentPlayerName" CurrentPlayerHomeCoord="@CurrentPlayerHomeCoord"
                                                      BeginNexusGate="@_pendingBeginNexusGate" IsEditable="@ShowOrdersForm"
                                                      OnRemoveMoveOrder="RemoveMoveOrder" OnRemoveBuildOrder="RemoveBuildOrder"
                                                      OnRemoveGateOrder="() => _pendingBeginNexusGate = false" />
                                }
                            </div>
                        }
                    </div>
                </ChildContent>
            </NexusSidebarPanelShell>
        </div>
        @if (ShowOrdersForm)
        {
            <button class="ui-button-primary w-full" @onclick="SubmitOrdersAsync" disabled="@IsSubmittingAction">
                @(IsSubmittingAction ? "Submitting..." : "Submit Orders")
            </button>
        }
    </aside>
</div>

@code {
    [Parameter, EditorRequired]
    public NexusGameView Session { get; set; } = default!;

    [Parameter, EditorRequired]
    public GameLobbyView Lobby { get; set; } = default!;

    [Parameter]
    public bool IsSubmittingAction { get; set; }

    [Parameter]
    public string? GameplayError { get; set; }

    [Parameter]
    public EventCallback<NexusTurnOrdersCommand> OnSubmitOrders { get; set; }

    [Parameter]
    public NexusGameplayTab? SelectedTab { get; set; }

    [Parameter]
    public bool HideTabHeader { get; set; }

    private readonly List<NexusMoveOrder> _pendingMoveOrders = [];
    private readonly List<NexusBuildOrder> _pendingBuildOrders = [];
    private bool _pendingBeginNexusGate;
    private Guid? _lastKnownGameId;
    private int? _lastKnownRound;
    private HexCoord? _selectedSystem;
    private ImmutableDictionary<NexusUnitType, int> _stagedMoveUnits =
        ImmutableDictionary<NexusUnitType, int>.Empty;
    private IReadOnlyList<HexCoord> _validMoveTargets = [];
    private static readonly NexusGameplayTab[] SidebarTabs = [NexusGameplayTab.Orders, NexusGameplayTab.Events];
    private NexusGameplayTab _activeSidebarTab = NexusGameplayTab.Orders;
    private EventFocus _hoverEventFocus = EventFocus.None;
    private EventFocus _pinnedEventFocus = EventFocus.None;

    protected override void OnParametersSet()
    {
        if (!NexusGameplayPanelState.ShouldResetUiState(
                Session.GameId,
                Session.RoundNumber,
                _lastKnownGameId,
                _lastKnownRound
            ))
            return;

        _lastKnownGameId = Session.GameId;
        _lastKnownRound = Session.RoundNumber;
        _pendingMoveOrders.Clear();
        _pendingBuildOrders.Clear();
        _pendingBeginNexusGate = false;
        ClearSelection();

        _hoverEventFocus = EventFocus.None;
        _pinnedEventFocus = EventFocus.None;

        if (Session.LastResolveEvents.Length == 0)
        {
            _activeSidebarTab = NexusGameplayTab.Orders;
        }

        if (Session.LastResolveEvents.Length > 0)
        {
            _activeSidebarTab = NexusGameplayTab.Events;
            var firstFocusable = Session.LastResolveEvents
                .Select(GetEventFocus)
                .FirstOrDefault(f => f.HasTarget);
            if (firstFocusable is not null)
            {
                _pinnedEventFocus = firstFocusable;
                if (firstFocusable.Primary.HasValue)
                    _selectedSystem = firstFocusable.Primary.Value;
            }
        }

        ApplySelectedTabOverride();

        return;

        void ApplySelectedTabOverride()
        {
            if (!SelectedTab.HasValue)
            {
                return;
            }

            _activeSidebarTab = IsSidebarTabDisabled(SelectedTab.Value)
                ? NexusGameplayTab.Orders
                : SelectedTab.Value;
        }
    }

    private bool ShowOrdersForm =>
        Lobby.IsCurrentUserActive
        && !Session.CurrentPlayer.HasSubmittedOrders
        && Session.Completion is null;

    private string CurrentPlayerName => Lobby.CurrentPlayerName;

    private string OpponentPlayerName =>
        Lobby.Players.FirstOrDefault(p => p.PlayerId != Lobby.CurrentPlayerId)?.Name
        ?? "your opponent";

    private HexCoord? CurrentPlayerHomeCoord =>
        Session.Systems.FirstOrDefault(s => s.HomePlayerId == Session.CurrentPlayer.PlayerId)?.Coord;

    private IReadOnlyDictionary<Guid, string> GetPlayerNames() =>
        new Dictionary<Guid, string>
        {
            [Session.CurrentPlayer.PlayerId] = CurrentPlayerName,
            [Session.Opponent.PlayerId] = OpponentPlayerName,
        };

    private void OnSystemClicked(HexCoord coord)
    {
        if (!ShowOrdersForm)
            return;

        if (_selectedSystem.HasValue && !_stagedMoveUnits.IsEmpty && _validMoveTargets.Contains(coord))
        {
            _pendingMoveOrders.Add(new NexusMoveOrder(_selectedSystem.Value, coord, _stagedMoveUnits));
            _stagedMoveUnits = ImmutableDictionary<NexusUnitType, int>.Empty;
            _validMoveTargets = [];
            return;
        }

        _selectedSystem = _selectedSystem == coord ? null : coord;
        _stagedMoveUnits = ImmutableDictionary<NexusUnitType, int>.Empty;
        _validMoveTargets = [];
    }

    private void OnMapBackgroundClicked()
    {
        ClearSelection();
    }

    private void RemoveMoveOrder(NexusMoveOrder order) => _pendingMoveOrders.Remove(order);

    private void RemoveBuildOrder(NexusUnitType unit)
    {
        var idx = _pendingBuildOrders.FindIndex(o => o.UnitType == unit);
        if (idx < 0)
            return;
        if (_pendingBuildOrders[idx].Count <= 1)
            _pendingBuildOrders.RemoveAt(idx);
        else
            _pendingBuildOrders[idx] = _pendingBuildOrders[idx] with { Count = _pendingBuildOrders[idx].Count - 1 };
    }

    private void RemoveBuildOrder(NexusBuildOrder order)
    {
        _pendingBuildOrders.RemoveAll(o => o.UnitType == order.UnitType);
    }

    private void ClearSelection()
    {
        _selectedSystem = null;
        _stagedMoveUnits = ImmutableDictionary<NexusUnitType, int>.Empty;
        _validMoveTargets = [];
    }

    private void OnFleetSelectionChanged(ImmutableDictionary<NexusUnitType, int> units)
    {
        _stagedMoveUnits = units;

        if (_selectedSystem is null || units.Count == 0)
        {
            _validMoveTargets = [];
            return;
        }

        _validMoveTargets = NexusViewQueries.GetValidMoveDestinations(
            Session, Session.CurrentPlayer.PlayerId, _selectedSystem!.Value);
    }

    private void AddBuildOrder(NexusUnitType unit)
    {
        if (ProjectedEnergy < unit.Cost())
            return;
        var idx = _pendingBuildOrders.FindIndex(o => o.UnitType == unit);
        if (idx >= 0)
            _pendingBuildOrders[idx] = _pendingBuildOrders[idx] with { Count = _pendingBuildOrders[idx].Count + 1 };
        else
            _pendingBuildOrders.Add(new NexusBuildOrder(unit, 1));
    }

    private void AddBuildOrderMax(NexusUnitType unit)
    {
        var maxAdd = ProjectedEnergy / unit.Cost();
        for (var i = 0; i < maxAdd; i++)
            AddBuildOrder(unit);
    }

    private void RemoveBuildOrdersForUnit(NexusUnitType unit)
    {
        _pendingBuildOrders.RemoveAll(o => o.UnitType == unit);
    }

    private void ToggleNexusGate()
    {
        if (_selectedSystem is null || !CanShowGateOption(_selectedSystem.Value))
            return;

        _pendingBeginNexusGate = !_pendingBeginNexusGate;
    }

    private bool CanShowGateOption(HexCoord coord)
    {
        if (Session.CurrentPlayer.GateProgress == NexusGateProgress.Completed)
            return false;

        var system = Session.Systems.FirstOrDefault(s => s.Coord == coord);
        if (system is null || !system.IsNexus)
            return false;

        var (_, _, planetary) = NexusHexHelpers.GetUnitCounts(system, Session.CurrentPlayer.PlayerId);
        return planetary > 0;
    }

    private ImmutableDictionary<NexusUnitType, int> GetAvailableUnits(HexCoord coord)
    {
        var system = Session.Systems.FirstOrDefault(s => s.Coord == coord);
        if (system is null)
            return ImmutableDictionary<NexusUnitType, int>.Empty;

        if (!system.Units.TryGetValue(Session.CurrentPlayer.PlayerId, out var unitsAtSystem))
            return ImmutableDictionary<NexusUnitType, int>.Empty;

        var assigned = _pendingMoveOrders
            .Where(o => o.From == coord)
            .SelectMany(o => o.Units)
            .GroupBy(kv => kv.Key)
            .ToDictionary(g => g.Key, g => g.Sum(kv => kv.Value));

        return unitsAtSystem
            .Select(kv => (Type: kv.Key, Count: kv.Value - assigned.GetValueOrDefault(kv.Key)))
            .Where(x => x.Count > 0)
            .ToImmutableDictionary(x => x.Type, x => x.Count);
    }

    private int ProjectedSpend =>
        _pendingBuildOrders.Sum(o => o.UnitType.Cost() * o.Count) + (_pendingBeginNexusGate ? 12 : 0);

    private int ProjectedEnergy => Session.CurrentPlayer.Energy - ProjectedSpend;

    private async Task SubmitOrdersAsync()
    {
        var command = new NexusTurnOrdersCommand(
            Session.CurrentPlayer.PlayerId,
            Session.RoundNumber,
            _pendingMoveOrders.ToImmutableArray(),
            _pendingBuildOrders.ToImmutableArray(),
            _pendingBeginNexusGate
        );

        await OnSubmitOrders.InvokeAsync(command);

        _pendingMoveOrders.Clear();
        _pendingBuildOrders.Clear();
        _pendingBeginNexusGate = false;
    }

    private void SetTab(NexusGameplayTab tab)
    {
        if (tab == NexusGameplayTab.Events && Session.LastResolveEvents.Length == 0)
            return;

        _activeSidebarTab = tab;
    }

    private static string GetSidebarTabLabel(NexusGameplayTab tab) =>
        tab switch
        {
            NexusGameplayTab.Orders => "Orders",
            NexusGameplayTab.Events => "Events",
            _ => tab.ToString(),
        };

    private bool IsSidebarTabDisabled(NexusGameplayTab tab) =>
        tab == NexusGameplayTab.Events && Session.LastResolveEvents.Length == 0;

    private string GetSidebarTabId(NexusGameplayTab tab) => $"nexus-sidebar-tab-{tab.ToString().ToLowerInvariant()}";

    private string GetSidebarPanelId(NexusGameplayTab tab) => $"nexus-sidebar-panel-{tab.ToString().ToLowerInvariant()}";

    private string ActiveSidebarTabId => GetSidebarTabId(_activeSidebarTab);

    private string ActiveSidebarPanelId => GetSidebarPanelId(_activeSidebarTab);

    private void OnEventHovered(NexusResolveEvent evt)
    {
        var focus = GetEventFocus(evt);
        if (!focus.HasTarget)
            return;

        if (IsSameFocus(_hoverEventFocus, focus))
            return;

        _hoverEventFocus = focus;
        if (focus.Primary.HasValue)
            _selectedSystem = focus.Primary.Value;
    }

    private void OnEventHoverCleared()
    {
        if (!_hoverEventFocus.HasTarget)
            return;

        _hoverEventFocus = EventFocus.None;
        if (_pinnedEventFocus.Primary.HasValue)
            _selectedSystem = _pinnedEventFocus.Primary.Value;
    }

    private void OnEventClicked(NexusResolveEvent evt)
    {
        var focus = GetEventFocus(evt);
        if (!focus.HasTarget)
            return;

        _pinnedEventFocus = focus;
        if (focus.Primary.HasValue)
            _selectedSystem = focus.Primary.Value;
    }

    private string GetEventRowClass(NexusResolveEvent evt)
    {
        const string baseRowClass =
            "w-full rounded-lg px-3 py-2.5 text-left text-base transition-colors";
        const string neutralRowClass =
            baseRowClass + " border border-white/10 bg-slate-950/40 text-slate-300 hover:border-amber-400/30 hover:text-slate-100";
        const string activeRowClass =
            baseRowClass + " border border-amber-400/40 bg-amber-500/10 text-amber-100";

        var focus = GetEventFocus(evt);
        if (!focus.HasTarget)
            return neutralRowClass;

        var isHovered = IsSameFocus(_hoverEventFocus, focus);
        var isPinned = IsSameFocus(_pinnedEventFocus, focus);
        if (isHovered || isPinned)
            return activeRowClass;

        return neutralRowClass;
    }

    private IReadOnlyList<HexCoord> ActiveEventFocusSystems =>
        _hoverEventFocus.HasTarget ? _hoverEventFocus.Systems : _pinnedEventFocus.Systems;

    private HexCoord? ActiveEventFocusFrom =>
        _hoverEventFocus.HasTarget ? _hoverEventFocus.From : _pinnedEventFocus.From;

    private HexCoord? ActiveEventFocusTo =>
        _hoverEventFocus.HasTarget ? _hoverEventFocus.To : _pinnedEventFocus.To;

    private static bool IsSameFocus(EventFocus a, EventFocus b)
    {
        if (!a.HasTarget || !b.HasTarget)
            return false;

        return a.Primary == b.Primary && a.From == b.From && a.To == b.To;
    }

    private static EventFocus GetEventFocus(NexusResolveEvent evt) =>
        evt switch
        {
            NexusUnitsMovedEvent e =>
                new EventFocus([e.From, e.To], e.From, e.To, e.To),
            NexusPlanetaryControlEvent e => new EventFocus([e.System], Primary: e.System),
            NexusSystemContestedEvent e => new EventFocus([e.System], Primary: e.System),
            NexusSystemUncontrolledEvent e => new EventFocus([e.System], Primary: e.System),
            NexusCombatBeganEvent e => new EventFocus([e.System], Primary: e.System),
            NexusPhaseResultEvent e => new EventFocus([e.System], Primary: e.System),
            NexusSystemClearedEvent e => new EventFocus([e.System], Primary: e.System),
            NexusUnitDeployedEvent e => new EventFocus([e.HomeSystem], Primary: e.HomeSystem),
            NexusGateStartedEvent e => new EventFocus([e.System], Primary: e.System),
            NexusGateCompletedEvent e => new EventFocus([e.System], Primary: e.System),
            NexusGateCancelledEvent e => new EventFocus([e.System], Primary: e.System),
            NexusIncomeEvent e when e.Sources.Length > 0 =>
                new EventFocus(e.Sources.ToArray(), Primary: e.Sources[0]),
            _ => EventFocus.None,
        };

    private sealed record EventFocus(
        IReadOnlyList<HexCoord> Systems,
        HexCoord? From = null,
        HexCoord? To = null,
        HexCoord? Primary = null
    )
    {
        public static EventFocus None { get; } = new([]);

        public bool HasTarget => Systems.Count > 0 || From.HasValue || To.HasValue || Primary.HasValue;
    }

    private string GetCompletionMessage()
    {
        if (Session.Completion is null)
            return string.Empty;

        return Session.Completion.Outcome switch
        {
            NexusGameOutcome.Victory
                when Session.Completion.WinnerId == Session.CurrentPlayer.PlayerId =>
                "You activated the Nexus gate. Victory!",
            NexusGameOutcome.Victory => $"{OpponentPlayerName} activated the Nexus gate.",
            NexusGameOutcome.Draw => "The match ended in a draw.",
            _ => "The match has ended.",
        };
    }
}
