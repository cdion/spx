@using Spx.Nexus.Domain

@{
    var displayName = GetDisplayName();
    var accentClass = GetAccentClass();
}

<span class="inline-flex items-center gap-1 @accentClass">
    @if (ShowHomeStar && IsHomeSystem)
    {
        <span class="inline-flex h-4 w-4 items-center justify-center rounded-full border border-white/15 bg-white/5"
              aria-label="Home system">
            <svg viewBox="-5 -5 10 10" class="h-3 w-3 fill-white/85" aria-hidden="true" focusable="false">
                <polygon points="0,-4 1.1,-1.5 3.8,-1.2 1.8,0.8 2.4,3.6 0,2.2 -2.4,3.6 -1.8,0.8 -3.8,-1.2 -1.1,-1.5" />
            </svg>
        </span>
    }
    <span class="font-semibold">@displayName</span>
    @if (ShowIncome && IncomeValue > 0)
    {
        <span class="ui-type-meta text-yellow-400/80">⚡@IncomeValue</span>
    }
    @if (ShowIncome && SupplyValue > 0)
    {
        <span class="ui-type-meta text-sky-400/80">⬡@SupplyValue</span>
    }
</span>

@code {
    [Parameter, EditorRequired]
    public HexCoord Coord { get; set; }

    [Parameter]
    public string? DisplayName { get; set; }

    [Parameter]
    public Guid? ControlOwner { get; set; }

    [Parameter, EditorRequired]
    public NexusPlayerContext CurrentPlayer { get; set; } = null!;

    [Parameter]
    public NexusPlayerContext? Opponent { get; set; }

    [Parameter]
    public bool ShowIncome { get; set; }

    [Parameter]
    public int IncomeValue { get; set; }

    [Parameter]
    public int SupplyValue { get; set; }

    [Parameter]
    public bool ShowHomeStar { get; set; }

    private bool IsHomeSystem =>
        Coord == CurrentPlayer.HomeCoord
        || (Opponent?.HomeCoord is { } oc && Coord == oc);

    private NexusPlayerContext? HomeOwner =>
        Coord == CurrentPlayer.HomeCoord ? CurrentPlayer
        : Opponent is not null && Coord == Opponent.HomeCoord ? Opponent
        : null;

    private NexusPlayerContext? ControlOwnerContext =>
        ControlOwner is null ? null
        : ControlOwner == CurrentPlayer.PlayerId ? CurrentPlayer
        : Opponent is not null && ControlOwner == Opponent.PlayerId ? Opponent
        : null;

    private string GetDisplayName()
    {
        if (!string.IsNullOrEmpty(DisplayName))
            return DisplayName;

        if (HomeOwner is { } owner)
            return NexusHomeSystemNames.GetDisplayName(owner.DisplayName);

        return NexusMapTopology.GetSectorDisplayName(Coord);
    }

    private string GetAccentClass()
    {
        // Home system takes priority over control owner
        if (HomeOwner is { } home)
            return NexusFactionCss.AccentText(home.Faction);

        if (ControlOwnerContext is { } control)
            return NexusFactionCss.AccentText(control.Faction);

        return "text-slate-300";
    }
}
