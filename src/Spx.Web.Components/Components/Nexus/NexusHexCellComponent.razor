@using System.Text

<g @onclick="HandleClick" @onclick:stopPropagation="true" class="@(IsClickable ? "cursor-pointer" : "")"
   data-testid="@NexusGameplayPanelTestIds.System(System.Coord)">
    <polygon points="@NexusHexHelpers.HexPoints(Center)"
             fill="@NexusHexHelpers.GetHexFill(System, CurrentPlayerId, CurrentPlayerFaction)"
             stroke="rgba(255,255,255,0.12)" stroke-width="1" opacity="0.92" />

    @* Triangle cap — home system indicator or Nexus gold *@
    @if (NexusHexHelpers.GetCapFill(System, CurrentPlayerId, CurrentPlayerFaction) is { } capFill)
    {
        <polygon points="@NexusHexHelpers.CapPoints(Center)" fill="@capFill" />
    }

    @* Star glyph on home systems *@
    @if (System.HomePlayerId.HasValue)
    {
        <polygon points="@NexusHexHelpers.StarPoints(Center)" fill="rgba(255,255,255,0.85)" />
    }

    @* Sector name label, income, unit counts, gate badge *@
    @((MarkupString)SectorNameLabel)
    @((MarkupString)IncomeLabelMarkup)
    @((MarkupString)UnitCountsMarkup)
    @((MarkupString)NexusGateBadgeMarkup)
</g>

@code {
    [Parameter, EditorRequired]
    public NexusSystemView System { get; set; } = default!;

    [Parameter, EditorRequired]
    public (double X, double Y) Center { get; set; }

    [Parameter, EditorRequired]
    public Guid CurrentPlayerId { get; set; }

    [Parameter]
    public Guid? OpponentPlayerId { get; set; }

    [Parameter]
    public NexusGateProgress CurrentPlayerGateProgress { get; set; }

    [Parameter]
    public NexusGateProgress OpponentGateProgress { get; set; }

    [Parameter]
    public NexusFactionColor CurrentPlayerFaction { get; set; }

    [Parameter]
    public bool IsClickable { get; set; }

    [Parameter]
    public EventCallback<HexCoord> OnClicked { get; set; }

    private string SectorNameLabel
    {
        get
        {
            if (System.IsNexus || System.HomePlayerId.HasValue)
                return string.Empty;
            var name = NexusMapTopology.GetSectorDisplayName(System.Coord);
            const string style =
                "fill=\"rgba(148,163,184,0.45)\" font-size=\"7\"";
            var y = NexusHexHelpers.Fmt(Center.Y - 10);
            var cx = NexusHexHelpers.Fmt(Center.X);
            return $"<text x=\"{cx}\" y=\"{y}\" text-anchor=\"middle\" {style}>{name}</text>";
        }
    }

    private string IncomeLabelMarkup
    {
        get
        {
            if (System.IsNexus || System.IncomeValue == 0)
                return string.Empty;

            return $"<text x=\"{NexusHexHelpers.Fmt(Center.X)}\" y=\"{NexusHexHelpers.Fmt(Center.Y + 22)}\" "
                + "text-anchor=\"middle\" fill=\"rgba(250,204,21,0.7)\" font-size=\"7\" font-family=\"monospace\">"
                + $"+{System.IncomeValue}&#x26A1;</text>";
        }
    }

    private string UnitCountsMarkup
    {
        get
        {
            var sb = new StringBuilder();

            var myColor = CurrentPlayerFaction == NexusFactionColor.Red ? "#f87171" : "#60a5fa";
            var opColor = CurrentPlayerFaction == NexusFactionColor.Red ? "#60a5fa" : "#f87171";
            var myDim = CurrentPlayerFaction == NexusFactionColor.Red ? "rgba(248,113,113,0.25)" : "rgba(96,165,250,0.25)";
            var opDim = CurrentPlayerFaction == NexusFactionColor.Red ? "rgba(96,165,250,0.25)" : "rgba(248,113,113,0.25)";

            var (myC, myS, myP) = NexusHexHelpers.GetUnitCounts(System, CurrentPlayerId);
            var hasMyUnits = myC + myS + myP > 0;

            var hasOpUnits = false;
            int opC = 0, opS = 0, opP = 0;
            if (OpponentPlayerId.HasValue)
            {
                (opC, opS, opP) = NexusHexHelpers.GetUnitCounts(System, OpponentPlayerId.Value);
                hasOpUnits = opC + opS + opP > 0;
            }

            // When both factions present, offset left/right; when only one, center it.
            var myOffsetX = hasMyUnits && hasOpUnits ? Center.X - 16 : Center.X;
            var opOffsetX = hasMyUnits && hasOpUnits ? Center.X + 16 : Center.X;
            var pipY = Center.Y + 10;

            // Three pips per faction: Strike ▲, Capital ◆, Planetary ●
            // Spaced 8px apart horizontally
            static void RenderFactionPips(
                StringBuilder sb,
                double originX,
                double y,
                string activeColor,
                string dimColor,
                int c,
                int s,
                int p
            )
            {
                NexusHexHelpers.AppendCategoryPip(sb, originX - 8, y, NexusUnitCategory.Strike, activeColor, dimColor, s);
                NexusHexHelpers.AppendCategoryPip(sb, originX, y, NexusUnitCategory.Capital, activeColor, dimColor, c);
                NexusHexHelpers.AppendCategoryPip(sb, originX + 8, y, NexusUnitCategory.Planetary, activeColor, dimColor, p);
            }

            if (hasMyUnits)
            {
                RenderFactionPips(sb, myOffsetX, pipY, myColor, myDim, myC, myS, myP);
            }

            if (hasOpUnits && OpponentPlayerId.HasValue)
            {
                RenderFactionPips(sb, opOffsetX, pipY, opColor, opDim, opC, opS, opP);
            }

            return sb.ToString();
        }
    }

    private string NexusGateBadgeMarkup
    {
        get
        {
            if (
                !System.IsNexus
                || (
                    CurrentPlayerGateProgress == NexusGateProgress.None
                    && OpponentGateProgress == NexusGateProgress.None
                )
            )
                return string.Empty;

            var currentColorPair = CurrentPlayerFaction == NexusFactionColor.Red
                ? ("#f87171", "rgba(248,113,113,0.18)")
                : ("#60a5fa", "rgba(96,165,250,0.18)");
            var opponentColorPair = CurrentPlayerFaction == NexusFactionColor.Red
                ? ("#60a5fa", "rgba(96,165,250,0.18)")
                : ("#f87171", "rgba(248,113,113,0.18)");

            var showCurrent = CurrentPlayerGateProgress != NexusGateProgress.None;
            var showOpponent = OpponentGateProgress != NexusGateProgress.None;

            if (showCurrent && showOpponent)
            {
                return RenderGatePips(CurrentPlayerGateProgress, currentColorPair, Center.Y - 6)
                    + RenderGatePips(OpponentGateProgress, opponentColorPair, Center.Y + 2);
            }

            if (showCurrent)
                return RenderGatePips(CurrentPlayerGateProgress, currentColorPair, Center.Y - 2);

            return RenderGatePips(OpponentGateProgress, opponentColorPair, Center.Y - 2);
        }
    }

    private string RenderGatePips(
        NexusGateProgress progress,
        (string ActiveFill, string DimFill) colors,
        double y
    )
    {
        var cx1 = NexusHexHelpers.Fmt(Center.X - 5);
        var cx2 = NexusHexHelpers.Fmt(Center.X + 5);
        var cy = NexusHexHelpers.Fmt(y);
        var pip2Fill = progress >= NexusGateProgress.Completed ? colors.ActiveFill : colors.DimFill;

        return $"<circle cx=\"{cx1}\" cy=\"{cy}\" r=\"3.5\" fill=\"{colors.ActiveFill}\"/>"
            + $"<circle cx=\"{cx2}\" cy=\"{cy}\" r=\"3.5\" fill=\"{pip2Fill}\"/>";
    }

    private Task HandleClick() =>
        IsClickable ? OnClicked.InvokeAsync(System.Coord) : Task.CompletedTask;
}
