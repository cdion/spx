@using Spx.Nexus.Domain
@using Spx.Web.Components.Nexus.Events

<div>
    @if (Events.Count == 0)
    {
        <p class="ui-type-muted">No events from the previous round.</p>
    }
    else
    {
        var ctx = new EventRowContext(CurrentPlayer, Opponent, Designs);

        <div class="space-y-2">
            @for (var index = 0; index < Events.Count; index++)
            {
                var evt = Events[index];
                <div class="whitespace-pre-line @RowClassSelector(evt)"
                     data-testid="@NexusGameplayPanelTestIds.ResolveEventRow(index)"
                     data-focus-state="@RowStateSelector(evt)"
                     @onmouseenter="() => OnEventFocusRequested.InvokeAsync(EventFocusRequest.PreviewRequested(evt))"
                     @onmouseleave="() => OnEventFocusRequested.InvokeAsync(EventFocusRequest.PreviewCleared())">
                    @switch (evt)
                    {
                        case NexusUnitsMovedEvent e:
                            <NexusUnitsMovedEventRow Event="@e" Context="@ctx" />
                            break;
                        case NexusPlanetaryControlEvent e:
                            <NexusPlanetaryControlEventRow Event="@e" Context="@ctx" />
                            break;
                        case NexusSystemContestedEvent e:
                            <NexusSystemContestedEventRow Event="@e" Context="@ctx" />
                            break;
                        case NexusSystemUncontrolledEvent e:
                            <NexusSystemUncontrolledEventRow Event="@e" Context="@ctx" />
                            break;
                        case NexusCombatResultEvent e:
                            <NexusCombatResultEventRow Event="@e" Context="@ctx" />
                            break;
                        case NexusSystemClearedEvent e:
                            <NexusSystemClearedEventRow Event="@e" Context="@ctx" />
                            break;
                        case NexusIncomeEvent e:
                            <NexusIncomeEventRow Event="@e" Context="@ctx" />
                            break;
                        case NexusUnitDeployedEvent e:
                            <NexusUnitDeployedEventRow Event="@e" Context="@ctx" />
                            break;
                        case NexusGateStartedEvent e:
                            <NexusGateStartedEventRow Event="@e" Context="@ctx" />
                            break;
                        case NexusGateCompletedEvent e:
                            <NexusGateCompletedEventRow Event="@e" Context="@ctx" />
                            break;
                        case NexusGateCancelledEvent e:
                            <NexusGateCancelledEventRow Event="@e" Context="@ctx" />
                            break;
                        case NexusCapitalDisbandedEvent e:
                            <NexusCapitalDisbandedEventRow Event="@e" Context="@ctx" />
                            break;
                        case NexusVictoryEvent e:
                            <NexusVictoryEventRow Event="@e" Context="@ctx" />
                            break;
                        case NexusDrawEvent e:
                            <NexusDrawEventRow Event="@e" Context="@ctx" />
                            break;
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<NexusResolveEvent> Events { get; set; } = [];

    [Parameter, EditorRequired]
    public NexusPlayerContext CurrentPlayer { get; set; } = null!;

    [Parameter]
    public NexusPlayerContext? Opponent { get; set; }

    [Parameter, EditorRequired]
    public Func<NexusResolveEvent, string> RowClassSelector { get; set; } =
        _ => "w-full rounded-lg border border-white/10 bg-slate-950/40 px-3 py-2 text-left text-sm text-slate-300";

    [Parameter, EditorRequired]
    public Func<NexusResolveEvent, string> RowStateSelector { get; set; } = _ => "inactive";

    [Parameter, EditorRequired]
    public IReadOnlyDictionary<Guid, NexusUnitDesign> Designs { get; set; } = null!;

    [Parameter]
    public EventCallback<EventFocusRequest> OnEventFocusRequested { get; set; }

    private string RowClassFor(NexusResolveEvent evt) => RowClassSelector(evt);

    private string RowStateFor(NexusResolveEvent evt) => RowStateSelector(evt);
}
