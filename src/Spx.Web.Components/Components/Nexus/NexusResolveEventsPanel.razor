<div>
    @if (Events.Count == 0)
    {
        <p class="ui-type-muted">No events from the previous round.</p>
    }
    else
    {
        <div class="space-y-2">
            @for (var index = 0; index < Events.Count; index++)
            {
                var evt = Events[index];
                <div class="whitespace-pre-line @GetRowClass(evt)"
                     data-testid="@NexusGameplayPanelTestIds.ResolveEventRow(index)" data-focus-state="@GetRowState(evt)"
                     @onmouseenter="() => OnEventFocusRequested.InvokeAsync(EventFocusRequest.PreviewRequested(evt))"
                     @onmouseleave="() => OnEventFocusRequested.InvokeAsync(EventFocusRequest.PreviewCleared())">
                    @FormatEvent(evt)
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<NexusResolveEvent> Events { get; set; } = [];

    [Parameter, EditorRequired]
    public IReadOnlyDictionary<Guid, string> PlayerNames { get; set; } =
        new Dictionary<Guid, string>();

    [Parameter, EditorRequired]
    public Guid ViewingPlayerId { get; set; }

    [Parameter, EditorRequired]
    public string CurrentPlayerName { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string OpponentPlayerName { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public Func<NexusResolveEvent, string> RowClassSelector { get; set; } =
        _ => "w-full rounded-lg border border-white/10 bg-slate-950/40 px-3 py-2 text-left text-sm text-slate-300";

    [Parameter, EditorRequired]
    public Func<NexusResolveEvent, string> RowStateSelector { get; set; } = _ => "inactive";

    [Parameter]
    public EventCallback<EventFocusRequest> OnEventFocusRequested { get; set; }

    private string GetRowClass(NexusResolveEvent evt) => RowClassSelector(evt);

    private string GetRowState(NexusResolveEvent evt) => RowStateSelector(evt);

    private string FormatEvent(NexusResolveEvent evt) =>
        NexusHomeSystemNames.ReplacePerspectiveLabels(
            NexusSessionEventFormatter.Format(evt, PlayerNames, ViewingPlayerId),
            CurrentPlayerName,
            OpponentPlayerName
        );
}
