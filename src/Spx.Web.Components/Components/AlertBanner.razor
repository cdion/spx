@if (ChildContent is not null)
{
    <div class="@CssClass" role="@Role">@ChildContent</div>
}

@code {
    public enum AlertTone { Error, Success, Warning }

    [Parameter]
    public AlertTone Tone { get; set; } = AlertTone.Error;

    [Parameter]
    public string Role { get; set; } = "alert";

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string CssClass => Tone switch
    {
        AlertTone.Success => "ui-alert ui-alert-success",
        AlertTone.Warning => "ui-alert ui-alert-warning",
        _ => "ui-alert ui-alert-error"
    };
}
